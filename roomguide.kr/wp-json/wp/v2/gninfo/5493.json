{"id":5493,"date":"2025-01-06T20:15:57","date_gmt":"2025-01-06T11:15:57","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ed%8c%8c%ed%8b%b0%ec%9b%90\/"},"modified":"2025-01-15T22:10:57","modified_gmt":"2025-01-15T13:10:57","slug":"party1","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/party1\/","title":{"rendered":"\ud30c\ud2f0\uc6d0"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \uac00\ub77c\uc624\ucf00 \ud30c\ud2f0\uc6d0 \u2013 \ub2f9\uc2e0\ub9cc\uc758 \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \uc704\ud55c \uacf5\uac04<\/h3>\n\n\n\n<p>\uac15\ub0a8 <strong>\uac00\ub77c\uc624\ucf00 \ud30c\ud2f0\uc6d0<\/strong>\uc740 \uc138\ub828\ub41c \ubd84\uc704\uae30\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc11c\ube44\uc2a4\ub97c \uacb0\ud569\ud558\uc5ec \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud55c \ud30c\ud2f0\uc6d0\uc740 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \uce5c\ubaa9 \ubaa8\uc784, \uc0dd\uc77c \ud30c\ud2f0 \ub4f1 \ub2e4\uc591\ud55c \ubaa9\uc801\uc5d0 \ub9de\ub294 \uc644\ubcbd\ud55c \uacf5\uac04\uc73c\ub85c, \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc774 \uacf5\uc874\ud558\ub294 \ub3c5\ubcf4\uc801\uc778 \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud30c\ud2f0\uc6d0\ub9cc\uc758 \ub3c5\ucc3d\uc801\uc778 \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\ud30c\ud2f0\uc6d0\uc740 \ud2b8\ub80c\ub514\ud55c \uac10\uac01\uacfc \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\ub85c \ud2b9\ubcc4\ud568\uc744 \ub354\ud569\ub2c8\ub2e4. \ub8f8\ub9c8\ub2e4 \uac01\uae30 \ub2e4\ub978 \ud14c\ub9c8\uc640 \ub514\ud14c\uc77c\uc774 \uc0b4\uc544 \uc788\ub294 \uacf5\uac04\uc740 \uace0\uac1d\ub2d8\uaed8 \uace0\uae09\uc2a4\ub7ec\uc6c0\uacfc \ud3b8\uc548\ud568\uc744 \ub3d9\uc2dc\uc5d0 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub2e8\uc21c\ud55c \uac00\ub77c\uc624\ucf00\uac00 \uc544\ub2cc \ud2b9\ubcc4\ud55c \uc774\ubca4\ud2b8\ub97c \uc644\uc131\ud558\ub294 \uc7a5\uc18c\ub85c, \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \ub2e4\uc591\ud55c \uc635\uc158\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\uc5d0\uc11c \ub204\ub9ac\ub294 \uc644\ubcbd\ud55c \uc811\uadfc\uc131<\/h3>\n\n\n\n<p>\ud30c\ud2f0\uc6d0\uc740 \uac15\ub0a8 \ud55c\ubcf5\ud310\uc5d0 \uc704\uce58\ud558\uc5ec \uc774\ub3d9\uc774 \ud3b8\ub9ac\ud558\uace0 \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub0a9\ub2c8\ub2e4. \uac15\ub0a8\uc758 \ud654\ub824\ud55c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c\ub3c4 \ucc28\ubd84\ud558\uace0 \ud488\uaca9 \uc788\ub294 \uc2dc\uac04\uc744 \ub204\ub9b4 \uc218 \uc788\ub294 \uacf5\uac04\uc73c\ub85c, \ud2b9\ubcc4\ud55c \ub0a0\uc744 \uc704\ud55c \ucd5c\uc801\uc758 \uc7a5\uc18c\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ub2e4\uc591\ud55c \ubaa9\uc801\uc5d0 \ub9de\ub294 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\ud30c\ud2f0\uc6d0\uc740 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \uae30\ub150\uc77c \ucd95\ud558, \uc0dd\uc77c \ud30c\ud2f0, \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \ubaa8\ub4e0 \uace0\uac1d\ub2d8\uc758 \uc694\uad6c\ub97c \ucda9\uc871\uc2dc\ud0ac \uc218 \uc788\ub294 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub0a8\ub140 \ub3d9\ubc18 \ubc29\ubb38\ub3c4 \uac00\ub2a5\ud558\uba70, \ub204\uad6c\uc640 \ud568\uaed8\ud558\ub354\ub77c\ub3c4 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d \uc911\uc2ec\uc758 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\ud30c\ud2f0\uc6d0\uc740 \uace0\uac1d\ub2d8\uc758 \ud3b8\uc758\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ubc1c\ub81b\ud30c\ud0b9 \uc11c\ube44\uc2a4\uc640 \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc635\uc158\uc744 \ud1b5\ud574 \ubc29\ubb38\ubd80\ud130 \uadc0\uac00\uae4c\uc9c0 \ubaa8\ub4e0 \uacfc\uc815\uc744 \ud3b8\uc548\ud558\uace0 \ud488\uaca9 \uc788\uac8c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9de\ucda4\ud615 \uc774\ubca4\ud2b8 \uc5f0\ucd9c<\/h3>\n\n\n\n<p>\ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ud558\uace0 \uc2f6\ub2e4\uba74 \ud30c\ud2f0\uc6d0\uc774 \uc815\ub2f5\uc785\ub2c8\ub2e4. DJ\uc640 \uc2f1\uc5b4 \uc12d\uc678(\ubcc4\ub3c4 \uc694\uccad \uac00\ub2a5)\ub97c \ud3ec\ud568\ud55c \ub2e4\uc591\ud55c \ub9de\ucda4\ud615 \uc774\ubca4\ud2b8\ub97c \ud1b5\ud574 \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc21c\uac04\uc744 \ud2b9\ubcc4\ud558\uac8c \uc5f0\ucd9c\ud574 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc548\uc804\ud55c \ud658\uacbd<\/h2>\n\n\n\n<p>\ud30c\ud2f0\uc6d0\uc740 \uccb4\uacc4\uc801\uc73c\ub85c \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uacfc \ucca0\uc800\ud788 \uad50\uc721\ubc1b\uc740 \uc2a4\ud0dc\ud504\ub97c \ud1b5\ud574 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \ucf8c\uc801\ud55c \ud658\uacbd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ubaa8\ub4e0 \uc21c\uac04\uc744 \uc138\uc2ec\ud558\uac8c \uad00\ub9ac\ud558\uba70, \ud3b8\uc548\ud558\uace0 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\uc7a5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud55c \uac00\uaca9 \uc815\ucc45\uacfc \uc2e0\ub8b0<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\uc815\ucc30\uc81c\ub97c \ud1b5\ud55c \ud22c\uba85\ud55c \uac00\uaca9<\/h3>\n\n\n\n<p>\ud30c\ud2f0\uc6d0\uc740 \uc815\ucc30\uc81c \uc6b4\uc601\uc73c\ub85c \ubaa8\ub4e0 \ube44\uc6a9\uc744 \uc0ac\uc804\uc5d0 \uba85\ud655\ud788 \uc548\ub0b4\ud558\uba70, \ucd94\uac00 \uc694\uae08 \uac71\uc815 \uc5c6\uc774 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uc73c\ub85c \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc2e0\ub8b0\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc6b4\uc601 \ucca0\ud559<\/h3>\n\n\n\n<p>\ud30c\ud2f0\uc6d0\uc740 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0\uacfc \ucd9c\uadfc \ud604\ud669 \ub4f1\uc744 \uc815\ud655\ud788 \uc548\ub0b4\ud558\uc5ec \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\uc640 \ud568\uaed8\ud558\ub294 \uc990\uac70\uc6b4 \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ud488\uaca9\uacfc \ub9e4\ub825\uc744 \uac16\ucd98 \ud30c\ud2b8\ub108<\/h3>\n\n\n\n<p>\ud30c\ud2f0\uc6d0\uc740 \uc5c4\uaca9\ud788 \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc2a4\ud0c0\uc77c\uc758 \ud30c\ud2b8\ub108\ub97c \uc120\ud0dd\ud558\uc5ec \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \uc644\uc131\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ud30c\ud2f0\uc6d0\ub9cc\uc758 \uc790\uc720\ub86d\uace0 \uc720\ucf8c\ud55c \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\ud30c\ud2f0\uc6d0\uc740 \uace0\uae09\uc2a4\ub7ec\uc6c0\uacfc \uc790\uc720\ub85c\uc6c0\uc774 \uc870\ud654\ub97c \uc774\ub8e8\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \ub204\uad6c\uc640 \ud568\uaed8\ud558\ub354\ub77c\ub3c4 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \ubcf4\uc7a5\ud558\uba70, \uc990\uac70\uc6c0\uacfc \ud488\uaca9\uc744 \ub3d9\uc2dc\uc5d0 \ub290\ub084 \uc218 \uc788\ub294 \ub3c5\ucc3d\uc801\uc778 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c \uc2dc\uc791\ub418\ub294 \ud2b9\ubcc4\ud55c \ucd94\uc5b5<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uac00\ub77c\uc624\ucf00 \ud30c\ud2f0\uc6d0\uc740 \uac15\ub0a8\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825\uacfc \ud2b9\ubcc4\ud568\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\uc640 \uc138\ub828\ub41c \uacf5\uac04\uc740 \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \ucd94\uc5b5\uc744 \uc120\uc0ac\ud558\uba70, \uc911\uc694\ud55c \ub0a0\uc744 \ub354\uc6b1 \ud2b9\ubcc4\ud558\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<br>\ud30c\ud2f0\uc6d0\uc5d0\uc11c\uc758 \uc2dc\uac04\uc740 \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\ub97c \ub118\uc5b4, \uc990\uac70\uc6c0\uacfc \ud488\uaca9\uc774 \uc644\ubcbd\ud788 \uc870\ud654\ub97c \uc774\ub8e8\ub294 \ud2b9\ubcc4\ud55c \uc21c\uac04\uc73c\ub85c \uae30\uc5b5\ub420 \uac83\uc785\ub2c8\ub2e4. \uc9c0\uae08 \ubc14\ub85c \ud30c\ud2f0\uc6d0\uc5d0\uc11c \ub2f9\uc2e0\ub9cc\uc758 \ud2b9\ubcc4\ud55c \ucd94\uc5b5\uc744 \ub9cc\ub4e4\uc5b4 \ubcf4\uc138\uc694!<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \uac00\ub77c\uc624\ucf00 \ud30c\ud2f0\uc6d0\uc740 \uac15\ub0a8\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825\uacfc \ud2b9\ubcc4\ud568\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\uc640 \uc138\ub828\ub41c \uacf5\uac04\uc740 \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \ucd94\uc5b5\uc744 \uc120\uc0ac\ud558\uba70, \uc911\uc694\ud55c \ub0a0\uc744 \ub354\uc6b1 \ud2b9\ubcc4\ud558\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":5558,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[25],"class_list":["post-5493","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-karaoke"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5493","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5558"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5493"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5493"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}