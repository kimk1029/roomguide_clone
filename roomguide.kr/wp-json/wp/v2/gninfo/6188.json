{"id":6188,"date":"2025-01-15T21:34:52","date_gmt":"2025-01-15T12:34:52","guid":{"rendered":"https:\/\/roomguide.kr\/?post_type=gninfo&#038;p=6188"},"modified":"2025-03-26T12:42:35","modified_gmt":"2025-03-26T03:42:35","slug":"race","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/race\/","title":{"rendered":"\ub808\uc774\uc2a4"},"content":{"rendered":"\n<p>\uc11c\uc6b8\uc758 <strong>\uac15\ub0a8<\/strong>\uc740 \uadf8 \uc790\uccb4\ub85c \uae00\ub85c\ubc8c\ud55c \ub9e4\ub825\uc744 \uc790\ub791\ud558\ub294 \uc9c0\uc5ed\uc785\ub2c8\ub2e4. \ube5b\ub098\ub294 \uac70\ub9ac, \uc138\ub828\ub41c \uc1fc\ud551\ubab0, \uadf8\ub9ac\uace0 \uc5b8\uc81c\ub098 \ud65c\uae30\ucc2c \ubd84\uc704\uae30\ub85c \uc720\uba85\ud55c \uc774\uacf3\uc5d0\ub294, \ud2b9\ud788 <strong>\ub098\uc774\ud2b8\ub77c\uc774\ud504<\/strong>\uac00 \ube7c\ub193\uc744 \uc218 \uc5c6\ub294 \uc911\uc694\ud55c \uc694\uc18c\ub85c \uc790\ub9ac \uc7a1\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uac15\ub0a8\uc758 \ud074\ub7fd \uc52c\uc740 \ub2e8\uc21c\ud788 \ucda4\uc744 \ucd94\ub294 \uacf3\uc774 \uc544\ub2c8\ub77c, <strong>\uacbd\uc7c1<\/strong>\uacfc <strong>\ucc28\ubcc4\ud654\ub41c \uacbd\ud5d8<\/strong>\uc774 \uc774\ub8e8\uc5b4\uc9c0\ub294 \ud2b9\ubcc4\ud55c \uacf5\uac04\uc774\uc8e0. \uc624\ub298\uc740 \uac15\ub0a8 \ud074\ub7fd \uc911\uc5d0\uc11c\ub3c4 \ud2b9\ud788 <strong>\uacbd\uc7c1\uc801\uc778 \ubd84\uc704\uae30<\/strong>\uc640 <strong>\uc774\uc0c9\uc801\uc778 \ud074\ub7fd \ubb38\ud654<\/strong>\ub97c \uc790\ub791\ud558\ub294 <strong>\ud074\ub7fd \ub808\uc774\uc2a4<\/strong>\uc5d0 \ub300\ud574 \uc54c\uc544\ubcf4\uaca0\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ud074\ub7fd \ub808\uc774\uc2a4\ub780?<\/h3>\n\n\n\n<p>&#8216;\ud074\ub7fd \ub808\uc774\uc2a4&#8217;\ub294 \uac15\ub0a8\uc758 \ud074\ub7fd\ub4e4\uc774 \uc11c\ub85c \uacbd\uc7c1\ud558\uba74\uc11c \uc790\ub791\ud558\ub294 <strong>\ub3c5\ud2b9\ud55c \uc2a4\ud0c0\uc77c<\/strong>\uacfc <strong>\ud2b9\ubcc4\ud55c \uacbd\ud5d8<\/strong>\uc744 \uc81c\uacf5\ud558\ub294 \ubb38\ud654\uc785\ub2c8\ub2e4. \uc774 \uacbd\uc7c1\uc740 \ub2e8\uc21c\ud55c \ud30c\ud2f0\ub098 \ud589\uc0ac\uac00 \uc544\ub2cc, \ud074\ub7fd\ub4e4\ub07c\ub9ac\uc758 <strong>\ube0c\ub79c\ub4dc \uacbd\uc7c1<\/strong>, <strong>\uace0\uc720\ud55c \uc74c\uc545 \uc2a4\ud0c0\uc77c<\/strong>, <strong>\ud2b9\ubcc4\ud55c \uc11c\ube44\uc2a4<\/strong>\uc640 <strong>VIP \uacbd\ud5d8<\/strong> \ub4f1\uc744 \ud1b5\ud574 \uc774\ub8e8\uc5b4\uc9d1\ub2c8\ub2e4. \ub9e4\uc8fc, \uc544\ub2c8 \ub9e4\uc77c \ubc24 \ud074\ub7fd\ub4e4\uc740 \uc790\uc2e0\ub9cc\uc758 \ucc28\ubcc4\ud654\ub41c \ucf58\ud150\uce20\uc640 \ub9e4\ub825\uc801\uc778 \ud30c\ud2f0 \uc2a4\ud0c0\uc77c\ub85c \ud074\ub7fd \uc560\ud638\uac00\ub4e4\uc744 \ub04c\uc5b4\ub4e4\uc774\uae30 \uc704\ud574 \uce58\uc5f4\ud55c \uacbd\uc7c1\uc744 \ud3bc\uce69\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \ud074\ub7fd \ub808\uc774\uc2a4\uc758 \uc8fc\uc694 \uacbd\uc7c1 \uc694\uc18c<\/h3>\n\n\n\n<ol class=\"wp-block-list\">\n<li><strong>\uc74c\uc545\uacfc DJ \ub77c\uc778\uc5c5<\/strong><br>\uac15\ub0a8\uc758 \ud074\ub7fd\ub4e4\uc740 <strong>\uc74c\uc545<\/strong>\uc744 \ud1b5\ud574 \uc790\uc2e0\uc744 \ucc28\ubcc4\ud654\ud569\ub2c8\ub2e4. \uac00\uc7a5 \uc778\uae30 \uc788\ub294 \ud074\ub7fd\ub4e4\uc740 \uc720\uba85 DJ\uc758 \uacf5\uc5f0\uc744 \uc790\uc8fc \uc5f4\uba70, \uc774\ub4e4\uc740 \ud55c\uad6d\ubfd0\ub9cc \uc544\ub2c8\ub77c \ud574\uc678\uc5d0\uc11c \uc628 \ud32c\ub4e4\ub3c4 \ub04c\uc5b4\ub4e4\uc785\ub2c8\ub2e4. <strong>EDM<\/strong>, <strong>\ud799\ud569<\/strong>, <strong>K-pop \ub9ac\ubbf9\uc2a4<\/strong> \ub4f1 \ub2e4\uc591\ud55c \uc74c\uc545 \uc7a5\ub974\ub97c \uc81c\uacf5\ud558\ub294 \ud074\ub7fd\ub4e4\uc774 \ub9ce\uc2b5\ub2c8\ub2e4. \uc608\ub97c \ub4e4\uc5b4, <strong>\uc625\ud0c0\uace4<\/strong>\uc740 EDM\uacfc \ud558\uc6b0\uc2a4 \uc74c\uc545\uc758 \uba54\uce74\ub85c \uc720\uba85\ud558\uba70, <strong>\uc544\ub808\ub098<\/strong>\ub294 \ud799\ud569\uacfc \ud2b8\ub7a9\uc744 \uc0ac\ub791\ud558\ub294 \uc774\ub4e4\uc5d0\uac8c \uc778\uae30\uac00 \ub9ce\uc2b5\ub2c8\ub2e4. \ud074\ub7fd\ub4e4\uc774 \uc81c\uacf5\ud558\ub294 \uc74c\uc545 \uc2a4\ud0c0\uc77c\uc740 \uc774\uacf3\uc5d0\uc11c\uc758 \uacbd\ud5d8\uc744 \uacb0\uc815\uc9d3\ub294 \uc911\uc694\ud55c \uc694\uc18c\uc785\ub2c8\ub2e4.<\/li>\n\n\n\n<li><strong>\ud074\ub7fd \uc778\ud14c\ub9ac\uc5b4\uc640 \ubd84\uc704\uae30<\/strong><br>\uac15\ub0a8\uc758 \ud074\ub7fd\uc740 \ub2e8\uc21c\ud788 \uc88b\uc740 \uc74c\uc545\uc744 \ub118\uc5b4\uc11c, <strong>\uc2dc\uac01\uc801<\/strong>\uc774\uace0 <strong>\uac10\uac01\uc801\uc778<\/strong> \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud074\ub7fd\ub9c8\ub2e4 \uace0\uc720\uc758 \ud14c\ub9c8\uc640 \ub514\uc790\uc778\uc774 \uc874\uc7ac\ud558\uba70, \uc774\ub97c \ud1b5\ud574 \uc790\uc2e0\ub9cc\uc758 \ubd84\uc704\uae30\ub97c \ub9cc\ub4e4\uc5b4\ub0c5\ub2c8\ub2e4. \uc608\ub97c \ub4e4\uc5b4, <strong>\uc625\ud0c0\uace4<\/strong>\uc740 \ubaa8\ub358\ud558\uace0 \uc138\ub828\ub41c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ucd5c\uace0\uae09 \uc74c\ud5a5 \uc2dc\uc2a4\ud15c\uc744 \uc790\ub791\ud558\uba70, <strong>\ube14\ub8e8\ud30c\ud06c<\/strong>\ub294 \uc790\uc5f0 \uce5c\ud654\uc801\uc778 \ub514\uc790\uc778\uacfc \ud568\uaed8 \ub3c4\uc2ec \uc18d\uc758 \uc232 \uac19\uc740 \ub290\ub08c\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \uac01 \ud074\ub7fd\uc740 \ubc29\ubb38\uac1d\ub4e4\uc774 \uadf8 \uacf5\uac04\uc5d0\uc11c\uc758 \ub3c5\ud2b9\ud55c \ubd84\uc704\uae30\ub97c \ub290\ub084 \uc218 \uc788\ub3c4\ub85d \uc138\uc2ec\ud558\uac8c \uc2e0\uacbd\uc744 \uc501\ub2c8\ub2e4.<\/li>\n\n\n\n<li><strong>VIP \uacbd\ud5d8\uacfc \uc11c\ube44\uc2a4<\/strong><br>\uac15\ub0a8\uc758 \ud074\ub7fd\uc5d0\uc11c\ub294 <strong>VIP \uacbd\ud5d8<\/strong>\uc774 \ud070 \uacbd\uc7c1 \uc694\uc18c \uc911 \ud558\ub098\uc785\ub2c8\ub2e4. \ud074\ub7fd\ub4e4\uc740 \ubc29\ubb38\uac1d\ub4e4\uc5d0\uac8c <strong>\ud504\ub77c\uc774\ube57\ud55c \uacf5\uac04<\/strong>\uacfc <strong>\uace0\uae09\uc2a4\ub7ec\uc6b4 \uc11c\ube44\uc2a4<\/strong>\ub97c \uc81c\uacf5\ud558\uae30 \uc704\ud574 \ub04a\uc784\uc5c6\uc774 \ub178\ub825\ud569\ub2c8\ub2e4. VIP \ud14c\uc774\ube14, \ud504\ub9ac\ubbf8\uc5c4 \uc220 \uc11c\ube44\uc2a4, \uc804\uc6a9 \ubc14\ud150\ub354 \ub4f1\uc774 \uadf8 \uc608\uc785\ub2c8\ub2e4. \ud2b9\ud788, VIP \uace0\uac1d\uc744 \uc704\ud574 \uc900\ube44\ub41c <strong>\uc2a4\ud398\uc15c \ud14c\uc774\ube14<\/strong>\uc774\ub098 <strong>\ud3ec\ud1a0\uc874<\/strong>\uc740 \ud074\ub7fd\uc744 \ubc29\ubb38\ud558\ub294 \uc774\uc720 \uc911 \ud558\ub098\uac00 \ub429\ub2c8\ub2e4. \uadf8\ub9cc\ud07c \ud074\ub7fd\ub4e4\uc740 <strong>\uac1c\uc778\ud654\ub41c \uc11c\ube44\uc2a4<\/strong>\uc640 <strong>\ud2b9\ubcc4\ud55c \ub300\uc811<\/strong>\uc744 \ud1b5\ud574 \uace0\uac1d\uc744 \uc0ac\ub85c\uc7a1\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/li>\n\n\n\n<li><strong>\uc0ac\ud68c\uc801 \uc778\ud504\ub77c\uc640 \ub124\ud2b8\uc6cc\ud0b9<\/strong><br>\uac15\ub0a8 \ud074\ub7fd\uc740 <strong>\uc0ac\ud68c\uc801 \ud5c8\ube0c<\/strong>\ub85c\uc11c\uc758 \uc5ed\ud560\ub3c4 \ud1a1\ud1a1\ud788 \ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ub9ce\uc740 \uc80a\uc740 \uc7ac\ub825\uac00\ub4e4\uacfc \uc720\uba85 \uc778\uc0ac\ub4e4\uc774 \uc790\uc8fc \ubc29\ubb38\ud558\uba70, \uc774\uacf3\uc5d0\uc11c\ub294 \ube44\uc988\ub2c8\uc2a4 \ub124\ud2b8\uc6cc\ud0b9\uc774 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc774\ub8e8\uc5b4\uc9d1\ub2c8\ub2e4. <strong>\uc720\uba85 DJ\uc640\uc758 \ub9cc\ub0a8<\/strong>\uc774\ub098 <strong>\uc2a4\ud0c0\ub4e4\uacfc\uc758 \uc18c\uc15c \uc774\ubca4\ud2b8<\/strong>\ub294 \ud074\ub7fd\uc758 \uba85\uc131\uacfc \ud568\uaed8 \uc774\ub8e8\uc5b4\uc9c0\ub294 \uc911\uc694\ud55c \uc694\uc18c\uc785\ub2c8\ub2e4. \uc774\ub85c \uc778\ud574 \uac15\ub0a8 \ud074\ub7fd\uc740 <strong>\ube44\uc988\ub2c8\uc2a4\uc640 \uc0ac\ud68c\uc801 \ub9cc\ub0a8<\/strong>\uc758 \uc7a5\uc774\uae30\ub3c4 \ud558\uba70, \ub9ce\uc740 \uc0ac\ub78c\ub4e4\uc5d0\uac8c \ub354 \ud070 \ub9e4\ub825\uc744 \ubc1c\uc0b0\ud569\ub2c8\ub2e4.<\/li>\n<\/ol>\n\n\n\n<h3 class=\"wp-block-heading\">\ud074\ub7fd \ub808\uc774\uc2a4\uc5d0\uc11c \uc2b9\uc790\uac00 \ub418\ub294 \ubc95<\/h3>\n\n\n\n<p>\uac15\ub0a8 \ud074\ub7fd \uc52c\uc5d0\uc11c\uc758 <strong>\ud074\ub7fd \ub808\uc774\uc2a4<\/strong>\ub294 \ub2e8\uc21c\ud788 \uacbd\uc7c1\uc5d0 \uadf8\uce58\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uac01 \ud074\ub7fd\uc740 <strong>\uc0c8\ub85c\uc6b4 \ud2b8\ub80c\ub4dc<\/strong>\uc640 <strong>\ub3c4\uc804\uc801\uc778 \uc694\uc18c<\/strong>\ub97c \uc9c0\uc18d\uc801\uc73c\ub85c \ub9cc\ub4e4\uc5b4\uac00\uba70, \ud30c\ud2f0 \ubb38\ud654\uc758 <strong>\ud55c\uacc4\ub97c \ub113\ud788\ub294<\/strong> \uc5ed\ud560\uc744 \ud569\ub2c8\ub2e4. \uadf8\ub807\ub2e4\uba74, <strong>\uc5b4\ub5a4 \ud074\ub7fd\uc774 \uc774 \ud074\ub7fd \ub808\uc774\uc2a4\uc5d0\uc11c \uc2b9\uc790\uac00 \ub420\uae4c\uc694?<\/strong><\/p>\n\n\n\n<ol class=\"wp-block-list\">\n<li><strong>\ud2b8\ub80c\ub4dc\uc640 \ud601\uc2e0\uc744 \uc120\ub3c4\ud558\ub294 \ud074\ub7fd<\/strong><br>\ud074\ub7fd \ub808\uc774\uc2a4\uc5d0\uc11c \uc911\uc694\ud55c \uac83\uc740, \ud604\uc7ac\uc758 \ud2b8\ub80c\ub4dc\ub97c \ub530\ub77c\uac00\ub294 \uac83\uc774 \uc544\ub2c8\ub77c <strong>\ud2b8\ub80c\ub4dc\ub97c \uc120\ub3c4<\/strong>\ud558\ub294 \uac83\uc785\ub2c8\ub2e4. <strong>\uc544\ub808\ub098<\/strong>, <strong>\uc625\ud0c0\uace4<\/strong>\uacfc \uac19\uc740 \ud074\ub7fd\ub4e4\uc740 \ub9e4\ub144 \uc0c8\ub85c\uc6b4 DJ \ub77c\uc778\uc5c5\uc744 \uc81c\uacf5\ud558\uace0, <strong>\ud601\uc2e0\uc801\uc778 \uc774\ubca4\ud2b8<\/strong>\ub97c \uac1c\ucd5c\ud568\uc73c\ub85c\uc368 \ud074\ub7fd \uc52c\uc744 \ub9ac\ub4dc\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub4e4\uc740 <strong>\uc80a\uc740 \uace0\uac1d\uce35\uc758 \uc695\uad6c<\/strong>\ub97c \uc774\ud574\ud558\uace0, \ud56d\uc0c1 \uadf8\ub4e4\uc774 \uc6d0\ud558\ub294 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/li>\n\n\n\n<li><strong>\ub3c5\ud2b9\ud55c \uace0\uac1d \uacbd\ud5d8 \uc81c\uacf5<\/strong><br>\uac15\ub0a8\uc758 \ud074\ub7fd\ub4e4\uc740 \uace0\uac1d\ub4e4\uc774 \ud2b9\ubcc4\ud558\ub2e4\uace0 \ub290\ub084 \uc218 \uc788\ub3c4\ub85d \ub2e4\uc591\ud55c \uc774\ubca4\ud2b8\uc640 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc608\ub97c \ub4e4\uc5b4, <strong>\ube44\uacf5\uc2dd\uc801\uc778 \ud30c\ud2f0<\/strong>\ub098 <strong>\ud14c\ub9c8 \ud30c\ud2f0<\/strong>\uc640 \uac19\uc740 \ud2b9\ubcc4\ud55c \uc774\ubca4\ud2b8\ub294 \uadf8 \uc790\uccb4\ub85c \ud070 \ub9e4\ub825\uc785\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud558\ub294 \ud074\ub7fd\uc740 \ub2e8\uc21c\ud788 \uc0ac\ub78c\ub4e4\uc744 \ub04c\uc5b4\ub4e4\uc774\ub294 \uac83\uc744 \ub118\uc5b4\uc11c, <strong>\uc785\uc18c\ubb38\uc744 \ud0c0\uace0<\/strong> \ub354 \ub9ce\uc740 \uc0ac\ub78c\ub4e4\uc744 \uc720\uce58\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/li>\n\n\n\n<li><strong>\uace0\uac1d \ucda9\uc131\ub3c4\ub97c \ub192\uc774\ub294 \ud074\ub7fd<\/strong><br>\uace0\uac1d\ub4e4\uc774 \ubc18\ubcf5\uc801\uc73c\ub85c \ucc3e\uace0 \uc2f6\uc740 \ud074\ub7fd\uc740 \ubc14\ub85c <strong>\ucda9\uc131\ub3c4 \ub192\uc740 \uace0\uac1d<\/strong>\uc744 \ubcf4\uc720\ud55c \ud074\ub7fd\uc785\ub2c8\ub2e4. \uac15\ub0a8 \ud074\ub7fd\ub4e4\uc740 \uace0\uac1d\ub4e4\uc758 <strong>\ub9ac\uc6cc\ub4dc \uc2dc\uc2a4\ud15c<\/strong>\uc774\ub098 <strong>\uba64\ubc84\uc2ed \ud504\ub85c\uadf8\ub7a8<\/strong>\uc744 \uc6b4\uc601\ud558\uc5ec, \uc9c0\uc18d\uc801\uc778 \ubc29\ubb38\uc744 \uc720\ub3c4\ud569\ub2c8\ub2e4. \ub610\ud55c, \uace0\uac1d\uc758 \ucde8\ud5a5\uc744 \ubc18\uc601\ud55c \uac1c\uc778\ud654\ub41c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uac01 \ud074\ub7fd\uc758 \ud32c\uce35\uc744 \ud615\uc131\ud569\ub2c8\ub2e4.<\/li>\n<\/ol>\n\n\n\n<h3 class=\"wp-block-heading\">\uacb0\ub860: \uac15\ub0a8 \ud074\ub7fd \ub808\uc774\uc2a4, \uadf8 \ub05d\uc740 \uc5c6\ub2e4<\/h3>\n\n\n\n<p>\uac15\ub0a8\uc758 \ud074\ub7fd \uc52c\uc740 \ub2e8\uc21c\ud55c \ubc24\ubb38\ud654\uc758 \uc77c\ubd80\uac00 \uc544\ub2d9\ub2c8\ub2e4. \uc774\ub294 <strong>\uac15\ub0a8 \ud074\ub7fd\ub4e4\uc774 \uacbd\uc7c1\ud558\ub294 \ud074\ub7fd \ub808\uc774\uc2a4<\/strong>\uc774\uba70, \uadf8 \uc911\uc2ec\uc5d0\ub294 \ud56d\uc0c1 <strong>\uc80a\uace0 \uc7ac\ub825 \uc788\ub294 \uc778\ud30c<\/strong>\uc640 \ud568\uaed8 <strong>\ucd5c\uace0\uc758 \ub098\uc774\ud2b8\ub77c\uc774\ud504<\/strong>\uac00 \uc874\uc7ac\ud569\ub2c8\ub2e4. <strong>\uc74c\uc545<\/strong>, <strong>\uc11c\ube44\uc2a4<\/strong>, <strong>\ub124\ud2b8\uc6cc\ud0b9<\/strong> \ub4f1 \ub2e4\uc591\ud55c \uc694\uc18c\ub4e4\uc774 \ub9de\ubb3c\ub824 \ub9cc\ub4e4\uc5b4\ub0b4\ub294 \ud074\ub7fd \uc52c\uc5d0\uc11c, \ub9e4\uc77c\ub9e4\uc77c \ud074\ub7fd\ub4e4\uc740 \uce58\uc5f4\ud55c \uacbd\uc7c1\uc744 \ubc8c\uc774\uba70 <strong>\uc790\uc2e0\ub9cc\uc758 \ucc28\ubcc4\ud654\ub41c \uacbd\ud5d8<\/strong>\uc744 \uc81c\uacf5\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\ub9cc\uc57d \uc5ec\ub7ec\ubd84\uc774 \uac15\ub0a8\uc5d0\uc11c\uc758 \ud2b9\ubcc4\ud55c \ub098\uc774\ud2b8\ub77c\uc774\ud504\ub97c \uc990\uae30\uace0 \uc2f6\ub2e4\uba74, \ub2e8\uc9c0 \ud074\ub7fd\uc744 \ubc29\ubb38\ud558\ub294 \uac83\uc744 \ub118\uc5b4\uc11c, \uadf8 \ud074\ub7fd\uc774 \ud3bc\uce58\ub294 <strong>\uacbd\uc7c1\uacfc \ud601\uc2e0\uc758 \ud604\uc7a5<\/strong>\uc744 \uccb4\ud5d8\ud558\ub294 \uac83\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4. \uac15\ub0a8 \ud074\ub7fd \ub808\uc774\uc2a4\uc5d0\uc11c \uc2b9\ub9ac\ud558\ub294 \ud074\ub7fd\uc740 \uadf8 \uc790\uccb4\ub85c <strong>\ud55c \ubc88\uc758 \uacbd\ud5d8<\/strong>\uc744 \ub118\uc5b4, \uc5ec\ub7ec\ubd84\uc758 \ubc24\uc744 \uc78a\uc9c0 \ubabb\ud560 \uacbd\ud5d8\uc73c\ub85c \ub9cc\ub4e4\uc5b4\uc904 \uac83\uc785\ub2c8\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ube0c\ub77c\uc9c8 \ucd95\uad6c\uc2a4\ud0c0 &#8216;\ub124\uc774\ub9c8\ub974&#8217;\uac00 \ubc29\ubb38\ud55c \uac83\uc73c\ub85c \uc720\uba85\ud574\uc9c4 \uc774 \ud074\ub7fd\uc740 \uc2e0\uc0ac\uc5ed 4\ubc88\ucd9c\uad6c\ucabd\uc5d0 \uc790\ub9ac\ud55c \ub300\ud45c\uc801\uc778 \uac15\ub0a8\ud074\ub7fd\uc785\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":6231,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[30],"class_list":["post-6188","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-club"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/6188","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/6231"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=6188"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=6188"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}