{"id":5511,"date":"2025-01-06T20:15:59","date_gmt":"2025-01-06T11:15:59","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-115\/"},"modified":"2025-03-26T12:41:25","modified_gmt":"2025-03-26T03:41:25","slug":"115-2","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/115-2\/","title":{"rendered":"115"},"content":{"rendered":"\n<h2 class=\"wp-block-heading\">\uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad &#8220;115&#8221; &#8211; \uc138\ub828\ub41c \ubd84\uc704\uae30\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<p>\uac15\ub0a8\uc758 \ub300\ud45c\uc801\uc778 \ud558\uc774\ud37c\ube14\ub9ad &#8220;115&#8221;\ub294 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uae54\ub054\ud55c \uc2dc\uc124\ub85c \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc220\uc790\ub9ac\ub97c \uc81c\uacf5\ud558\uba74\uc11c\ub3c4 \ud3b8\uc548\ud55c \ubd84\uc704\uae30\ub97c \ub290\ub084 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ud070 \uaddc\ubaa8\ub97c \uc790\ub791\ud558\ub294 &#8220;115&#8221;\ub294 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uc73c\ub85c \ub2e4\uc591\ud55c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \ub6f0\uc5b4\ub09c \uc11c\ube44\uc2a4 \ud488\uc9c8\uacfc \uc218\uc9c8\ub85c \uc720\uba85\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uace0\uac1d\uce35\uc744 \uc704\ud55c \ucd5c\uc801\uc758 \uacf5\uac04<\/h2>\n\n\n\n<p>&#8220;115&#8221;\ub294 \ube44\uc988\ub2c8\uc2a4 \uc190\ub2d8\uc740 \ubb3c\ub860, \uc0dd\uc77c \ud30c\ud2f0\ub098 \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \ub2e4\uc591\ud55c \uc774\ubca4\ud2b8\ub97c \uc990\uae30\uae30 \uc704\ud55c \uace0\uac1d\ub4e4\uc5d0\uac8c \uc778\uae30\uac00 \ub9ce\uc2b5\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c \uc0dd\uc77c \ud30c\ud2f0 \uc7a5\uc18c\ub85c \uac00\uc7a5 \uc790\uc8fc \uc120\ud0dd\ub418\ub294 \uacf3\uc73c\ub85c, \ub0a8\ub140 \uad6c\ubd84 \uc5c6\uc774 \ubc29\ubb38\uc774 \uac00\ub2a5\ud558\uba70 \ud2b9\ubcc4\ud55c \ub0a0\uc744 \uae30\ub150\ud558\uae30\uc5d0 \uc801\ud569\ud55c \uacf5\uac04\uc73c\ub85c \uc0ac\ub791\ubc1b\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<p>&#8220;115&#8221;\uc5d0\uc11c\ub294 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uc5ec \uace0\uac1d\ub2d8\uc774 \ub354\uc6b1 \ud3b8\ub9ac\ud558\uac8c \uacf5\uac04\uc744 \uc774\uc6a9\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ubcc4\ud788 \uc6d0\ud558\ub294 \uc544\ud2f0\uc2a4\ud2b8\ub098 DJ\ub97c \uc12d\uc678\ud560 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\ub3c4 \uc81c\uacf5\ud558\uba70, (\ubcc4\ub3c4\uc758 \ube44\uc6a9\uc774 \ubc1c\uc0dd\ud569\ub2c8\ub2e4) \uace0\uae09\uc2a4\ub7ec\uc6b4 \ud658\uacbd\uc5d0\uc11c \uc220\uc790\ub9ac\uc640 \ub2e4\uc591\ud55c \ud65c\ub3d9\uc744 \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\ub2d8\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud558\ub294 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<p>\uc800\ud76c &#8220;115&#8221;\ub294 \uae30\uc874\uc758 \uc220\uc790\ub9ac \ubd84\uc704\uae30\ub97c \uc720\uc9c0\ud558\uba74\uc11c\ub3c4 \uc0c9\ub2e4\ub978 \uacbd\ud5d8\uc744 \uc120\uc0ac\ud560 \uc218 \uc788\ub3c4\ub85d \uc124\uacc4\ub418\uc5c8\uc2b5\ub2c8\ub2e4. \uccb4\uacc4\uc801\uc73c\ub85c \ud6c8\ub828\ub41c \uc544\uac00\uc528\ub4e4\uc774 \uace0\uac1d\ub2d8\uc744 \uc138\uc2ec\ud558\uac8c \ubc30\ub824\ud558\uba70, \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc2e4 \uc218 \uc788\ub3c4\ub85d \ub3c4\uc640\ub4dc\ub9bd\ub2c8\ub2e4. \uc544\uac00\uc528\ub4e4\uc740 \ucca0\uc800\ud55c \ub9c8\uc778\ub4dc \uad50\uc721\uc744 \ud1b5\ud574 \ucd5c\uace0 \uc218\uc900\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\uc758 \uc131\uacf5\uc801\uc778 \uc870\ud654<\/h2>\n\n\n\n<p>\ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\ub294 \ub5bc\ub824\uc57c \ub5c4 \uc218 \uc5c6\ub294 \uad00\uacc4\uc785\ub2c8\ub2e4. \ud558\uc9c0\ub9cc, \ub9cc\uc871\ub3c4\uac00 \ub0ae\uc740 \uc811\ub300\ub294 \ube44\uc988\ub2c8\uc2a4\uc5d0 \uc545\uc601\ud5a5\uc744 \ubbf8\uce60 \uc218 \uc788\ub2e4\ub294 \uc810\uc744 \uba85\uc2ec\ud574\uc57c \ud569\ub2c8\ub2e4. &#8220;115&#8221;\ub294 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4\uc640 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4 \ub9c8\uc778\ub4dc\ub97c \uac16\ucd98 \uc544\uac00\uc528\ub4e4\uc774 \uace0\uac1d\ub2d8\uc758 \ube44\uc988\ub2c8\uc2a4 \uc131\uacf5\uc744 \uc9c0\uc6d0\ud560 \uc218 \uc788\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac70\ud488 \uc5c6\ub294 \uac00\uaca9, \ud22c\uba85\ud55c \uc815\ucc30\uc81c \uc6b4\uc601<\/h2>\n\n\n\n<p>&#8220;115&#8221;\ub294 \uac70\ud488 \uc5c6\ub294 \uac00\uaca9\uacfc \ud22c\uba85\ud55c \uc815\ucc30\uc81c\ub85c \uc6b4\uc601\ub418\uba70, \uace0\uac1d\ub2d8\uaed8 \ubd88\ud544\uc694\ud55c \ucd94\uac00 \ube44\uc6a9\uc744 \uc694\uad6c\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \ubbf8\ub9ac \uc5f0\ub77d\uc744 \uc8fc\uc2dc\uba74 \uc8fc\ub300\uc640 \uc11c\ube44\uc2a4\uc5d0 \ub300\ud574 \uc790\uc138\ud558\uac8c \uc548\ub0b4\ub4dc\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc2e0\ub8b0\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc11c\ube44\uc2a4 \uc81c\uacf5\uc744 \uc57d\uc18d\ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\ub2d8\uacfc\uc758 \uc18c\uc911\ud55c \uc778\uc5f0<\/h2>\n\n\n\n<p>&#8220;115&#8221;\ub97c \ud55c\ubc88 \ucc3e\uc544\uc8fc\uc2e0 \uace0\uac1d\ub2d8\uc740 \ub300\ubd80\ubd84 \ub2e8\uace8\uc774 \ub418\uc5b4 \uc8fc\uc2ed\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uacfc\uc758 \uc18c\uc911\ud55c \uc778\uc5f0\uc744 \uacc4\uc18d \uc774\uc5b4\uac00\uae30 \uc704\ud574 \uc2e0\ub8b0\uc640 \uc815\uc9c1\ud568\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc5ec\uae30\uace0 \uc788\uc73c\uba70, \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc544\uac00\uc528 \uc22b\uc790\ub97c \uacfc\uc7a5\ud558\uc9c0 \uc54a\uc73c\uba70 \ub300\uae30 \uc2dc\uac04\uc5d0 \ub300\ud574\uc11c\ub3c4 \uc815\ud655\ud558\uac8c \uc548\ub0b4\ud574 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \ub9e4\ub825\uc801\uc778 \uc544\uac00\uc528\ub4e4<\/h2>\n\n\n\n<p>&#8220;115&#8221;\ub294 \ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \ub9e4\ub825\uc801\uc778 \uc544\uac00\uc528\ub4e4\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uc790\uc2e0\uc774 \uc120\ud638\ud558\ub294 \uc2a4\ud0c0\uc77c\uc758 \uc544\uac00\uc528\ub97c \uc120\ud0dd\ud558\uc2e4 \uc218 \uc788\uc73c\uba70, \uae4c\ub2e4\ub85c\uc6b4 \uae30\uc900\uc744 \ud1b5\ud574 \uc120\ubcc4\ub41c \uc544\uac00\uc528\ub4e4\uc740 \ubbf8\ubaa8\uc640 \ub9c8\uc778\ub4dc \ubaa8\ub450\uc5d0\uc11c \uc218\uc900 \ub192\uc740 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<p>&#8220;115&#8221;\ub294 \uc815\uc9c1\ud55c \uc8fc\ub300\uc640 \ub6f0\uc5b4\ub09c \uc11c\ube44\uc2a4\ub85c \ub0b4\uc0c1 \ud655\ub960\uc744 \ucd5c\uc18c\ud654\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8 \ubd88\ud3b8\ud568\uc774 \uc5c6\ub3c4\ub85d \uc138\uc2ec\ud55c \ubd80\ubd84\uae4c\uc9c0 \ubc30\ub824\ud558\uba70, \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub97c \ud1b5\ud574 \ucd5c\uc0c1\uc758 \uacbd\ud5d8\uc744 \uc120\uc0ac\ud574 \ub4dc\ub9bd\ub2c8\ub2e4. \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud558\uc774\ud37c\ube14\ub9ad &#8220;115&#8221;\uc758 \ucc28\ubcc4\ud654\ub41c \ub9e4\ub825<\/h2>\n\n\n\n<p>\ud558\uc774\ud37c\ube14\ub9ad &#8220;115&#8221;\ub294 \ud37c\ube14\ub9ad \uc5c5\uc18c\uc758 \ud3b8\uc548\ud55c \ubd84\uc704\uae30\uc640 \ud558\uc774\uca5c\uc624\uae09 \uc544\uac00\uc528\ub4e4\ub85c \uad6c\uc131\ub41c \ucd5c\uace0\uc758 \uc2dc\uc2a4\ud15c\uc744 \uc790\ub791\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uc880 \ub354 \uc790\uc720\ub85c\uc6b4 \ubd84\uc704\uae30\uc5d0\uc11c \uc220\uacfc \ub178\ub798\ub97c \uc990\uae30\uc2e4 \uc218 \uc788\uc73c\uba70, \ud130\uce58\uc758 \uc790\uc720\ub85c\uc6c0\ub3c4 \uc81c\uacf5\ub429\ub2c8\ub2e4. \uc218\uc704\uc640 \uc2a4\ud0c0\uc77c\uc774 \ub2e4\uc591\ud558\uc5ec \uac1c\uc778 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc544\uac00\uc528\ub97c \uc120\ud0dd\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\ub2d8\uc744 \uc704\ud55c \ucd5c\uc0c1\uc758 \uc11c\ube44\uc2a4 \uc81c\uacf5<\/h2>\n\n\n\n<p>&#8220;115&#8221;\ub294 \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub97c \ud22c\uba85\ud558\uac8c \uc81c\uacf5\ud558\uc5ec \uace0\uac1d\ub2d8\uc758 \uc2dc\uac04\uc744 \uc18c\uc911\ud788 \uc5ec\uae41\ub2c8\ub2e4. \uac15\ub0a8\uc758 \ud558\uc774\ud37c\ube14\ub9ad &#8220;115&#8221;\ub294 \uc5c5\uadf8\ub808\uc774\ub4dc\ub41c \ubd84\uc704\uae30\uc640 \ub9e4\ub825\uc801\uc778 \uc544\uac00\uc528\ub4e4\ub85c \uc5ec\ub7ec\ubd84\uc744 \ub9de\uc774\ud569\ub2c8\ub2e4. \uad81\uae08\ud55c \uc0ac\ud56d\uc740 \uc5b8\uc81c\ub4e0\uc9c0 \uc804\ud654\ub85c \ubb38\uc758\ud574 \uc8fc\uc138\uc694. \uc8fc\ub300\uc640 \uc11c\ube44\uc2a4\uc5d0 \ub300\ud574 \uba85\ud655\ud558\uac8c \uc548\ub0b4\ub4dc\ub9ac\uba70, \uace0\uac1d\ub2d8\uc774 \ud3b8\uc548\ud558\uace0 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc220\uc790\ub9ac\ub97c \uacbd\ud5d8\ud558\uc2e4 \uc218 \uc788\ub3c4\ub85d \ub3d5\uaca0\uc2b5\ub2c8\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8\uc758 \ub300\ud45c\uc801\uc778 \ud558\uc774\ud37c\ube14\ub9ad &#8220;115&#8221;\ub294 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uae54\ub054\ud55c \uc2dc\uc124\ub85c \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc220\uc790\ub9ac\ub97c \uc81c\uacf5\ud558\uba74\uc11c\ub3c4 \ud3b8\uc548\ud55c \ubd84\uc704\uae30\ub97c \ub290\ub084 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":5543,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[27],"class_list":["post-5511","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-hipublic"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5511","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5543"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5511"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5511"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}