{"id":5513,"date":"2025-01-06T20:15:59","date_gmt":"2025-01-06T11:15:59","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%97%90%ed%94%84%ec%9b%90\/"},"modified":"2025-03-26T12:48:57","modified_gmt":"2025-03-26T03:48:57","slug":"f1","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/f1\/","title":{"rendered":"\uc5d0\ud504\uc6d0"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \uca5c\uc624 \uc5d0\ud504\uc6d0 \u2013 \ud488\uaca9\uacfc \ub514\ud14c\uc77c\uc774 \uc0b4\uc544\uc788\ub294 \ud2b9\ubcc4\ud55c \uacf5\uac04<\/h3>\n\n\n\n<p>\uac15\ub0a8 <strong>\uca5c\uc624 \uc5d0\ud504\uc6d0<\/strong>\uc740 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc11c\ube44\uc2a4\ub97c \ubc14\ud0d5\uc73c\ub85c, \uace0\uac1d\ub2d8\uaed8 \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\ub97c \ub118\uc5b4\uc120 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc758 \ud3b8\ub9ac\ud55c \uc704\uce58\uc640 \ucc28\ubcc4\ud654\ub41c \ubd84\uc704\uae30\ub85c \ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \uc0ac\uad50 \ubaa8\uc784, \uae30\ub150\uc77c \ud30c\ud2f0 \ub4f1 \ub2e4\uc591\ud55c \ubaa9\uc801\uc5d0 \uc774\uc0c1\uc801\uc778 \uacf5\uac04\uc744 \uc81c\uacf5\ud558\uba70, \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc744 \ub3d9\uc2dc\uc5d0 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc5d0\ud504\uc6d0\uc758 \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4\uc640 \uac10\uac01\uc801\uc778 \ub514\uc790\uc778<\/h3>\n\n\n\n<p>\uc5d0\ud504\uc6d0\uc740 \ubaa8\ub358\ud558\uace0 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\ub85c, \ub204\uad6c\ub098 \ub9cc\uc871\ud560 \uc218 \uc788\ub294 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\ub97c \uc790\ub791\ud569\ub2c8\ub2e4. \ucc28\ubd84\ud558\uba74\uc11c\ub3c4 \uc2a4\ud0c0\uc77c\ub9ac\uc2dc\ud55c \uacf5\uac04\uc740 \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uacfc \uc0ac\uad50 \ubaa8\uc784 \ubaa8\ub450\uc5d0 \uc801\ud569\ud558\uba70, \uace0\uac1d\ub2d8\uaed8 \ud2b9\ubcc4\ud55c \ucd94\uc5b5\uc744 \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<br>\uc774\uacf3\uc5d0\uc11c\ub294 \uae54\ub054\ud55c \uc2dc\uc124\uacfc \ub514\ud14c\uc77c\ud55c \uacf5\uac04 \ubc30\uce58\uac00 \ub3cb\ubcf4\uc774\uba70, \uace0\uae09\uc2a4\ub7ec\uc6c0 \uc18d\uc5d0\uc11c \ud3b8\uc548\ud568\uc744 \ub290\ub084 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud55c \ucd5c\uc801\uc758 \uc7a5\uc18c<\/h3>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uc5d0\ud504\uc6d0\uc740 \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud558\uc5ec \ub6f0\uc5b4\ub09c \uc811\uadfc\uc131\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub113\uace0 \ucf8c\uc801\ud55c \uacf5\uac04\uc740 \ubaa8\ub4e0 \uace0\uac1d\uc758 \ub2e4\uc591\ud55c \uc694\uad6c\ub97c \ub9cc\uc871\uc2dc\ud0ac \uc218 \uc788\uc73c\uba70, \uc0ac\uad50\uc640 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300\ub97c \ubaa8\ub450 \uc544\uc6b0\ub974\ub294 \uc774\uc0c1\uc801\uc778 \uc7a5\uc18c\ub85c \uc190\uaf3d\ud799\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c\ub3c4 \uc190\uc5d0 \uaf3d\ud788\ub294 \ub300\uaddc\ubaa8 \uc2dc\uc124\uacfc \ud488\uc9c8 \ub192\uc740 \uc11c\ube44\uc2a4\ub294 \uc5d0\ud504\uc6d0\uc758 \uc790\ub791\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ub2e4\uc591\ud55c \uace0\uac1d\uce35\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc5d0\ud504\uc6d0\uc740 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \uce5c\ubaa9 \ubaa8\uc784, \uc0dd\uc77c \ud30c\ud2f0, \uae30\ub150\uc77c \ud589\uc0ac \ub4f1 \ub2e4\uc591\ud55c \uace0\uac1d\uc758 \ud544\uc694\uc5d0 \ubd80\uc751\ud560 \uc218 \uc788\ub3c4\ub85d \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub0a8\ub140 \ub3d9\ubc18 \ubc29\ubb38\ub3c4 \uac00\ub2a5\ud558\uba70, \ub204\uad6c\uc640 \ud568\uaed8\ud574\ub3c4 \ud3b8\uc548\ud558\uace0 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uacf5\uac04\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\uc744 \uc704\ud55c \ud3b8\ub9ac\ud558\uace0 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uace0\uac1d\ub2d8\uc758 \ud3b8\ub9ac\ud55c \ubc29\ubb38\uc744 \uc704\ud574 \uc5d0\ud504\uc6d0\uc740 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \ubc29\ubb38\ud560 \uc218 \uc788\uc73c\uba70, \uc774\ub3d9 \uacfc\uc815\uc5d0\uc11c\ub3c4 \ud488\uaca9\uacfc \ud3b8\uc548\ud568\uc744 \ub290\ub07c\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<br>\uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \uc874\uc911\ud558\uba70, \ucc98\uc74c\ubd80\ud130 \ub05d\uae4c\uc9c0 \ubd88\ud3b8\ud568 \uc5c6\ub294 \uacbd\ud5d8\uc744 \uc57d\uc18d\ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9de\ucda4\ud615 \uc774\ubca4\ud2b8 \uc9c0\uc6d0<\/h3>\n\n\n\n<p>\uace0\uac1d\ub2d8\uc758 \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ud2b9\ubcc4\ud558\uac8c \ub9cc\ub4e4\uc5b4 \uc904 DJ \ubc0f \uc2f1\uc5b4 \uc12d\uc678 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. (\ubcc4\ub3c4 \ube44\uc6a9 \ubc1c\uc0dd) \uc5d0\ud504\uc6d0\ub9cc\uc758 \uac10\uac01\uc801\uc778 \uc774\ubca4\ud2b8 \uc5f0\ucd9c\ub85c \uace0\uac1d\ub2d8\ub9cc\uc758 \ub3c5\ud2b9\ud558\uace0 \ud2b9\ubcc4\ud55c \ubd84\uc704\uae30\ub97c \ub9cc\ub4e4\uc5b4\ub4dc\ub9bd\ub2c8\ub2e4. \ubaa8\ub4e0 \ub514\ud14c\uc77c\uc740 \uace0\uac1d\ub2d8\uc758 \uc694\uccad\uc5d0 \ub530\ub77c \uc138\uc2ec\ud558\uac8c \uc900\ube44\ub429\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uc5c6\ub294 \uc548\uc804\ud558\uace0 \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uc5d0\ud504\uc6d0\uc740 \ucca0\uc800\ud788 \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uacfc \uccb4\uacc4\uc801\uc73c\ub85c \uad50\uc721\ubc1b\uc740 \uc2a4\ud0dc\ud504\ub97c \ud1b5\ud574 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc220\uc790\ub9ac \ud658\uacbd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ubaa8\ub4e0 \uc21c\uac04\uc744 \ud2b9\ubcc4\ud558\uace0 \uc548\uc804\ud558\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9ac\uba70, \uc138\ubd80\uc801\uc778 \uc11c\ube44\uc2a4\uae4c\uc9c0 \ub193\uce58\uc9c0 \uc54a\ub294 \ub514\ud14c\uc77c\ub85c \ub9cc\uc871\uac10\uc744 \ub354\ud569\ub2c8\ub2e4.<br>\uace0\uac1d\ub2d8\uc758 \uc990\uac70\uc6c0\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud558\uba70, \ubaa8\ub4e0 \uc0c1\ud669\uc5d0\uc11c \uc138\uc2ec\ud55c \ubc30\ub824\ub97c \ub290\ub07c\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud569\ub9ac\uc801\uc778 \uac00\uaca9\uacfc \uc2e0\ub8b0\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc6b4\uc601<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ud22c\uba85\ud55c \uc815\ucc30\uc81c \uac00\uaca9 \uc815\ucc45<\/h3>\n\n\n\n<p>\uc5d0\ud504\uc6d0\uc740 \ud22c\uba85\ud558\uace0 \ud569\ub9ac\uc801\uc778 \uc815\ucc30\uc81c\ub97c \uc6b4\uc601\ud558\uc5ec \uace0\uac1d\ub2d8\uaed8 \ubd88\ud544\uc694\ud55c \ucd94\uac00 \uc694\uae08 \uc5c6\uc774 \ud488\uaca9 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uba85\ud655\ud788 \uc548\ub0b4\ub418\uba70, \uac00\uaca9\uc5d0 \ub300\ud55c \uac71\uc815 \uc5c6\uc774 \uc220\uc790\ub9ac\ub97c \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \ubcf4\uc7a5\ud569\ub2c8\ub2e4.<br>\uac00\uaca9\ubfd0\ub9cc \uc544\ub2c8\ub77c \uc11c\ube44\uc2a4 \ud488\uc9c8 \uba74\uc5d0\uc11c\ub3c4 \ub192\uc740 \uac00\uc131\ube44\ub97c \uc790\ub791\ud558\ub294 \uc5d0\ud504\uc6d0\uc740 \uace0\uac1d\ub2d8\uc758 \ub9cc\uc871\uc744 \uc704\ud574 \ud56d\uc0c1 \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc2e0\ub8b0\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c<\/h3>\n\n\n\n<p>\uc5d0\ud504\uc6d0\uc740 \uace0\uac1d\ub2d8\uacfc\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0\uacfc \ucd9c\uadfc \ud604\ud669 \ub4f1\uc744 \uc815\ud655\ud558\uac8c \uc548\ub0b4\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4. \ucc98\uc74c\ubd80\ud130 \ub05d\uae4c\uc9c0 \uc2e0\ub8b0\ud560 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \ud55c \ubc88 \ubc29\ubb38\ud55c \uace0\uac1d\ub2d8\uc740 \ub300\ubd80\ubd84 \ub2e8\uace8\uc774 \ub420 \uc815\ub3c4\ub85c \ub192\uc740 \ub9cc\uc871\ub3c4\ub97c \uc790\ub791\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\uc640\uc758 \ud2b9\ubcc4\ud55c \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uacfc \ub9e4\ub825\uc744 \uc9c0\ub2cc \ud30c\ud2b8\ub108<\/h3>\n\n\n\n<p>\uc5d0\ud504\uc6d0\uc5d0\uc11c\ub294 \uc5c4\uaca9\ud55c \uae30\uc900\uc744 \ud1b5\ud574 \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc2a4\ud0c0\uc77c\uc758 \ud30c\ud2b8\ub108\ub97c \uc120\ud0dd\ud558\uc5ec, \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\ub97c \ub118\uc5b4\uc120 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<br>\ud30c\ud2b8\ub108\ub4e4\uc740 \ub6f0\uc5b4\ub09c \ubbf8\ubaa8\uc640 \ud568\uaed8, \uace0\uac1d\ub2d8\uaed8 \ud3b8\uc548\ud558\uace0 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \uc81c\uacf5\ud558\uae30 \uc704\ud574 \ucca0\uc800\ud788 \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uca5c\uc624\ub9cc\uc758 \ucc28\ubcc4\ud654\ub41c \uc790\uc720\ub85c\uc6b4 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc5d0\ud504\uc6d0\uc740 \uca5c\uc624 \ud2b9\uc720\uc758 \ucc28\ubcc4\ud654\ub41c \uc2dc\uc2a4\ud15c\uc73c\ub85c, \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \uc790\uc720\ub86d\uac8c \uc220\uc790\ub9ac\ub97c \uc990\uae38 \uc218 \uc788\ub294 \ud658\uacbd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub2e8\uc21c\ud55c \uc74c\uc8fc\uac00 \uc544\ub2cc \uac10\uac01\uc801\uc774\uace0 \ud488\uaca9 \uc788\ub294 \uacbd\ud5d8\uc744 \ud1b5\ud574 \uace0\uac1d\ub2d8\uc758 \ub9cc\uc871\uc744 \uc774\ub04c\uc5b4\ub0c5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uacbd\ud5d8<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uc5d0\ud504\uc6d0\uc740 \uac15\ub0a8\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 \ub3c5\ud2b9\ud55c \ub9e4\ub825\uacfc \ud488\uaca9 \uc788\ub294 \uacf5\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc138\ub828\ub41c \ubd84\uc704\uae30\uc640 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4\ub85c \uace0\uac1d\ub2d8\uc758 \uae30\ub300\ub97c \ub6f0\uc5b4\ub118\ub294 \ub9cc\uc871\uc744 \uc57d\uc18d\ub4dc\ub9ac\uba70, \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4e4\uc5b4\ub4dc\ub9bd\ub2c8\ub2e4.<br>\uc774\uacf3\uc5d0\uc11c\uc758 \uc220\uc790\ub9ac\ub294 \ub2e8\uc21c\ud55c \uc74c\uc8fc\ub97c \ub118\uc5b4\uc120 \ud2b9\ubcc4\ud55c \ucd94\uc5b5\uc73c\ub85c \ub0a8\uc744 \uac83\uc785\ub2c8\ub2e4. \uac15\ub0a8 \uca5c\uc624 \uc5d0\ud504\uc6d0\uc5d0\uc11c \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc744 \ub3d9\uc2dc\uc5d0 \ub290\uaef4\ubcf4\uc138\uc694.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \uca5c\uc624 \uc5d0\ud504\uc6d0\uc740 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc11c\ube44\uc2a4\ub97c \ubc14\ud0d5\uc73c\ub85c, \uace0\uac1d\ub2d8\uaed8 \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\ub97c \ub118\uc5b4\uc120 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":5605,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[29],"class_list":["post-5513","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-dot5"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5513","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5605"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5513"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5513"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}