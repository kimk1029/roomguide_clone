{"id":5500,"date":"2025-01-15T20:15:57","date_gmt":"2025-01-15T11:15:57","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%82%ac%eb%9d%bc%ec%9e%88%eb%84%a4\/"},"modified":"2025-04-28T18:22:12","modified_gmt":"2025-04-28T09:22:12","slug":"alive","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/alive\/","title":{"rendered":"\uc0ac\ub77c\uc788\ub124"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \uc0ac\ub77c\uc788\ub124 \uac00\ub77c\uc624\ucf00 \u2013 \uac15\ub0a8 \ucd5c\ub300 \uaddc\ubaa8\uc640 \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ud070 \uaddc\ubaa8\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\ub97c \uc790\ub791\ud558\ub294 <strong>\uc0ac\ub77c\uc788\ub124 \uac00\ub77c\uc624\ucf00<\/strong>\ub294 \uc80a\uc740 \uac10\uc131\uc758 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uae54\ub054\ud55c \uc2dc\uc124\ub85c \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud569\ub9ac\uc801\uc778 \uac00\uaca9 \uc815\ucc45\uacfc \ucd5c\uc0c1\uc758 \uc11c\ube44\uc2a4\ub85c \uac15\ub0a8\uc5d0\uc11c \ub9ce\uc740 \uc0ac\ub791\uc744 \ubc1b\uace0 \uc788\ub294 \uba85\uc18c\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc0ac\ub77c\uc788\ub124 \uac00\ub77c\uc624\ucf00\uc758 \ud2b9\ubcc4\ud55c \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \uc80a\uc740 \uac10\uc131\uc758 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4<\/h3>\n\n\n\n<p>\uc0ac\ub77c\uc788\ub124\ub294 \uae54\ub054\ud558\uace0 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4\ub85c \uc220\uc790\ub9ac\uc758 \ud488\uaca9\uc744 \ud55c\uce35 \ub192\uc5ec\uc90d\ub2c8\ub2e4. \uae30\uc874 \uac00\ub77c\uc624\ucf00\uc5d0\uc11c \ub290\ub07c\uae30 \uc5b4\ub824\uc6b4 \ucc28\ubcc4\ud654\ub41c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \ucd5c\ub300 \uaddc\ubaa8\uc640 \uc6b0\uc218\ud55c \uc218\uc9c8<\/h3>\n\n\n\n<p>\uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ud070 \uaddc\ubaa8\ub97c \uc790\ub791\ud558\uba70, \ud2b9\ud788 \uc218\uc9c8\uc774 \uc88b\uae30\ub85c \uc720\uba85\ud569\ub2c8\ub2e4. \uc774\uacf3\uc5d0\uc11c\ub294 \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\ub97c \ub118\uc5b4\uc120 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud558\uae30 \uc704\ud574 \ucd5c\uc120\uc744 \ub2e4\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ub2e4\uc591\ud55c \uace0\uac1d\uce35\uc744 \uc704\ud55c \ub9de\ucda4 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc0ac\ub77c\uc788\ub124\ub294 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300\ubfd0\ub9cc \uc544\ub2c8\ub77c \uc0dd\uc77c, \uce5c\ubaa9, \ud30c\ud2f0 \ubaa8\uc784 \ub4f1 \ub2e4\uc591\ud55c \uace0\uac1d\uce35\uc758 \ub2c8\uc988\ub97c \ucda9\uc871\uc2dc\ud0a4\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ub0a8\ub140 \ub3d9\ubc18 \ubc29\ubb38\ub3c4 \uac00\ub2a5\ud558\uc5ec \ub204\uad6c\uc640 \ud568\uaed8 \uc640\ub3c4 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud3b8\uc548\ud558\uace0 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9 \ubc0f \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uace0\uac1d\ub2d8\uc758 \ud3b8\ub9ac\ud55c \ubc29\ubb38\uc744 \uc704\ud574 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubcf5\uc7a1\ud55c \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \uc5ec\uc720\ub85c\uc6b4 \uc220\uc790\ub9ac\ub97c \uc2dc\uc791\ud560 \uc218 \uc788\uc73c\uba70, \ud3b8\uc548\ud55c \uc774\ub3d9 \ub610\ud55c \ubcf4\uc7a5\ub429\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">DJ \ubc0f \uc2f1\uc5b4 \uc12d\uc678 \uac00\ub2a5<\/h3>\n\n\n\n<p>\ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ud2b9\ubcc4\ud558\uac8c \ub9cc\ub4e4\uc5b4 \uc904 DJ\uc640 \uc2f1\uc5b4 \uc12d\uc678 \uc11c\ube44\uc2a4\ub3c4 \uc81c\uacf5\ub429\ub2c8\ub2e4. (\ubcc4\ub3c4 \ube44\uc6a9 \ubc1c\uc0dd) \uc774\ub97c \ud1b5\ud574 \ub9de\ucda4\ud615 \ud30c\ud2f0\uc640 \uc990\uac70\uc6b4 \ubd84\uc704\uae30\ub97c \uc870\uc131\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc548\uc804\ud55c \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>\uc0ac\ub77c\uc788\ub124\uc758 \uc2dc\uc2a4\ud15c\uc740 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub3c4\ub85d \uc124\uacc4\ub418\uc5c8\uc2b5\ub2c8\ub2e4. \ucca0\uc800\ud55c \uad00\ub9ac\uc640 \uad50\uc721\uc744 \ubc1b\uc740 \uc2a4\ud0dc\ud504\uc640 \ud30c\ud2b8\ub108\ub4e4\uc774 \uace0\uac1d\ub2d8\uaed8 \ud3b8\uc548\ud558\uace0 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc220\uc790\ub9ac\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud55c \uac00\uaca9 \uc815\ucc45\uacfc \uc2e0\ub8b0 \uacbd\uc601<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ud569\ub9ac\uc801\uc778 \uac00\uaca9 \uc815\ucc45<\/h3>\n\n\n\n<p>\uc0ac\ub77c\uc788\ub124\ub294 <strong>\uac70\ud488 \uc5c6\ub294 \ud22c\uba85 \uc815\ucc30\uc81c<\/strong>\ub97c \uc6b4\uc601\ud569\ub2c8\ub2e4. \uac00\uaca9\uc5d0 \ub300\ud55c \ubd88\uc548 \uc5c6\uc774 \uc220\uc790\ub9ac\ub97c \uc990\uae38 \uc218 \uc788\ub3c4\ub85d \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uba85\ud655\ud788 \uc548\ub0b4\ub429\ub2c8\ub2e4. \uc790\uc138\ud55c \ube44\uc6a9 \ubb38\uc758\ub294 \uc804\ud654\ub85c \uac00\ub2a5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc2e0\ub8b0\ub97c \uc6b0\uc120\uc73c\ub85c<\/h3>\n\n\n\n<p>\uc0ac\ub77c\uc788\ub124\ub294 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd9c\uadfc \ud604\ud669\uacfc \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0\uc744 \uc815\ud655\ud788 \uc548\ub0b4\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ub178\ub825\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud2b9\ubcc4\ud55c \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\ub4e4<\/h3>\n\n\n\n<p>\uc0ac\ub77c\uc788\ub124\uc5d0\uc11c\ub294 \uae4c\ub2e4\ub85c\uc6b4 \uae30\uc900\uc744 \ud1b5\ud574 \uc120\ubc1c\ub41c, \uc218\uc900 \ub192\uc740 \ubbf8\ubaa8\uc640 \ud655\uc2e4\ud55c \ub9c8\uc778\ub4dc\ub97c \uacb8\ube44\ud55c \ud30c\ud2b8\ub108\ub4e4\uacfc \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc2a4\ud0c0\uc77c\uc758 \ud30c\ud2b8\ub108\ub97c \uc120\ud0dd\ud560 \uc218 \uc788\uc5b4 \ub354\uc6b1 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uac10\uac01\uc801\uc778 \uc560\uc778 \ubaa8\ub4dc\uc758 \uc790\uc720\ub85c\uc6b4 \uc220\uc790\ub9ac<\/h3>\n\n\n\n<p>\ud37c\ube14\ub9ad \uac00\ub77c\uc624\ucf00\uc758 \uc7a5\uc810\uc744 \uc0b4\ub9ac\uba74\uc11c\ub3c4 \ud558\uc774\uca5c\uc624\uae09 \ud004\ub9ac\ud2f0\ub97c \uc81c\uacf5\ud558\ub294 \ud558\uc774\ud37c\ube14\ub9ad \uc2dc\uc2a4\ud15c\uc744 \ud1b5\ud574, \uc560\uc778\ucc98\ub7fc \uc790\uc5f0\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \uc74c\uc8fc\uac00\ubb34\ub97c \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ub3c5\ud2b9\ud55c \uacbd\ud5d8<\/h2>\n\n\n\n<p>\uc0ac\ub77c\uc788\ub124\ub294 \uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ub3c5\ud2b9\ud55c \ub9e4\ub825\uc744 \uc9c0\ub2cc \uac00\ub77c\uc624\ucf00\uc785\ub2c8\ub2e4. \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uc73c\ub85c \uace0\ud488\uaca9 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uaed8 \ucd5c\uace0\uc758 \ub9cc\uc871\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c \uc78a\uc9c0 \ubabb\ud560 \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc6d0\ud558\uc2e0\ub2e4\uba74 \uc0ac\ub77c\uc788\ub124\ub97c \uc120\ud0dd\ud574 \ubcf4\uc138\uc694!<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h3 class=\"wp-block-heading\">\ubb38\uc758 \ubc0f \uc608\uc57d<\/h3>\n\n\n\n<ul class=\"wp-block-list\">\n<li>\uc6b4\uc601\uc2dc\uac04: <strong>\uc77c\uc694\uc77c \ubc0f \uacf5\ud734\uc77c \ud734\ubb34<\/strong><\/li>\n\n\n\n<li>\uc608\uc57d \ubc0f \ubb38\uc758: <strong>\uc804\ud654 \ubb38\uc758<\/strong><\/li>\n<\/ul>\n\n\n\n<p>\uc0ac\ub77c\uc788\ub124 \uac00\ub77c\uc624\ucf00\ub294 \uace0\uac1d\ub2d8\uaed8 \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uae30 \uc704\ud574 \ud56d\uc0c1 \ub178\ub825\ud569\ub2c8\ub2e4. \uc9c0\uae08 \ubc14\ub85c \uc608\uc57d\ud558\uc2dc\uace0 \uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac\ub97c \uc990\uaca8\ubcf4\uc138\uc694.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ud070 \uaddc\ubaa8\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\ub97c \uc790\ub791\ud558\ub294 \uc0ac\ub77c\uc788\ub124 \uac00\ub77c\uc624\ucf00\ub294 \uc80a\uc740 \uac10\uc131\uc758 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uae54\ub054\ud55c \uc2dc\uc124\ub85c \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. <\/p>\n","protected":false},"featured_media":5579,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[27],"class_list":["post-5500","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-hipublic"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5500","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5579"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5500"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5500"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}