{"id":5520,"date":"2025-01-06T20:15:59","date_gmt":"2025-01-06T11:15:59","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%eb%af%b8%eb%9d%bc%ed%81%b4\/"},"modified":"2025-03-26T12:44:04","modified_gmt":"2025-03-26T03:44:04","slug":"miracle","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/miracle\/","title":{"rendered":"\ubbf8\ub77c\ud074"},"content":{"rendered":"\n<h2 class=\"wp-block-heading\">\uac15\ub0a8 \uca5c\uc624 &#8220;\ubbf8\ub77c\ud074&#8221; &#8211; \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc120\uc0ac\ud558\ub294 \uacf5\uac04<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 &#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \uace0\uac1d\ub2d8\uaed8 \uace0\uae09\uc2a4\ub7fd\uace0 \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc81c\uacf5\ud558\ub294 \ud504\ub9ac\ubbf8\uc5c4 \uacf5\uac04\uc785\ub2c8\ub2e4. \uc774\uacf3\uc5d0\uc11c\ub294 \uc138\ub828\ub418\uace0 \uc544\ub291\ud55c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ucd5c\uace0\uae09 \uc11c\ube44\uc2a4\uc640 \ud568\uaed8 \uae30\uc5b5\uc5d0 \ub0a8\ub294 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\uc640 \ud658\uacbd\uc744 \ud1b5\ud574, \uc220\uc790\ub9ac\ub294 \ub2e8\uc21c\ud55c \uc990\uac70\uc6c0\uc774 \uc544\ub2cc \ud558\ub098\uc758 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc73c\ub85c \ubc14\ub01d\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ube44\uc988\ub2c8\uc2a4 \ubc0f \uc911\uc694\ud55c \ubaa8\uc784\uc5d0 \ucd5c\uc801\ud654\ub41c \uacf5\uac04<\/h2>\n\n\n\n<p>&#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \uc911\uc694\ud55c \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uc774\ub098 \uc811\ub300\uc5d0\ub3c4 \uc801\ud569\ud55c \uc644\ubcbd\ud55c \uacf5\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uace0\uae09\uc2a4\ub7fd\uace0 \ucc28\ubd84\ud55c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \uc911\uc694\ud55c \ub300\ud654\ub97c \ub098\ub204\uac70\ub098, \uc911\uc694\ud55c \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uc744 \uc9c4\ud589\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub610\ud55c, \uc18c\uc911\ud55c \uc0ac\ub78c\ub4e4\uacfc\uc758 \ud30c\ud2f0\ub098 \uae30\ub150\uc77c \ubaa8\uc784\uc5d0\ub3c4 \ucd5c\uc801\uc758 \uc7a5\uc18c\ub85c, \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ud2b9\ubcc4\ud558\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4. &#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \uace0\uac1d\ub2d8\uc758 \ubaa8\ub4e0 \uc694\uad6c\ub97c \ub9cc\uc871\uc2dc\ud0ac \uc218 \uc788\ub294 \uc644\ubcbd\ud55c \ud658\uacbd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<p>&#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \uace0\uac1d\ub2d8\uc758 \ud3b8\ub9ac\ud55c \ubc29\ubb38\uc744 \uc704\ud574 \ubc1c\ub81b\ud30c\ud0b9 \uc11c\ube44\uc2a4\uc640 \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubc1c\ub81b\ud30c\ud0b9\uc744 \ud1b5\ud574 \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \ubc14\ub85c \uc785\uc7a5\ud560 \uc218 \uc788\uc73c\uba70, \ub9ac\ubb34\uc9c4\uc744 \uc608\uc57d\ud558\uc2dc\uba74 \uc774\ub3d9 \uc911\uc5d0\ub3c4 \ud3b8\uc548\ud558\uac8c \ud734\uc2dd\uc744 \ucde8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub610\ud55c, \ud2b9\ubcc4\ud55c \ubd84\uc704\uae30\ub97c \uc6d0\ud558\uc2e0\ub2e4\uba74 \uc544\ud2f0\uc2a4\ud2b8\ub098 DJ \uc12d\uc678\ub3c4 \uac00\ub2a5(\ubcc4\ub3c4 \ube44\uc6a9 \ubc1c\uc0dd)\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \ucd5c\uc801\uc758 \ubd84\uc704\uae30\ub97c \uc5f0\ucd9c\ud574 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ucd5c\uc0c1\uc758 \uc11c\ube44\uc2a4\uc640 \ud488\uaca9 \uc788\ub294 \uc9c1\uc6d0\ub4e4<\/h2>\n\n\n\n<p>&#8220;\ubbf8\ub77c\ud074&#8221;\uc758 \uc9c1\uc6d0\ub4e4\uc740 \ubaa8\ub4e0 \uace0\uac1d\ub2d8\uaed8 \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uae30 \uc704\ud574 \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \uc544\uac00\uc528\ub4e4\uc740 \ubbf8\ubaa8\uc640 \ub9c8\uc778\ub4dc \ubaa8\ub450 \ub6f0\uc5b4\ub09c \uc218\uc900\uc744 \uc790\ub791\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc694\uad6c\uc5d0 \ub9de\ucdb0 \uc644\ubcbd\ud55c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \ud3b8\uc548\ud55c \uc220\uc790\ub9ac \uc2dc\uac04\uc744 \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d, \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub294 \ucca0\uc800\ud788 \uad00\ub9ac\ub429\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uc5b8\uc81c\ub098 \ud3b8\uc548\ud558\uace0 \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac\ub97c \ub9cc\ub07d\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\uc758 \uc644\ubcbd\ud55c \uc870\ud654<\/h2>\n\n\n\n<p>&#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uacfc \uc811\ub300\ub97c \ub3d9\uc2dc\uc5d0 \ub9cc\uc871\uc2dc\ud0ac \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uc911\uc694\ud55c \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305 \uc911\uc5d0\ub3c4 \uace0\uac1d\ub2d8\uc740 \uace0\uae09\uc2a4\ub7fd\uace0 \ucc28\ubd84\ud55c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ud6a8\uacfc\uc801\uc778 \ub300\ud654\ub97c \ub098\ub204\uc2e4 \uc218 \uc788\uc73c\uba70, \uc220\uc790\ub9ac\uc5d0\uc11c\ub3c4 \ud3b8\uc548\ud558\uace0 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4. &#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\uac00 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc774\uc5b4\uc9c0\ub294 \uc644\ubcbd\ud55c \ud658\uacbd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud558\uace0 \ud569\ub9ac\uc801\uc778 \uac00\uaca9 \uc815\ucc45<\/h2>\n\n\n\n<p>&#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \ud22c\uba85\ud558\uace0 \ud569\ub9ac\uc801\uc778 \uac00\uaca9 \uc815\ucc45\uc744 \uc790\ub791\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc8fc\ub300\uc640 \uc11c\ube44\uc2a4 \uc694\uae08\uc740 \uc0ac\uc804\uc5d0 \uc815\ud655\ud788 \uc548\ub0b4\ub418\uba70, \ucd94\uac00 \ube44\uc6a9 \uc5c6\uc774 \uace0\uac1d\ub2d8\uaed8 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uc73c\ub85c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8\uc11c\ub294 \uac00\uaca9\uc5d0 \ub300\ud55c \uac71\uc815 \uc5c6\uc774 \uc220\uc790\ub9ac\uc758 \ud488\uaca9\uc5d0 \uc9d1\uc911\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\uacfc\uc758 \uc2e0\ub8b0\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc9c0\uc18d\uc801\uc778 \uad00\uacc4<\/h2>\n\n\n\n<p>&#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \uace0\uac1d\ub2d8\uacfc\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ud55c \ubc88 \ubc29\ubb38\ud55c \uace0\uac1d\ub2d8\uc740 \ub300\ubd80\ubd84 \ub2e8\uace8\uc774 \ub418\uc5b4 \ub2e4\uc2dc \ucc3e\uac8c \ub429\ub2c8\ub2e4. &#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \uc5b8\uc81c\ub098 \uc815\ud655\ud558\uace0 \uc2e0\ub8b0\ud560 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4. \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc544\uac00\uc528\uc758 \uc218\ub098 \ub300\uae30 \uc2dc\uac04\uc5d0 \ub300\ud55c \uacfc\uc7a5 \uc5c6\uc774 \uc815\ud655\ud558\uac8c \uc548\ub0b4\ub4dc\ub9ac\uba70, \ud56d\uc0c1 \uace0\uac1d\ub2d8\uc758 \ub9cc\uc871\uc744 \uc704\ud574 \ub178\ub825\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \ub9e4\ub825\uc801\uc778 \uc544\uac00\uc528\ub4e4<\/h2>\n\n\n\n<p>&#8220;\ubbf8\ub77c\ud074&#8221;\uc5d0\ub294 \ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc744 \uc9c0\ub2cc \ub9e4\ub825\uc801\uc778 \uc544\uac00\uc528\ub4e4\uc774 \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uc790\uc2e0\ub9cc\uc758 \uc2a4\ud0c0\uc77c\uc744 \uace0\ub97c \uc218 \uc788\uc73c\uba70, \ubbf8\ubaa8\uc640 \ub9c8\uc778\ub4dc\uac00 \ub6f0\uc5b4\ub09c \uc544\uac00\uc528\ub4e4\ub9cc\uc744 \uc120\ubcc4\ud558\uc5ec \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8\uc11c\ub294 \ud3b8\uc548\ud558\uace0 \uc990\uac70\uc6b4 \uc220\uc790\ub9ac \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc2dc\uba70 \uc790\uc2e0\ub9cc\uc758 \uc2a4\ud0c0\uc77c\uc5d0 \ub9de\ub294 \uc544\uac00\uc528\uc640 \ud568\uaed8 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uae38 \uc218 \uc788\ub294 \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>&#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uae38 \uc218 \uc788\ub294 \uc220\uc790\ub9ac \ud658\uacbd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub294 \ucca0\uc800\ud788 \uad00\ub9ac\ub418\uba70, \uace0\uac1d\ub2d8\uaed8\uc11c \ud3b8\uc548\ud558\uac8c \uc220\uc744 \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \ub3d5\uc2b5\ub2c8\ub2e4. \ub0b4\uc0c1 \uc5c6\uc774 \uc990\uae38 \uc218 \uc788\ub294 \uc220\uc790\ub9ac\uc5d0\uc11c \ucd5c\uace0\uc758 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8 \uca5c\uc624 &#8220;\ubbf8\ub77c\ud074&#8221;\ub9cc\uc758 \ub3c5\ud2b9\ud55c \ub9e4\ub825<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 &#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \ub2e4\ub978 \uacf3\uc5d0\uc11c\ub294 \uacbd\ud5d8\ud560 \uc218 \uc5c6\ub294 \ub3c5\ud2b9\ud558\uace0 \ucc28\ubcc4\ud654\ub41c \ub9e4\ub825\uc744 \uc790\ub791\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uc138\ub828\ub41c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \uc790\uc720\ub86d\uac8c \uc220\uc744 \uc990\uae30\uba70, \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \ub9cc\ub07d\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. &#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \uace0\uac1d\ub2d8\uaed8 \ucd5c\uc0c1\uc758 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud558\uba70, \uc5b8\uc81c\ub098 \uc0c8\ub85c\uc6b4 \uc990\uac70\uc6c0\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c<\/h2>\n\n\n\n<p>&#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \uace0\uac1d\ub2d8\uc758 \uc2dc\uac04\uc744 \uac00\uc7a5 \uc18c\uc911\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub294 \uc815\ud655\ud558\uace0 \ud22c\uba85\ud558\uac8c \uc81c\uacf5\ub418\uba70, \uace0\uac1d\ub2d8\uaed8\uc11c \ubd88\ud3b8\ud568 \uc5c6\uc774 \uc220\uc790\ub9ac\ub97c \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \ucca0\uc800\ud558\uac8c \uad00\ub9ac\ub429\ub2c8\ub2e4. \uad81\uae08\ud55c \uc0ac\ud56d\uc774 \uc788\uc73c\uba74 \uc5b8\uc81c\ub4e0\uc9c0 \uce5c\uc808\ud558\uac8c \uc548\ub0b4\ub4dc\ub9ac\uba70, \uace0\uac1d\ub2d8\uaed8 \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud560 \uac83\uc785\ub2c8\ub2e4. &#8220;\ubbf8\ub77c\ud074&#8221;\uc5d0\uc11c \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \ub9cc\ub07d\ud558\uc2dc\uace0, \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc2dc\uae30 \ubc14\ub78d\ub2c8\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \uca5c\uc624 &#8220;\ubbf8\ub77c\ud074&#8221; &#8211; \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc120\uc0ac\ud558\ub294 \uacf5\uac04 \uac15\ub0a8 \uca5c\uc624 &#8220;\ubbf8\ub77c\ud074&#8221;\uc740 \uace0\uac1d\ub2d8\uaed8 \uace0\uae09\uc2a4\ub7fd\uace0 \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc81c\uacf5\ud558\ub294 \ud504\ub9ac\ubbf8\uc5c4 \uacf5\uac04\uc785\ub2c8\ub2e4. \uc774\uacf3\uc5d0\uc11c\ub294 \uc138\ub828\ub418\uace0 \uc544\ub291\ud55c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ucd5c\uace0\uae09 \uc11c\ube44\uc2a4\uc640 \ud568\uaed8 \uae30\uc5b5\uc5d0 \ub0a8\ub294 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\uc640 \ud658\uacbd\uc744 \ud1b5\ud574, \uc220\uc790\ub9ac\ub294 \ub2e8\uc21c\ud55c \uc990\uac70\uc6c0\uc774 \uc544\ub2cc \ud558\ub098\uc758 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc73c\ub85c \ubc14\ub01d\ub2c8\ub2e4. \ube44\uc988\ub2c8\uc2a4 \ubc0f \uc911\uc694\ud55c \ubaa8\uc784\uc5d0 \ucd5c\uc801\ud654\ub41c [&hellip;]<\/p>\n","protected":false},"featured_media":5564,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[29],"class_list":["post-5520","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-dot5"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5520","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5564"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5520"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5520"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}