{"id":5506,"date":"2025-01-06T20:15:57","date_gmt":"2025-01-06T11:15:57","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%eb%a9%94%ec%9d%b4%ec%bb%a4\/"},"modified":"2025-03-26T12:44:01","modified_gmt":"2025-03-26T03:44:01","slug":"maker","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/maker\/","title":{"rendered":"\uba54\uc774\ucee4"},"content":{"rendered":"\n<h2 class=\"wp-block-heading\">\uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad &#8220;\uba54\uc774\ucee4&#8221; &#8211; \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac\uc640 \ud2b9\ubcc4\ud55c \uacbd\ud5d8<\/h2>\n\n\n\n<p>\uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad &#8220;\uba54\uc774\ucee4&#8221;\ub294 \uac15\ub0a8\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uae09\uc2a4\ub7fd\uace0 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\ub294 &#8220;\uba54\uc774\ucee4&#8221;\ub294 \uace0\uac1d\ub2d8\uaed8 \ub3c5\ud2b9\ud558\uace0 \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \uc774\uacf3\uc5d0\uc11c\ub294 \ub2e8\uc21c\ud788 \uc220\uc744 \ub9c8\uc2dc\ub294 \uac83 \uc774\uc0c1\uc758 \uc990\uac70\uc6c0\uacfc \ud3b8\uc548\ud568\uc744 \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uaed8 \ucd5c\uace0\uc758 \ub9cc\uc871\uc744 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \ubaa8\uc784\uacfc \ud30c\ud2f0\uc5d0 \uc801\ud569\ud55c \ub9de\ucda4\ud615 \uacf5\uac04<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\ub294 \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305, \uc911\uc694\ud55c \uc811\ub300, \ud30c\ud2f0, \uae30\ub150\uc77c \ub4f1 \ub2e4\uc591\ud55c \uc6a9\ub3c4\uc5d0 \ub9de\ucdb0 \ucd5c\uc801\ud654\ub41c \uacf5\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc911\uc694\ud55c \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uc774\ub098 \uace0\uac1d \uc811\ub300\uac00 \ud544\uc694\ud558\uc2e0 \ubd84\ub4e4\uc5d0\uac8c \uc548\uc131\ub9de\ucda4\uc778 \uacf5\uac04\uc73c\ub85c, \uace0\uae09\uc2a4\ub7fd\uace0 \ucc28\ubd84\ud55c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \uc911\uc694\ud55c \ub300\ud654\ub97c \ub098\ub204\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub610\ud55c, \uce5c\uad6c\ub4e4\uacfc\uc758 \ud30c\ud2f0\ub098 \uc0dd\uc77c \ub4f1 \ud2b9\ubcc4\ud55c \ub0a0\uc744 \uae30\ub150\ud558\ub294 \ubaa8\uc784\uc5d0\ub3c4 \uc644\ubcbd\ud55c \uc7a5\uc18c\ub85c, \uc18c\uc911\ud55c \uc0ac\ub78c\ub4e4\uacfc \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4 \uc81c\uacf5<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\ub294 \uace0\uac1d\ub2d8\uc758 \ud3b8\ub9ac\ud55c \ubc29\ubb38\uc744 \uc704\ud574 \ubc1c\ub81b\ud30c\ud0b9 \uc11c\ube44\uc2a4\uc640 \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubc1c\ub81b\ud30c\ud0b9\uc744 \ud1b5\ud574 \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \ubc14\ub85c \uc785\uc7a5\ud558\uc2e4 \uc218 \uc788\uc73c\uba70, \ub9ac\ubb34\uc9c4 \uc608\uc57d\uc744 \ud1b5\ud574 \ud3b8\uc548\ud558\uac8c \uc774\ub3d9\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub610\ud55c, \ud2b9\ubcc4\ud55c \ubd84\uc704\uae30\ub97c \uc6d0\ud558\ub294 \uace0\uac1d\ub2d8\uc744 \uc704\ud574 DJ\ub098 \uc544\ud2f0\uc2a4\ud2b8 \uc12d\uc678\ub3c4 \uac00\ub2a5\ud558\uba70(\ubcc4\ub3c4\uc758 \ube44\uc6a9 \ubc1c\uc0dd), \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ucdb0 \ucd5c\uc801\uc758 \ubd84\uc704\uae30\ub97c \uc5f0\ucd9c\ud574 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ucd5c\uc0c1\uc758 \uc11c\ube44\uc2a4\uc640 \uce5c\uc808\ud55c \uc9c1\uc6d0\ub4e4<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\uc758 \uc544\uac00\uc528\ub4e4\uc740 \uace0\uac1d\ub2d8\uc744 \ub9de\uc774\ud560 \uc900\ube44\uac00 \ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \ubbf8\ubaa8\uc640 \ub9c8\uc778\ub4dc\uac00 \ub6f0\uc5b4\ub09c \uc544\uac00\uc528\ub4e4\uc740 \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ucdb0 \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub294 \ucca0\uc800\ud558\uac8c \uad00\ub9ac\ub418\uba70, \uace0\uac1d\ub2d8\uaed8\uc11c \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \ud3b8\uc548\ud558\uac8c \uc220\uc790\ub9ac\ub97c \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \ub3c4\uc640\ub4dc\ub9bd\ub2c8\ub2e4. &#8220;\uba54\uc774\ucee4&#8221;\uc5d0\uc11c\uc758 \uc11c\ube44\uc2a4\ub294 \uc138\uc2ec\ud558\uace0 \uace0\uae09\uc2a4\ub7fd\uae30 \ub54c\ubb38\uc5d0 \uc5b8\uc81c\ub098 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\uc758 \uc644\ubcbd\ud55c \uade0\ud615<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\ub294 \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uacfc \uc811\ub300\ub97c \ub3d9\uc2dc\uc5d0 \ub9cc\uc871\uc2dc\ud0ac \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uc744 \uc9c4\ud589\ud558\uba70 \uc911\uc694\ud55c \ub300\ud654\ub97c \ub098\ub204\uc2e4 \uc218 \uc788\uace0, \uc811\ub300\uc640 \uc220\uc790\ub9ac\ub97c \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. &#8220;\uba54\uc774\ucee4&#8221;\uc758 \ubd84\uc704\uae30\uc640 \uc11c\ube44\uc2a4\ub294 \ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\uac00 \uc790\uc5f0\uc2a4\ub7fd\uac8c \uc774\ub8e8\uc5b4\uc9c0\ub294 \uc644\ubcbd\ud55c \ud658\uacbd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud558\uace0 \ud569\ub9ac\uc801\uc778 \uac00\uaca9 \uc815\ucc45<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\ub294 \ud22c\uba85\ud558\uace0 \ud569\ub9ac\uc801\uc778 \uac00\uaca9 \uc815\ucc45\uc744 \uc790\ub791\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc8fc\ub300\ub294 \uc0ac\uc804 \uc548\ub0b4\ub97c \ud1b5\ud574 \uc815\ud655\ud788 \uc804\ub2ec\ub4dc\ub9ac\uba70, \ucd94\uac00 \ube44\uc6a9 \uc5c6\uc774 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uc73c\ub85c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8\uc11c\ub294 \uac00\uaca9\uc5d0 \ub300\ud55c \uac71\uc815 \uc5c6\uc774 \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac\ub97c \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\uacfc\uc758 \uc2e0\ub8b0\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc9c0\uc18d\uc801\uc778 \uad00\uacc4<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\ub294 \uace0\uac1d\ub2d8\uacfc\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud55c \uac00\uce58\ub85c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ud55c \ubc88 \ubc29\ubb38\ud55c \uace0\uac1d\ub2d8\uc740 \ub300\ubd80\ubd84 \ub2e8\uace8\uc774 \ub418\uc5b4 \ub2e4\uc2dc \ucc3e\uac8c \ub429\ub2c8\ub2e4. &#8220;\uba54\uc774\ucee4&#8221;\ub294 \uc5b8\uc81c\ub098 \uc815\ud655\ud558\uace0 \uc2e0\ub8b0\ud560 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \uc694\uad6c\uc5d0 \ub9de\ub294 \uc815\ud655\ud55c \ucd08\uc774\uc2a4 \uc815\ubcf4\uc640 \ub300\uae30 \uc2dc\uac04\uc744 \uc81c\uacf5\ud558\uba70, \uc5b8\uc81c\ub098 \ub9cc\uc871\uc744 \ub4dc\ub9ac\uae30 \uc704\ud574 \ub178\ub825\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \ub9e4\ub825\uc801\uc778 \uc544\uac00\uc528\ub4e4<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\uc5d0\ub294 \ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \uc544\uac00\uc528\ub4e4\uc774 \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uc790\uc2e0\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc2a4\ud0c0\uc77c\uc744 \uc120\ud0dd\ud558\uc2e4 \uc218 \uc788\uc73c\uba70, \ubbf8\ubaa8\uc640 \ub9c8\uc778\ub4dc \ubaa8\ub450\uc5d0\uc11c \ub6f0\uc5b4\ub09c \uc218\uc900\uc744 \uc790\ub791\ud558\ub294 \uc544\uac00\uc528\ub4e4\ub9cc\uc744 \uc120\ubcc4\ud558\uc5ec \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8\uc11c\ub294 \uc790\uc2e0\ub9cc\uc758 \uc2a4\ud0c0\uc77c\ub85c \uc220\uc790\ub9ac\ub97c \uc990\uae30\uba70 \ud3b8\uc548\ud55c \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uae38 \uc218 \uc788\ub294 \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\ub294 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uae38 \uc218 \uc788\ub294 \uc220\uc790\ub9ac \ud658\uacbd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub294 \ucca0\uc800\ud788 \uad00\ub9ac\ub418\uba70, \uace0\uac1d\ub2d8\uaed8\uc11c \ud3b8\uc548\ud558\uac8c \uc220\uc744 \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \ub3d5\uc2b5\ub2c8\ub2e4. \ub0b4\uc0c1 \uc5c6\uc774 \uc220\uc790\ub9ac\ub97c \uc990\uae30\uace0 \uc2f6\uc740 \ubd84\ub4e4\uc5d0\uac8c &#8220;\uba54\uc774\ucee4&#8221;\ub294 \uc644\ubcbd\ud55c \uc120\ud0dd\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad &#8220;\uba54\uc774\ucee4&#8221;\ub9cc\uc758 \ub3c5\ud2b9\ud55c \ub9e4\ub825<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\ub294 \uac15\ub0a8\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 \ub3c5\ud2b9\ud55c \ub9e4\ub825\uc744 \uc9c0\ub2cc \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uc790\uc720\ub86d\uace0 \ud3b8\uc548\ud55c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \uc220\uc744 \uc990\uae30\uba70, \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \ub9cc\ub07d\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. &#8220;\uba54\uc774\ucee4&#8221;\ub294 \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ucdb0 \ucd5c\uc0c1\uc758 \uacbd\ud5d8\uc744 \uc120\uc0ac\ud558\uba70, \uc5b8\uc81c\ub4e0\uc9c0 \uc0c8\ub85c\uc6b4 \uc990\uac70\uc6c0\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c<\/h2>\n\n\n\n<p>&#8220;\uba54\uc774\ucee4&#8221;\ub294 \uace0\uac1d\ub2d8\uc758 \uc2dc\uac04\uc744 \uac00\uc7a5 \uc18c\uc911\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub294 \uc815\ud655\ud558\uace0 \ud22c\uba85\ud558\uac8c \uc81c\uacf5\ub418\uba70, \uace0\uac1d\ub2d8\uaed8\uc11c \ubd88\ud3b8\ud568 \uc5c6\uc774 \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \ucca0\uc800\ud558\uac8c \uad00\ub9ac\ub429\ub2c8\ub2e4. \uc5b8\uc81c\ub4e0\uc9c0 \uad81\uae08\ud55c \uc0ac\ud56d\uc774 \uc788\uc73c\uc2dc\uba74 \uce5c\uc808\ud558\uac8c \uc548\ub0b4\ub4dc\ub9ac\uba70, \uace0\uac1d\ub2d8\uaed8 \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud560 \uac83\uc785\ub2c8\ub2e4. &#8220;\uba54\uc774\ucee4&#8221;\uc5d0\uc11c \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \ub9cc\ub07d\ud558\uc2dc\uace0, \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc2dc\uae30 \ubc14\ub78d\ub2c8\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uace0\uae09\uc2a4\ub7fd\uace0 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\ub294 &#8220;\uba54\uc774\ucee4&#8221;\ub294 \uace0\uac1d\ub2d8\uaed8 \ub3c5\ud2b9\ud558\uace0 \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":5568,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[27],"class_list":["post-5506","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-hipublic"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5506","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5568"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5506"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5506"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}