{"id":5499,"date":"2025-01-06T20:15:57","date_gmt":"2025-01-06T11:15:57","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%94%a8%ec%97%94%ec%97%94\/"},"modified":"2025-01-15T22:01:15","modified_gmt":"2025-01-15T13:01:15","slug":"cnn","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/cnn\/","title":{"rendered":"\uc528\uc5d4\uc5d4"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \ud638\uc2a4\ud2b8\ubc14 \uc528\uc5d4\uc5d4 \u2013 \ub2f9\uc2e0\ub9cc\uc744 \uc704\ud55c \ud2b9\ubcc4\ud55c \uc21c\uac04\uc758 \ub274\uc2a4<\/h3>\n\n\n\n<p>\uac15\ub0a8 **\ud638\uc2a4\ud2b8\ubc14 \uc528\uc5d4\uc5d4(CNN)**\uc740 \uc5ec\uc131 \uace0\uac1d\ub2d8\ub4e4\ub9cc\uc744 \uc704\ud574 \ub9c8\ub828\ub41c \ud488\uaca9 \uc788\uace0 \uc138\ub828\ub41c \uacf5\uac04\uc785\ub2c8\ub2e4. \uc774\ub984\ucc98\ub7fc \ud56d\uc0c1 \uc0c8\ub86d\uace0 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc804\ub2ec\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \ud558\ub8e8\ub97c \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4ed\ub2c8\ub2e4. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0\uc11c \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc744 \ub3d9\uc2dc\uc5d0 \ub204\ub9b4 \uc218 \uc788\ub294 \ucd5c\uace0\uc758 \uc120\ud0dd, \uc528\uc5d4\uc5d4\uc5d0\uc11c \ub2f9\uc2e0\ub9cc\uc758 \ud2b9\ubcc4\ud55c \uc774\uc57c\uae30\ub97c \ub9cc\ub4e4\uc5b4 \ubcf4\uc138\uc694.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc528\uc5d4\uc5d4\ub9cc\uc758 \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \ud2b8\ub80c\ub514\ud558\uba74\uc11c\ub3c4 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uac10\uac01\uc801\uc778 \ub514\uc790\uc778\uc73c\ub85c \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc744 \ub9cc\uc871\uc2dc\ud0ac \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uc6b0\uc544\ud55c \uc870\uba85\uacfc \uace0\uae09\uc2a4\ub7ec\uc6b4 \ub514\ud14c\uc77c\uc774 \uc5b4\uc6b0\ub7ec\uc838 \uace0\uac1d\ub2d8\uaed8 \ud2b9\ubcc4\ud558\uace0 \uc78a\uc9c0 \ubabb\ud560 \uc21c\uac04\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \uc774\uacf3\uc5d0\uc11c \ub2f9\uc2e0\uc740 \uc624\ub86f\uc774 \uc8fc\uc778\uacf5\uc774 \ub418\uc5b4 \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ub204\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc758 \ud3b8\ub9ac\ud55c \uc704\uce58<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud558\uc5ec \uc774\ub3d9\uacfc \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub0a9\ub2c8\ub2e4. \ud654\ub824\ud55c \uac15\ub0a8\uc758 \uc5d0\ub108\uc9c0\uc640 \uc528\uc5d4\uc5d4\ub9cc\uc758 \ucc28\ubd84\ud558\uace0 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\ub97c \ud568\uaed8 \ub290\ub084 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ubaa8\ub4e0 \ubaa9\uc801\uc5d0 \ub9de\ub294 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uc0dd\uc77c \ud30c\ud2f0, \uae30\ub150\uc77c \ucd95\ud558, \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \uace0\uac1d\ub2d8\uc758 \ub2e4\uc591\ud55c \ubaa9\uc801\uc5d0 \ub9de\ub294 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ud2b9\ubcc4\ud558\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9ac\uae30 \uc704\ud574 \uc138\uc2ec\ud558\uac8c \uc900\ube44\ub41c \uc528\uc5d4\uc5d4\ub9cc\uc758 \ud2b9\ubcc4\ud568\uc744 \uacbd\ud5d8\ud574 \ubcf4\uc138\uc694.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d \uc911\uc2ec\uc758 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ud504\ub77c\uc774\ube57 \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uace0\uac1d\ub2d8\uc758 \ubc29\ubb38\uc774 \ub354 \ud3b8\uc548\ud558\ub3c4\ub85d \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \ubc14\ub85c \uc785\uc7a5\ud560 \uc218 \uc788\uc73c\uba70, \uc774\ub3d9 \uacfc\uc815\uc5d0\uc11c\ub3c4 \ud488\uaca9\uc744 \ub290\ub084 \uc218 \uc788\ub3c4\ub85d \uc138\uc2ec\ud558\uac8c \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9de\ucda4\ud615 \uc774\ubca4\ud2b8 \uc5f0\ucd9c<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uace0\uac1d\ub2d8\uc758 \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4. DJ\uc640 \uc774\ubca4\ud2b8 \uc804\ubb38\uac00\uc758 \uc138\uc2ec\ud55c \uc900\ube44\ub85c, \ub2f9\uc2e0\ub9cc\uc758 \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \uc78a\uc9c0 \ubabb\ud560 \ucd94\uc5b5\uc73c\ub85c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud638\uc2a4\ud2b8\uc640 \ud568\uaed8\ud558\ub294 \ud2b9\ubcc4\ud55c \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ud488\uaca9\uacfc \ub9e4\ub825\uc744 \uacb8\ube44\ud55c \ud638\uc2a4\ud2b8<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uc5c4\uaca9\ud788 \uc120\ubc1c\ub41c \ud488\uaca9 \uc788\uace0 \ub9e4\ub825\uc801\uc778 \ud638\uc2a4\ud2b8\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uacfc \ubd84\uc704\uae30\uc5d0 \ub9de\ucdb0 \ud638\uc2a4\ud2b8\uac00 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uacfc \uc78a\uc9c0 \ubabb\ud560 \uc990\uac70\uc6c0\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uc528\uc5d4\uc5d4\ub9cc\uc758 \uc790\uc720\ub86d\uace0 \uc138\ub828\ub41c \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uc5ec\uc131 \uace0\uac1d\ub2d8\ub4e4\ub9cc\uc744 \uc704\ud55c \uc548\uc804\ud558\uace0 \uc790\uc720\ub85c\uc6b4 \uacf5\uac04\uc73c\ub85c, \ub204\uad6c\uc640 \ud568\uaed8\ud558\ub4e0 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub3c4\ub85d \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud558\uace0 \uc2e0\ub8b0\ud560 \uc218 \uc788\ub294 \uc6b4\uc601<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\uc815\ucc30\uc81c\ub97c \ud1b5\ud55c \ud569\ub9ac\uc801 \uac00\uaca9<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uc815\ucc30\uc81c\ub97c \ud1b5\ud574 \ubaa8\ub4e0 \ube44\uc6a9\uc744 \uc0ac\uc804\uc5d0 \uba85\ud655\ud788 \uc548\ub0b4\ud569\ub2c8\ub2e4. \ucd94\uac00 \uc694\uae08 \uac71\uc815 \uc5c6\uc774 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uc73c\ub85c \ud488\uaca9 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \uc18c\uc911\ud788 \uc5ec\uae41\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uc2e0\ub8b0\ub97c \uc911\uc2ec\uc73c\ub85c \ud55c \uc6b4\uc601 \ucca0\ud559<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ud638\uc2a4\ud2b8 \uc120\ud0dd\uacfc \uc11c\ube44\uc2a4 \uc81c\uacf5 \ub0b4\uc6a9\uc5d0 \ub300\ud574 \ubaa8\ub4e0 \uc815\ubcf4\ub97c \uba85\ud655\ud788 \uc548\ub0b4\ud558\uc5ec \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub354 \uac00\uce58 \uc788\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c \uc0c8\ub85c\uc6b4 \uc774\uc57c\uae30\uac00 \uc2dc\uc791\ub418\ub294 \uacf3<\/h2>\n\n\n\n<p>\uac15\ub0a8 \ud638\uc2a4\ud2b8\ubc14 \uc528\uc5d4\uc5d4\uc740 \uc5ec\uc131 \uace0\uac1d\ub2d8\ub9cc\uc744 \uc704\ud55c \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825\uacfc \ud2b9\ubcc4\ud568\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud488\uaca9 \uc788\ub294 \uc11c\ube44\uc2a4\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uacf5\uac04\uc740 \uc77c\uc0c1\uc5d0\uc11c \ubc97\uc5b4\ub098 \ud2b9\ubcc4\ud55c \ucd94\uc5b5\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<br>\uc528\uc5d4\uc5d4\uc5d0\uc11c\uc758 \uc2dc\uac04\uc740 \ub2f9\uc2e0\ub9cc\uc744 \uc704\ud55c \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc774 \uc870\ud654\ub97c \uc774\ub8e8\ub294 \uc21c\uac04\uc73c\ub85c \uae30\uc5b5\ub420 \uac83\uc785\ub2c8\ub2e4. \uc9c0\uae08 \ubc14\ub85c \uc528\uc5d4\uc5d4\uc5d0\uc11c \ub2f9\uc2e0\ub9cc\uc758 \ud2b9\ubcc4\ud55c \uc774\uc57c\uae30\ub97c \uc2dc\uc791\ud574 \ubcf4\uc138\uc694!<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc528\uc5d4\uc5d4\uc740 \uc0dd\uc77c \ud30c\ud2f0, \uae30\ub150\uc77c \ucd95\ud558, \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \uace0\uac1d\ub2d8\uc758 \ub2e4\uc591\ud55c \ubaa9\uc801\uc5d0 \ub9de\ub294 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. <\/p>\n","protected":false},"featured_media":2398,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[31],"class_list":["post-5499","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-hostbar"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5499","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/2398"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5499"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5499"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}