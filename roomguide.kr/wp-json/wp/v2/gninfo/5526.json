{"id":5526,"date":"2025-01-06T20:15:59","date_gmt":"2025-01-06T11:15:59","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%8a%a4%ed%85%8c%ec%9d%b4\/"},"modified":"2025-03-26T12:47:59","modified_gmt":"2025-03-26T03:47:59","slug":"stay","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/stay\/","title":{"rendered":"\uc2a4\ud14c\uc774"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \uca5c\uc624 \uc2a4\ud14c\uc774 \u2013 \ud488\uaca9 \uc788\ub294 \uacf5\uac04\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac<\/h3>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 <strong>\uc2a4\ud14c\uc774<\/strong>\ub294 \ucc28\ubd84\ud558\uace0 \uc138\ub828\ub41c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac\ub97c \uc990\uae38 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uacf5\uac04\uc785\ub2c8\ub2e4. \ubaa8\ub358\ud55c \uc778\ud14c\ub9ac\uc5b4\uc640 \uae54\ub054\ud55c \uc2dc\uc124, \ud569\ub9ac\uc801\uc778 \uac00\uaca9 \uc815\ucc45\uc73c\ub85c \uac15\ub0a8\uc758 \ub2e4\uc591\ud55c \uace0\uac1d\ub4e4\uc5d0\uac8c \uc0ac\ub791\ubc1b\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uca5c\uc624 \uc2a4\ud14c\uc774\uc758 \ud2b9\ubcc4\ud55c \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \ubaa8\ub358\ud558\uace0 \uac10\uac01\uc801\uc778 \uc778\ud14c\ub9ac\uc5b4<\/h3>\n\n\n\n<p>\uc2a4\ud14c\uc774\ub294 \uae54\ub054\ud558\uace0 \ucc28\ubd84\ud55c \uc778\ud14c\ub9ac\uc5b4\ub85c \uc138\ub828\ub41c \ubd84\uc704\uae30\ub97c \uc790\ub791\ud569\ub2c8\ub2e4. \ubcf5\uc7a1\ud55c \ub3c4\uc2ec \uc18d\uc5d0\uc11c\ub3c4 \ud3b8\uc548\ud568\uacfc \uc5ec\uc720\ub97c \ub290\ub084 \uc218 \uc788\ub294 \uacf5\uac04\uc73c\ub85c, \ube44\uc988\ub2c8\uc2a4\uc640 \uc0ac\uad50 \ubaa8\uc784 \ubaa8\ub450\uc5d0 \uc801\ud569\ud55c \uc7a5\uc18c\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\uc758 \ucd5c\uc801\uc758 \uc785\uc9c0\uc640 \ub300\uaddc\ubaa8 \uc2dc\uc124<\/h3>\n\n\n\n<p>\uca5c\uc624 \uc2a4\ud14c\uc774\ub294 \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud558\uba70 \ub113\uace0 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uacf5\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c\ub3c4 \uc190\uaf3d\ud788\ub294 \uaddc\ubaa8\uc640 \ud488\uc9c8\ub85c \uace0\uac1d\ub2d8\uc758 \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ud574\ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ubaa8\ub4e0 \uace0\uac1d\uc744 \uc704\ud55c \ub2e4\ubaa9\uc801 \uacf5\uac04<\/h3>\n\n\n\n<p>\ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \uc0dd\uc77c \ud30c\ud2f0, \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \ub2e4\uc591\ud55c \ubaa9\uc801\uc5d0 \ub9de\ub294 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \ub0a8\ub140 \ub3d9\ubc18 \ubc29\ubb38\ub3c4 \uac00\ub2a5\ud558\uc5ec \ub354\uc6b1 \ud3ed\ub113\uc740 \uc120\ud0dd\uc9c0\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d \ub9cc\uc871\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uace0\uac1d\ub2d8\uc758 \ud3b8\uc758\ub97c \uc704\ud574 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \ubc29\ubb38\ud560 \uc218 \uc788\uc73c\uba70, \uc774\ub3d9 \ub610\ud55c \ud3b8\uc548\ud558\uace0 \ud504\ub77c\uc774\ube57\ud558\uac8c \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ud2b9\ubcc4 \uc774\ubca4\ud2b8\ub97c \uc704\ud55c DJ \ubc0f \uc2f1\uc5b4 \uc12d\uc678<\/h3>\n\n\n\n<p>\uc2a4\ud14c\uc774\uc5d0\uc11c\ub294 \uace0\uac1d\ub2d8\uc758 \uc694\uccad\uc5d0 \ub530\ub77c DJ\uc640 \uc2f1\uc5b4 \uc12d\uc678\uac00 \uac00\ub2a5\ud558\uba70, \ub9de\ucda4\ud615 \uc774\ubca4\ud2b8\ub97c \ud1b5\ud574 \ub354\uc6b1 \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4. (\ubcc4\ub3c4 \ube44\uc6a9 \ubc1c\uc0dd)<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc548\uc804\ud55c \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>\uca5c\uc624 \uc2a4\ud14c\uc774\ub294 \uace0\uac1d\ub2d8\uc758 \ud3b8\uc548\ud55c \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucca0\uc800\ud788 \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uacfc \uc804\ubb38 \uad50\uc721\uc744 \ubc1b\uc740 \uc2a4\ud0dc\ud504\ub97c \ud1b5\ud574 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \ud3b8\uc548\ud558\uace0 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\uc7a5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud55c \uac00\uaca9 \uc815\ucc45\uacfc \uc2e0\ub8b0 \uacbd\uc601<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\uac70\ud488 \uc5c6\ub294 \ud569\ub9ac\uc801\uc778 \uac00\uaca9<\/h3>\n\n\n\n<p>\uc2a4\ud14c\uc774\ub294 \ud22c\uba85\ud55c \uc815\ucc30\uc81c\ub97c \uc6b4\uc601\ud558\uc5ec, \uace0\uac1d\ub2d8\uaed8 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uc73c\ub85c \ud488\uaca9 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uc548\ub0b4\ub4dc\ub9ac\uba70, \ucd94\uac00 \uc694\uae08 \uac71\uc815 \uc5c6\uc774 \ud3b8\uc548\ud558\uac8c \uc774\uc6a9\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc2e0\ub8b0\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c<\/h3>\n\n\n\n<p>\uca5c\uc624 \uc2a4\ud14c\uc774\ub294 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd9c\uadfc \ud604\ud669\uacfc \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0\uc744 \uc815\ud655\ud788 \uc548\ub0b4\ud558\uc5ec \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9e4\ub825\uacfc \ud488\uaca9\uc744 \uacb8\ube44\ud55c \ud30c\ud2b8\ub108<\/h3>\n\n\n\n<p>\uc2a4\ud14c\uc774\uc5d0\uc11c\ub294 \uae4c\ub2e4\ub85c\uc6b4 \uae30\uc900\uc744 \ud1b5\ud574 \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc774\uace0 \ud488\uaca9 \uc788\ub294 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc2a4\ud0c0\uc77c\uc744 \uc120\ud0dd\ud558\uc5ec \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ub9cc\ub4e4\uc5b4 \ubcf4\uc138\uc694.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uca5c\uc624\ub9cc\uc758 \uc790\uc5f0\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\ud37c\ube14\ub9ad \uac00\ub77c\uc624\ucf00\uc640 \uca5c\uc624\uc758 \uc7a5\uc810\uc744 \uacb0\ud569\ud55c \uc2a4\ud14c\uc774\ub9cc\uc758 \ub3c5\ud2b9\ud55c \uc2dc\uc2a4\ud15c\uc73c\ub85c, \uc790\uc720\ub86d\uace0 \uc990\uac70\uc6b4 \uc220\uc790\ub9ac\ub97c \uacbd\ud5d8\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c \ub290\ub084 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uacbd\ud5d8<\/h2>\n\n\n\n<p>\uca5c\uc624 \uc2a4\ud14c\uc774\ub294 \uac15\ub0a8\uc5d0\uc11c\ub9cc \ub9cc\ub0a0 \uc218 \uc788\ub294 \ud488\uaca9 \uc788\uace0 \ud2b9\ubcc4\ud55c \uacf5\uac04\uc785\ub2c8\ub2e4. \uc138\ub828\ub41c \ubd84\uc704\uae30\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub85c \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \ube44\uc988\ub2c8\uc2a4 \uc811\ub300\ub294 \ubb3c\ub860, \uc0ac\uc801\uc778 \ubaa8\uc784\uc5d0\uc11c\ub3c4 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc120\ud0dd\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h3 class=\"wp-block-heading\">\ubb38\uc758 \ubc0f \uc608\uc57d<\/h3>\n\n\n\n<ul class=\"wp-block-list\">\n<li>\uc6b4\uc601\uc2dc\uac04: <strong>\uc77c\uc694\uc77c \ubc0f \uacf5\ud734\uc77c \ud734\ubb34<\/strong><\/li>\n\n\n\n<li>\uc608\uc57d \ubc0f \ubb38\uc758: <strong>\uc804\ud654 \ubb38\uc758<\/strong><\/li>\n<\/ul>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uc2a4\ud14c\uc774\ub294 \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub354\uc6b1 \uac00\uce58 \uc788\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9ac\uae30 \uc704\ud574 \ud56d\uc0c1 \ub178\ub825\ud569\ub2c8\ub2e4. \uc9c0\uae08 \ubc14\ub85c \uc608\uc57d\ud558\uc2dc\uace0, \uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc990\uaca8\ubcf4\uc138\uc694!<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \uca5c\uc624 \uc2a4\ud14c\uc774\ub294 \ucc28\ubd84\ud558\uace0 \uc138\ub828\ub41c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac\ub97c \uc990\uae38 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uacf5\uac04\uc785\ub2c8\ub2e4. <\/p>\n","protected":false},"featured_media":5667,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[29],"class_list":["post-5526","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-dot5"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5526","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5667"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5526"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5526"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}