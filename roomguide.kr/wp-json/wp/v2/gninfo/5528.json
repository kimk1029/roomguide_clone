{"id":5528,"date":"2025-01-06T20:16:00","date_gmt":"2025-01-06T11:16:00","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%eb%8d%94%ea%b8%80%eb%a1%9c%eb%a6%ac\/"},"modified":"2025-03-26T12:41:55","modified_gmt":"2025-03-26T03:41:55","slug":"theglory","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/theglory\/","title":{"rendered":"\ub354\uae00\ub85c\ub9ac"},"content":{"rendered":"\n<h2 class=\"wp-block-heading\">\uac15\ub0a8 \uca5c\uc624 &#8220;\ub354\uae00\ub85c\ub9ac&#8221; &#8211; \uace0\uae09\uc2a4\ub7ec\uc6c0\uacfc \uc990\uac70\uc6c0\uc758 \uc644\ubcbd\ud55c \uc870\ud654<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\uc640 \ud3b8\uc548\ud55c \ud658\uacbd\uc744 \uc790\ub791\ud558\ub294 \uc220\uc790\ub9ac \uacf5\uac04\uc785\ub2c8\ub2e4. \ub113\uace0 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \ud568\uaed8 \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4\uac00 \uc81c\uacf5\ub418\uba70, \uace0\uac1d\ub2d8\uaed8\uc11c \ud2b9\ubcc4\ud55c \uc2dc\uac04\uacfc \ud568\uaed8 \uc990\uae38 \uc218 \uc788\ub3c4\ub85d \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \uae30\ub150\ud558\uace0 \uc2f6\uc740 \ubd84\ub4e4\uc5d0\uac8c \ucd5c\uc801\uc758 \uc120\ud0dd\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4. &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \uadf8 \uc774\ub984\ucc98\ub7fc, \uace0\uac1d\ub2d8\uaed8 \ud654\ub824\ud558\uace0 \uae30\uc5b5\uc5d0 \ub0a8\ub294 \uacbd\ud5d8\uc744 \uc120\uc0ac\ud560 \uc900\ube44\uac00 \ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uace0\uac1d\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uacf5\uac04<\/h2>\n\n\n\n<p>&#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \ube44\uc988\ub2c8\uc2a4 \uc190\ub2d8\uc740 \ubb3c\ub860, \uc0dd\uc77c \ud30c\ud2f0, \uce5c\uad6c \ubaa8\uc784, \ud2b9\ubcc4\ud55c \uae30\ub150\uc77c\uc744 \uc704\ud55c \ubaa8\uc784\uc5d0\ub3c4 \uc644\ubcbd\ud558\uac8c \uc5b4\uc6b8\ub9ac\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \ub2e4\uc591\ud55c \uace0\uac1d\uce35\uc758 \uc694\uad6c\ub97c \ucda9\uc871\uc2dc\ud0a4\uae30 \uc704\ud574 \uc138\uc2ec\ud558\uac8c \uc900\ube44\ub41c \uacf5\uac04\uc5d0\uc11c, \ud3b8\uc548\ud558\uace0 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \uc778\uae30 \uc788\ub294 \uc7a5\uc18c\ub85c, \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ud2b9\ubcc4\ud558\uac8c \uae30\ub150\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub0a8\ub140 \uad6c\ubd84 \uc5c6\uc774 \ubaa8\ub4e0 \uace0\uac1d\ub2d8\uc774 \ud3b8\uc548\ud558\uace0 \uc790\uc720\ub86d\uac8c \ubc29\ubb38\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<p>&#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uc5ec, \uace0\uac1d\ub2d8\uaed8 \ubcf4\ub2e4 \ud3b8\ub9ac\ud558\uace0 \uc5ec\uc720\ub85c\uc6b4 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubbf8\ub9ac \uc608\uc57d\ud558\uc2dc\uba74 \ub9ac\ubb34\uc9c4\uc744 \ud1b5\ud574 \ud3b8\uc548\ud558\uac8c \uc774\ub3d9\ud558\uc2e4 \uc218 \uc788\uc73c\uba70, \ubc1c\ub81b\ud30c\ud0b9 \uc11c\ube44\uc2a4 \ub355\ubd84\uc5d0 \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \ubc14\ub85c \uc785\uc7a5\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub610\ud55c, \ud2b9\ubcc4\ud55c \ubd84\uc704\uae30\ub97c \uc704\ud574 \uc544\ud2f0\uc2a4\ud2b8\ub098 DJ \uc12d\uc678\ub3c4 \uac00\ub2a5\ud558\uba70 (\ubcc4\ub3c4\uc758 \ube44\uc6a9 \ubc1c\uc0dd), \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ucd98 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ucd5c\uace0\uae09 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\ub294 \uc804\ubb38 \uc9c1\uc6d0\ub4e4<\/h2>\n\n\n\n<p>&#8220;\ub354\uae00\ub85c\ub9ac&#8221;\uc5d0\uc11c\ub294 \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\ub294 \uc804\ubb38 \uc9c1\uc6d0\ub4e4\uc774 \uace0\uac1d\ub2d8\uc744 \ub9de\uc774\ud569\ub2c8\ub2e4. \ucca0\uc800\ud55c \uad50\uc721\uc744 \ubc1b\uc740 \uc544\uac00\uc528\ub4e4\uc774 \uace0\uac1d\ub2d8\uc744 \ubc30\ub824\ud558\uba70, \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \ud3b8\uc548\ud558\uace0 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub3c4\ub85d \ub3d5\uc2b5\ub2c8\ub2e4. &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \uace0\uac1d\ub2d8\uc758 \ub9cc\uc871\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud558\uba70, \ud3b8\uc548\ud55c \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub294 \uace0\uac1d\ub2d8\uaed8 \ucd5c\uc0c1\uc758 \ub9cc\uc871\uc744 \ub4dc\ub9b4 \uc218 \uc788\ub3c4\ub85d \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\uc758 \uc644\ubcbd\ud55c \uade0\ud615<\/h2>\n\n\n\n<p>\ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uacfc \uc811\ub300\ub294 \uc911\uc694\ud55c \uad00\uacc4\ub97c \ub9fa\uace0 \uc788\uc2b5\ub2c8\ub2e4. &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4\uc640 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4\ub85c \ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\ub97c \uc644\ubcbd\ud558\uac8c \uc870\ud654\uc2dc\ucf1c, \uace0\uac1d\ub2d8\uc758 \ube44\uc988\ub2c8\uc2a4 \uc131\uacf5\uc744 \ub3d5\uc2b5\ub2c8\ub2e4. \uc911\uc694\ud55c \ud68c\uc758\ub098 \uc811\ub300\uac00 \uc6d0\ud65c\ud558\uac8c \uc774\ub8e8\uc5b4\uc9c8 \uc218 \uc788\ub3c4\ub85d \ucd5c\uc801\uc758 \ud658\uacbd\uc744 \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uc774 \ud3b8\uc548\ud558\uac8c \ub300\ud654\ub97c \ub098\ub204\uace0 \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \ubc30\ub824\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uc815\uc9c1\ud55c \uac00\uaca9, \ud22c\uba85\ud55c \uc6b4\uc601<\/h2>\n\n\n\n<p>&#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \uc815\uc9c1\ud55c \uac00\uaca9 \uc815\ucc45\uacfc \ud22c\uba85\ud55c \uc6b4\uc601\uc744 \ud1b5\ud574 \uace0\uac1d\ub2d8\uaed8 \ubbff\uc744 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc8fc\ub300\uc640 \uad00\ub828\ub41c \ubaa8\ub4e0 \uc0ac\ud56d\uc740 \uc0ac\uc804\uc5d0 \uba85\ud655\ud558\uac8c \uc548\ub0b4\ub4dc\ub9ac\uba70, \ucd94\uac00 \ube44\uc6a9 \uc5c6\uc774 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uc73c\ub85c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc774 \ubd88\ud544\uc694\ud55c \uac71\uc815 \uc5c6\uc774 \ud3b8\uc548\ud558\uac8c \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d, \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub97c \ud22c\uba85\ud558\uac8c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\ub2d8\uacfc\uc758 \uc2e0\ub8b0\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uad00\uacc4<\/h2>\n\n\n\n<p>&#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \uace0\uac1d\ub2d8\uacfc\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud558\uba70, \ud55c \ubc88 \ubc29\ubb38\ud558\uc2e0 \uace0\uac1d\ub2d8\uc740 \ub300\ubd80\ubd84 \ub2e8\uace8\uc774 \ub418\uc5b4 \ub2e4\uc2dc \ucc3e\uc544\uc635\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8\uc11c\ub294 \ud56d\uc0c1 \uc815\ud655\ud558\uace0 \uc2e0\ub8b0\ud560 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \ubc1b\uc73c\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc544\uac00\uc528 \uc22b\uc790\ub098 \ub300\uae30 \uc2dc\uac04\uc5d0 \ub300\ud574\uc11c\ub3c4 \uacfc\uc7a5 \uc5c6\uc774 \uc815\ud655\ud558\uac8c \uc548\ub0b4\ub4dc\ub9ac\uba70, \uace0\uac1d\ub2d8\uc758 \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \ub9e4\ub825\uc801\uc778 \uc544\uac00\uc528\ub4e4<\/h2>\n\n\n\n<p>&#8220;\ub354\uae00\ub85c\ub9ac&#8221;\uc5d0\ub294 \ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc744 \uac00\uc9c4 \ub9e4\ub825\uc801\uc778 \uc544\uac00\uc528\ub4e4\uc774 \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uc790\uc2e0\uc774 \uc120\ud638\ud558\ub294 \uc2a4\ud0c0\uc77c\uc758 \uc544\uac00\uc528\ub97c \uc120\ud0dd\ud560 \uc218 \uc788\uc73c\uba70, \uae4c\ub2e4\ub85c\uc6b4 \uae30\uc900\uc744 \ud1b5\ud574 \uc120\ubcc4\ub41c \uc544\uac00\uc528\ub4e4\uc740 \ubbf8\ubaa8\uc640 \ub9c8\uc778\ub4dc \ubaa8\ub450\uc5d0\uc11c \uc218\uc900 \ub192\uc740 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc544\uac00\uc528\ub97c \uc120\ud0dd\ud558\uc154\uc11c \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc990\uac70\uc6b4 \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>&#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \ud3b8\uc548\ud558\uac8c \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \ucca0\uc800\ud558\uac8c \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uc744 \uc790\ub791\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc740 \uc990\uac70\uc6b4 \uc220\uc790\ub9ac\uc5d0\uc11c \uac71\uc815 \uc5c6\uc774 \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc2e4 \uc218 \uc788\uc73c\uba70, \uc11c\ube44\uc2a4\uc640 \uc8fc\ub300 \ubaa8\ub450\uc5d0\uc11c \uc138\uc2ec\ud55c \ubc30\ub824\uac00 \uc774\ub8e8\uc5b4\uc9d1\ub2c8\ub2e4. &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \uace0\uac1d\ub2d8\uaed8 \ucd5c\uace0\uc758 \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc81c\uacf5\ud560 \uc218 \uc788\ub3c4\ub85d \ud56d\uc0c1 \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uca5c\uc624 &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub9cc\uc758 \ud2b9\ubcc4\ud55c \ub9e4\ub825<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \ub2e4\ub978 \uacf3\uacfc \ucc28\ubcc4\ud654\ub41c \ubd84\uc704\uae30\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc544\uac00\uc528\ub4e4\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \uc790\uc720\ub86d\uace0 \ud3b8\uc548\ud55c \ubd84\uc704\uae30\uc5d0\uc11c \uc220\uacfc \ub178\ub798\ub97c \ub9c8\uc74c\uaecf \uc990\uae30\uba70, \ud130\uce58\uc758 \uc790\uc720\ub85c\uc6c0\ub3c4 \uc81c\uacf5\ub429\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8\uc11c \ud3b8\uc548\ud558\uac8c \uc220\uc790\ub9ac\ub97c \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \uc218\uc704\uc640 \uc2a4\ud0c0\uc77c\uc5d0 \ub9de\ucdb0 \ub2e4\uc591\ud55c \uc120\ud0dd\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4. &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \ub2e4\ub978 \uacf3\uacfc \ube44\uad50\ud560 \uc218 \uc5c6\ub294 \ud2b9\ubcc4\ud55c \ub9e4\ub825\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ucd5c\uc6b0\uc120<\/h2>\n\n\n\n<p>&#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub294 \ud22c\uba85\ud558\uace0 \uc815\ud655\ud558\uac8c \uc81c\uacf5\ub418\uba70, \uace0\uac1d\ub2d8\uc774 \ubd88\ud3b8\ud568 \uc5c6\uc774 \uc990\uae30\uc2e4 \uc218 \uc788\ub3c4\ub85d \uc138\uc2ec\ud558\uac8c \uad00\ub9ac\ub429\ub2c8\ub2e4. \uac15\ub0a8 \uca5c\uc624 &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \ub204\ub9ac\uc2dc\uace0, \ud56d\uc0c1 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc11c\ube44\uc2a4\ub97c \ubc1b\uc73c\uc2e4 \uc218 \uc788\ub3c4\ub85d \ub3d5\uaca0\uc2b5\ub2c8\ub2e4. \uc5b8\uc81c\ub4e0\uc9c0 \uad81\uae08\ud55c \uc0ac\ud56d\uc740 \ubb38\uc758\ud574 \uc8fc\uc138\uc694.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \uca5c\uc624 &#8220;\ub354\uae00\ub85c\ub9ac&#8221;\ub294 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\uc640 \ud3b8\uc548\ud55c \ud658\uacbd\uc744 \uc790\ub791\ud558\ub294 \uc220\uc790\ub9ac \uacf5\uac04\uc785\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":5561,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[29],"class_list":["post-5528","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-dot5"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5528","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5561"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5528"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5528"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}