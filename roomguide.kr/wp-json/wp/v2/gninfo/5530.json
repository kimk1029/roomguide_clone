{"id":5530,"date":"2025-01-06T20:16:00","date_gmt":"2025-01-06T11:16:00","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%95%8c%ed%8c%8c%eb%b2%b3\/"},"modified":"2025-03-26T12:48:40","modified_gmt":"2025-03-26T03:48:40","slug":"alphabet","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/alphabet\/","title":{"rendered":"\uc54c\ud30c\ubcb3"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \uca5c\uc624 \uc54c\ud30c\ubcb3 \u2013 \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \uc704\ud55c \uc0c8\ub85c\uc6b4 \uae30\uc900<\/h3>\n\n\n\n<p>\uac15\ub0a8 <strong>\uca5c\uc624 \uc54c\ud30c\ubcb3<\/strong>\uc740 \uace0\uae09\uc2a4\ub7fd\uace0 \uc138\ub828\ub41c \uacf5\uac04\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac\ub97c \uc990\uae38 \uc218 \uc788\ub294 \ucd5c\uc801\uc758 \uc7a5\uc18c\uc785\ub2c8\ub2e4. \ubaa8\ub358\ud55c \uc778\ud14c\ub9ac\uc5b4\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4, \uac15\ub0a8 \uc911\uc2ec\ubd80\uc758 \ucd5c\uc801\uc758 \uc704\uce58\ub85c \uace0\uac1d\ub2d8\uc758 \ubaa8\ub4e0 \uae30\ub300\ub97c \ucda9\uc871\uc2dc\ud0b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc54c\ud30c\ubcb3\uc758 \ud2b9\ubcc4\ud55c \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uac10\uac01\uc801\uc778 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc54c\ud30c\ubcb3\uc740 \ubaa8\ub358\ud558\uace0 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4\ub85c \ud488\uaca9 \uc788\ub294 \ubd84\uc704\uae30\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc220\uc790\ub9ac\ubfd0\ub9cc \uc544\ub2c8\ub77c \ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \uae30\ub150\uc77c, \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \ub2e4\uc591\ud55c \uc0c1\ud669\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud55c \ucd5c\uc801\uc758 \uacf5\uac04<\/h3>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uc54c\ud30c\ubcb3\uc740 \uac15\ub0a8 \ud55c\ubcf5\ud310\uc5d0 \uc704\uce58\ud558\uc5ec \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub098\uba70, \uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ub113\uace0 \ucf8c\uc801\ud55c \uc2dc\uc124\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub204\uad6c\uc640 \ud568\uaed8\ud574\ub3c4 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc774 \ubcf4\uc7a5\ub429\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ubaa8\ub4e0 \uace0\uac1d\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc54c\ud30c\ubcb3\uc740 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300\ubd80\ud130 \uc18c\uaddc\ubaa8 \ubaa8\uc784, \uc0dd\uc77c \ud30c\ud2f0 \ub4f1 \ubaa8\ub4e0 \uace0\uac1d\ub2d8\uc758 \ubaa9\uc801\uc5d0 \ub9de\ub294 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub0a8\ub140 \ub3d9\ubc18 \ubc29\ubb38\ub3c4 \uac00\ub2a5\ud574 \ub354\uc6b1 \ud3ed\ub113\uc740 \uc120\ud0dd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d \uc911\uc2ec\uc758 \ud3b8\ub9ac\ud558\uace0 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc54c\ud30c\ubcb3\uc740 \uace0\uac1d\ub2d8\uc758 \ud3b8\uc548\ud55c \ubc29\ubb38\uc744 \uc704\ud574 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \uc785\uc7a5\ud560 \uc218 \uc788\uc73c\uba70, \uc774\ub3d9 \uc911\uc5d0\ub3c4 \ud488\uaca9\uc744 \ub290\ub07c\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9de\ucda4\ud615 \uc774\ubca4\ud2b8 \uc9c0\uc6d0<\/h3>\n\n\n\n<p>\ud2b9\ubcc4\ud55c \ub0a0\uc744 \uc704\ud574 DJ\uc640 \uc2f1\uc5b4 \uc12d\uc678 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. (\ubcc4\ub3c4 \ube44\uc6a9 \ubc1c\uc0dd) \uace0\uac1d\ub2d8\uc758 \uc694\uccad\uc5d0 \ub530\ub77c \uc644\ubcbd\ud55c \uc774\ubca4\ud2b8\ub97c \ub9cc\ub4e4\uc5b4 \ub354\uc6b1 \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ubcf4\uc7a5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uc5c6\ub294 \uc548\uc804\ud55c \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>\uc54c\ud30c\ubcb3\uc740 \ucca0\uc800\ud788 \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uacfc \uccb4\uacc4\uc801\uc778 \uad50\uc721\uc744 \ubc1b\uc740 \uc2a4\ud0dc\ud504\ub97c \ud1b5\ud574 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc548\uc804\ud558\uace0 \ud3b8\uc548\ud55c \uc220\uc790\ub9ac\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ub9cc\uc871\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud558\uba70, \ud56d\uc0c1 \ub192\uc740 \uc218\uc900\uc758 \uc11c\ube44\uc2a4\ub97c \uc720\uc9c0\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud569\ub9ac\uc801\uc778 \uac00\uaca9\uacfc \ud22c\uba85\ud55c \uc6b4\uc601<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\uc815\ucc30\uc81c \uac00\uaca9 \uc6b4\uc601<\/h3>\n\n\n\n<p>\uc54c\ud30c\ubcb3\uc740 \ud22c\uba85\ud55c \uc815\ucc30\uc81c \uc6b4\uc601\uc73c\ub85c, \uace0\uac1d\ub2d8\uaed8 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uacfc \uc2e0\ub8b0\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uc548\ub0b4\ub418\uba70, \ucd94\uac00 \uc694\uae08 \uac71\uc815 \uc5c6\uc774 \ud3b8\uc548\ud55c \uc774\uc6a9\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uc2e0\ub8b0\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c<\/h3>\n\n\n\n<p>\uc54c\ud30c\ubcb3\uc740 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd9c\uadfc \ud604\ud669, \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0 \ub4f1\uc744 \uba85\ud655\ud788 \uc548\ub0b4\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\uc640\uc758 \ud2b9\ubcc4\ud55c \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108<\/h3>\n\n\n\n<p>\uc54c\ud30c\ubcb3\uc5d0\uc11c\ub294 \uc5c4\uaca9\ud55c \uae30\uc900\uc73c\ub85c \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc774\uace0 \ud488\uaca9 \uc788\ub294 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \ud30c\ud2b8\ub108\ub97c \uc120\ud0dd\ud558\uc5ec \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uca5c\uc624\ub9cc\uc758 \ucc28\ubcc4\ud654\ub41c \uacbd\ud5d8<\/h3>\n\n\n\n<p>\uc54c\ud30c\ubcb3\uc740 \uca5c\uc624 \ud2b9\uc720\uc758 \uc790\uc5f0\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\uc640 \uace0\uae09\uc2a4\ub7ec\uc6c0\uc744 \uacb0\ud569\ud558\uc5ec \uc220\uc790\ub9ac\uc758 \ud488\uaca9\uc744 \ud55c\uce35 \ub192\uc785\ub2c8\ub2e4. \ub204\uad6c\uc640 \ud568\uaed8\ud574\ub3c4 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c \ub290\ub084 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uc21c\uac04<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uc54c\ud30c\ubcb3\uc740 \uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ub3c5\ud2b9\ud55c \ub9e4\ub825\uacfc \ud2b9\ubcc4\ud568\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uae09\uc2a4\ub7ec\uc6b4 \uacf5\uac04\uacfc \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub85c \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \uc21c\uac04\uc744 \uc120\uc0ac\ud558\uba70, \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4e4\uc5b4\ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \uca5c\uc624 \uc54c\ud30c\ubcb3\uc740 \uac15\ub0a8 \ud55c\ubcf5\ud310\uc5d0 \uc704\uce58\ud558\uc5ec \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub098\uba70, \uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ub113\uace0 \ucf8c\uc801\ud55c \uc2dc\uc124\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. <\/p>\n","protected":false},"featured_media":5549,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[29],"class_list":["post-5530","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-dot5"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5530","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5549"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5530"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5530"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}