{"id":5531,"date":"2025-01-06T20:16:00","date_gmt":"2025-01-06T11:16:00","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%8d%b8%eb%8d%b0%ec%9d%b4\/"},"modified":"2025-03-26T12:48:13","modified_gmt":"2025-03-26T03:48:13","slug":"someday","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/someday\/","title":{"rendered":"\uc378\ub370\uc774"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \uca5c\uc624 \uc378\ub370\uc774 \u2013 \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \uc704\ud55c \uc644\ubcbd\ud55c \uc120\ud0dd<\/h3>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 <strong>\uc378\ub370\uc774<\/strong>\ub294 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub85c \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac\ub97c \uc81c\uacf5\ud558\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uacfc \uac15\ub0a8 \uc911\uc2ec\uc5d0\uc11c\uc758 \ud0c1\uc6d4\ud55c \uc811\uadfc\uc131\uc73c\ub85c \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc378\ub370\uc774\uc758 \ud2b9\ubcc4\ud55c \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \uac10\uac01\uc801\uc778 \uc778\ud14c\ub9ac\uc5b4\uc640 \ud3b8\uc548\ud55c \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc378\ub370\uc774\ub294 \ubaa8\ub358\ud55c \uac10\uac01\uacfc \uc138\ub828\ub41c \ubd84\uc704\uae30\ub85c \ubaa8\ub4e0 \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc744 \ub9cc\uc871\uc2dc\ud0b5\ub2c8\ub2e4. \ud3b8\uc548\ud558\uba74\uc11c\ub3c4 \ud488\uaca9 \uc788\ub294 \uacf5\uac04\uc5d0\uc11c \ube44\uc988\ub2c8\uc2a4\uc640 \uc0ac\uad50\uc758 \uc644\ubcbd\ud55c \uade0\ud615\uc744 \ub290\uaef4\ubcf4\uc138\uc694.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\uc758 \ucd5c\uc801\uc758 \uc785\uc9c0<\/h3>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uc378\ub370\uc774\ub294 \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud574 \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub098\uba70, \uac15\ub0a8\uc5d0\uc11c\ub3c4 \uc190\uaf3d\ud788\ub294 \ub300\uaddc\ubaa8 \uc2dc\uc124\uacfc \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\ub97c \uc790\ub791\ud569\ub2c8\ub2e4. \ud2b9\ubcc4\ud55c \uc790\ub9ac\ub098 \uc18c\uc911\ud55c \uc21c\uac04\uc744 \uc704\ud55c \ucd5c\uc801\uc758 \uc7a5\uc18c\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ub2e4\uc591\ud55c \uace0\uac1d\uce35\uc744 \uc704\ud55c \ub9de\ucda4 \uacf5\uac04<\/h3>\n\n\n\n<p>\ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \uc0dd\uc77c \ud30c\ud2f0, \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \uc5b4\ub5a4 \ubaa9\uc801\uc5d0\ub3c4 \uc801\ud569\ud55c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub0a8\ub140 \ub3d9\ubc18 \ubc29\ubb38\ub3c4 \uac00\ub2a5\ud558\uba70, \ub204\uad6c\uc640 \ud568\uaed8\ud574\ub3c4 \ub9cc\uc871\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\uc744 \uc704\ud55c \uc644\ubcbd\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ud504\ub77c\uc774\ube57 \ub9ac\ubb34\uc9c4 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc378\ub370\uc774\ub294 \uace0\uac1d\ub2d8\uc758 \ud3b8\uc758\ub97c \uc704\ud574 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubcf5\uc7a1\ud55c \ub3c4\uc2ec\uc5d0\uc11c\ub3c4 \ud3b8\ub9ac\ud558\uac8c \ubc29\ubb38\ud560 \uc218 \uc788\uc73c\uba70, \uc774\ub3d9 \uacfc\uc815\uc5d0\uc11c\ub3c4 \ud488\uaca9\uc744 \ub290\ub07c\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9de\ucda4\ud615 \uc774\ubca4\ud2b8 \uc9c0\uc6d0<\/h3>\n\n\n\n<p>\uace0\uac1d\ub2d8\uc758 \ud2b9\ubcc4\ud55c \ub0a0\uc744 \uc704\ud574 DJ, \uc2f1\uc5b4 \uc12d\uc678 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. (\ubcc4\ub3c4 \ube44\uc6a9 \ubc1c\uc0dd) \ub9de\ucda4\ud615 \uc774\ubca4\ud2b8\ub85c \uc78a\uc9c0 \ubabb\ud560 \ucd94\uc5b5\uc744 \ub9cc\ub4e4\uc5b4\ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uc5c6\ub294 \uc548\uc804\ud55c \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>\uc378\ub370\uc774\ub294 \uace0\uac1d\ub2d8\uaed8 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc220\uc790\ub9ac \ubb38\ud654\ub97c \uc57d\uc18d\ub4dc\ub9bd\ub2c8\ub2e4. \ucca0\uc800\ud788 \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uacfc \uccb4\uacc4\uc801\uc778 \uad50\uc721\uc744 \ubc1b\uc740 \uc2a4\ud0dc\ud504\ub97c \ud1b5\ud574, \uc5b8\uc81c\ub098 \ud3b8\uc548\ud558\uace0 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud569\ub9ac\uc801\uc778 \uac00\uaca9\uacfc \uc2e0\ub8b0 \uacbd\uc601<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ud22c\uba85\ud55c \uc815\ucc30\uc81c \uac00\uaca9<\/h3>\n\n\n\n<p>\uc378\ub370\uc774\ub294 \uac70\ud488 \uc5c6\ub294 \uac00\uaca9 \uc815\ucc45\uc744 \ud1b5\ud574 \uace0\uac1d\ub2d8\uaed8 \ud569\ub9ac\uc801\uc778 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uc548\ub0b4\ub418\uba70, \ubd88\ud544\uc694\ud55c \ucd94\uac00 \uc694\uae08 \uc5c6\uc774 \ud3b8\uc548\ud558\uac8c \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc2e0\ub8b0\ub97c \uc6b0\uc120\uc73c\ub85c<\/h3>\n\n\n\n<p>\uc378\ub370\uc774\ub294 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd9c\uadfc \ud604\ud669, \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0 \ub4f1\uc744 \uc815\ud655\ud788 \uc548\ub0b4\ud558\uc5ec \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ub178\ub825\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\uc640 \ud2b9\ubcc4\ud55c \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108<\/h3>\n\n\n\n<p>\uc378\ub370\uc774\uc5d0\uc11c\ub294 \uae4c\ub2e4\ub86d\uac8c \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \ud30c\ud2b8\ub108\ub97c \uc120\ud0dd\ud558\uc5ec \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \ub9cc\ub4e4\uc5b4\ubcf4\uc138\uc694.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uca5c\uc624\ub9cc\uc758 \uc790\uc5f0\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc378\ub370\uc774\ub294 \uca5c\uc624 \ud2b9\uc720\uc758 \ud3b8\uc548\ud558\uba74\uc11c\ub3c4 \ud488\uaca9 \uc788\ub294 \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \uc790\uc720\ub86d\uace0 \uc990\uac70\uc6b4 \uc220\uc790\ub9ac\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ube44\uc988\ub2c8\uc2a4\uc640 \uc0ac\uad50, \ubaa8\ub450\ub97c \ub9cc\uc871\uc2dc\ud0ac \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uacf5\uac04\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c \ub290\ub084 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uacbd\ud5d8<\/h2>\n\n\n\n<p>\uc378\ub370\uc774\ub294 \uac15\ub0a8\uc5d0\uc11c\ub9cc \ub204\ub9b4 \uc218 \uc788\ub294 \ub3c5\ud2b9\ud55c \ub9e4\ub825\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub85c \uace0\uac1d\ub2d8\uaed8 \ucd5c\uc0c1\uc758 \ub9cc\uc871\uc744 \uc120\uc0ac\ud558\uba70, \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4e4\uc5b4\ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h3 class=\"wp-block-heading\">\ubb38\uc758 \ubc0f \uc608\uc57d<\/h3>\n\n\n\n<ul class=\"wp-block-list\">\n<li>\uc6b4\uc601\uc2dc\uac04: <strong>\uc77c\uc694\uc77c \ubc0f \uacf5\ud734\uc77c \ud734\ubb34<\/strong><\/li>\n\n\n\n<li>\uc608\uc57d \ubc0f \ubb38\uc758: <strong>\uc804\ud654 \ubb38\uc758<\/strong><\/li>\n<\/ul>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uc378\ub370\uc774\ub294 \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub354\uc6b1 \uac00\uce58 \uc788\uac8c \ub9cc\ub4e4\uc5b4\ub4dc\ub9ac\uae30 \uc704\ud574 \ud56d\uc0c1 \ub178\ub825\ud569\ub2c8\ub2e4. \uc9c0\uae08 \ubc14\ub85c \uc608\uc57d\ud558\uc2dc\uace0, \uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc990\uaca8\ubcf4\uc138\uc694!<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \uca5c\uc624 \uc378\ub370\uc774\ub294 \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud574 \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub098\uba70, \uac15\ub0a8\uc5d0\uc11c\ub3c4 \uc190\uaf3d\ud788\ub294 \ub300\uaddc\ubaa8 \uc2dc\uc124\uacfc \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\ub97c \uc790\ub791\ud569\ub2c8\ub2e4. <\/p>\n","protected":false},"featured_media":5591,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[29],"class_list":["post-5531","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-dot5"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5531","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5591"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5531"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5531"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}