{"id":5518,"date":"2025-01-06T20:15:59","date_gmt":"2025-01-06T11:15:59","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%9d%b8%ed%8a%b8%eb%a1%9c\/"},"modified":"2025-03-26T12:51:22","modified_gmt":"2025-03-26T03:51:22","slug":"intro","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/intro\/","title":{"rendered":"\uc778\ud2b8\ub85c"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \uca5c\uc624 \uc778\ud2b8\ub85c \u2013 \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc758 \uc2dc\uc791<\/h3>\n\n\n\n<p>\uac15\ub0a8 <strong>\uca5c\uc624 \uc778\ud2b8\ub85c<\/strong>\ub294 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub85c \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac\ub97c \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \ube44\uc988\ub2c8\uc2a4 \uc811\ub300\ubd80\ud130 \uc0ac\uad50 \ubaa8\uc784, \uae30\ub150\uc77c \ud30c\ud2f0\uae4c\uc9c0, \ub2e4\uc591\ud55c \ubaa9\uc801\uc5d0 \ub9de\ucd98 \ucd5c\uc801\uc758 \uacf5\uac04\uc73c\ub85c \uc124\uacc4\ub41c \uc778\ud2b8\ub85c\ub294 \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0\uc11c \ud2b9\ubcc4\ud568\uc758 \uc0c8\ub85c\uc6b4 \uae30\uc900\uc744 \uc81c\uc2dc\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc778\ud2b8\ub85c\ub9cc\uc758 \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \uac10\uac01\uc801\uc778 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc778\ud2b8\ub85c\ub294 \uace0\uae09\uc2a4\ub7ec\uc6c0\uacfc \ud2b8\ub80c\ub4dc\ub97c \uacb0\ud569\ud55c \uac10\uac01\uc801\uc778 \uc778\ud14c\ub9ac\uc5b4\ub97c \uc790\ub791\ud569\ub2c8\ub2e4. \uae54\ub054\ud558\uace0 \uc138\uc2ec\ud558\uac8c \uc124\uacc4\ub41c \ub8f8\uc740 \ud3b8\uc548\ud568\uacfc \ud488\uaca9\uc744 \ub3d9\uc2dc\uc5d0 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uc744 \uc704\ud55c \ucc28\ubd84\ud55c \uacf5\uac04\ubd80\ud130 \uc0ac\uad50 \ubaa8\uc784\uc5d0 \uc801\ud569\ud55c \uc5ec\uc720\ub85c\uc6b4 \ud658\uacbd\uae4c\uc9c0, \ubaa8\ub4e0 \ub9cc\ub0a8\uc744 \ud2b9\ubcc4\ud55c \ucd94\uc5b5\uc73c\ub85c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\uc758 \ucd5c\uc801\uc758 \uc704\uce58<\/h3>\n\n\n\n<p>\uc778\ud2b8\ub85c\ub294 \uac15\ub0a8\uc758 \uc911\uc2ec\ubd80\uc5d0 \uc790\ub9ac \uc7a1\uc544 \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub098\uba70, \uc774\ub3d9\uc774 \ud3b8\ub9ac\ud569\ub2c8\ub2e4. \ud654\ub824\ud55c \ub3c4\uc2ec \uc18d\uc5d0\uc11c\ub3c4 \ucc28\ubcc4\ud654\ub41c \ubd84\uc704\uae30\ub97c \ub290\ub084 \uc218 \uc788\ub294 \uc774\uacf3\uc740 \uac15\ub0a8\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ubcf4\ub0b4\uae30\uc5d0 \uc644\ubcbd\ud55c \uc7a5\uc18c\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ub2e4\uc591\ud55c \ubaa9\uc801\uc5d0 \ub9de\ucd98 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \uce5c\ubaa9 \ubaa8\uc784, \uc0dd\uc77c \ud30c\ud2f0, \ud639\uc740 \ud2b9\ubcc4\ud55c \ub0a0\uc758 \uae30\ub150\uae4c\uc9c0, \uc778\ud2b8\ub85c\ub294 \uace0\uac1d\ub2d8\uc758 \ub2e4\uc591\ud55c \uc694\uad6c\ub97c \ub9cc\uc871\uc2dc\ud0ac \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub204\uad6c\uc640 \ud568\uaed8\ud558\ub354\ub77c\ub3c4 \uae30\ub300 \uc774\uc0c1\uc758 \ub9cc\uc871\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub514\ud14c\uc77c\uc774 \ub3cb\ubcf4\uc774\ub294 \uace0\uac1d \uc911\uc2ec\uc758 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ud504\ub77c\uc774\ube57 \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc778\ud2b8\ub85c\ub294 \uace0\uac1d\ub2d8\uc758 \ud3b8\ub9ac\ud55c \ubc29\ubb38\uc744 \uc704\ud574 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubcf5\uc7a1\ud55c \uc774\ub3d9 \uacfc\uc815\uc5d0\uc11c\ub3c4 \ud3b8\uc548\ud568\uacfc \ud488\uaca9\uc744 \ub290\ub084 \uc218 \uc788\ub3c4\ub85d \uc138\uc2ec\ud558\uac8c \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9de\ucda4\ud615 \uc774\ubca4\ud2b8 \uc9c0\uc6d0<\/h3>\n\n\n\n<p>\ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ub3cb\ubcf4\uc774\uac8c \ub9cc\ub4e4\uace0 \uc2f6\uc73c\uc2e0\uac00\uc694? \uc778\ud2b8\ub85c\ub294 DJ\uc640 \uc544\ud2f0\uc2a4\ud2b8 \uc12d\uc678(\ubcc4\ub3c4 \uc694\uccad \uac00\ub2a5)\ub97c \ud1b5\ud574 \uace0\uac1d\ub2d8\ub9cc\uc758 \ub3c5\ud2b9\ud55c \uc774\ubca4\ud2b8\ub97c \uc5f0\ucd9c\ud574 \ub4dc\ub9bd\ub2c8\ub2e4. \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\uac00 \uc544\ub2cc \uae30\uc5b5\uc5d0 \ub0a8\ub294 \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc548\uc804\ud55c \ud658\uacbd<\/h2>\n\n\n\n<p>\uc778\ud2b8\ub85c\ub294 \uccb4\uacc4\uc801\uc73c\ub85c \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uacfc \uad50\uc721\ubc1b\uc740 \uc804\ubb38 \uc2a4\ud0dc\ud504\ub97c \ud1b5\ud574, \ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \ucf8c\uc801\ud55c \uc220\uc790\ub9ac \ud658\uacbd\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc138\ubd80 \uc0ac\ud56d\uc5d0 \uc138\uc2ec\ud788 \uc2e0\uacbd \uc368 \uace0\uac1d\ub2d8\uc758 \ub9cc\uc871\ub3c4\ub97c \ub192\uc774\uba70, \uc548\uc804\ud558\uace0 \ud3b8\uc548\ud55c \uc2dc\uac04\uc744 \ubcf4\uc7a5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud558\uace0 \ud569\ub9ac\uc801\uc778 \uc6b4\uc601 \ucca0\ud559<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\uc815\ucc30\uc81c\ub97c \ud1b5\ud55c \ud22c\uba85\ud55c \uac00\uaca9 \uc815\ucc45<\/h3>\n\n\n\n<p>\uc778\ud2b8\ub85c\ub294 \uac70\ud488 \uc5c6\ub294 \uc815\ucc30\uc81c \uc6b4\uc601\uc73c\ub85c \ud569\ub9ac\uc801\uc774\uace0 \ud22c\uba85\ud55c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uba85\ud655\ud788 \uc548\ub0b4\ub418\uba70, \ucd94\uac00 \uc694\uae08 \uc5c6\uc774 \ud488\uaca9 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \ub9c8\uc74c\uaecf \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc2e0\ub8b0\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c<\/h3>\n\n\n\n<p>\uc778\ud2b8\ub85c\ub294 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \ubb34\uc5c7\ubcf4\ub2e4 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0\uacfc \ucd9c\uadfc \ud604\ud669\uc744 \uc815\ud655\ud788 \uc548\ub0b4\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\uc640\uc758 \ud2b9\ubcc4\ud55c \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \ub9e4\ub825\uacfc \ud488\uaca9\uc744 \uc9c0\ub2cc \ud30c\ud2b8\ub108<\/h3>\n\n\n\n<p>\uc778\ud2b8\ub85c\ub294 \ucca0\uc800\ud55c \uae30\uc900\uc73c\ub85c \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc2a4\ud0c0\uc77c\uc758 \ud30c\ud2b8\ub108\ub97c \uc120\ud0dd\ud558\uc5ec, \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\uac00 \uc544\ub2cc \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uca5c\uc624\ub9cc\uc758 \ucc28\ubcc4\ud654\ub41c \uc790\uc720\ub85c\uc6b4 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc778\ud2b8\ub85c\ub294 \uca5c\uc624\uc758 \uace0\uae09\uc2a4\ub7ec\uc6c0\uacfc \ud37c\ube14\ub9ad\uc758 \uc790\uc720\ub85c\uc6b4 \ubd84\uc704\uae30\ub97c \uacb0\ud569\ud55c \ub3c5\ud2b9\ud55c \uc2dc\uc2a4\ud15c\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc220\uc790\ub9ac\uc758 \uc990\uac70\uc6c0\uc744 \ud488\uaca9 \uc788\uac8c \uc990\uae38 \uc218 \uc788\ub294 \uc774\uacf3\uc740 \ub204\uad6c\uc640 \ud568\uaed8\ud558\ub354\ub77c\ub3c4 \ub9cc\uc871\uc744 \ubcf4\uc7a5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c \uc2dc\uc791\ud558\ub294 \ud2b9\ubcc4\ud55c \uc21c\uac04<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uc778\ud2b8\ub85c\ub294 \uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ub3c5\ucc3d\uc801\uc774\uace0 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\uc640 \uc138\ub828\ub41c \uacf5\uac04\uc740 \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \ucd94\uc5b5\uc744 \uc120\uc0ac\ud558\uba70, \uc911\uc694\ud55c \ub0a0\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<br>\uc778\ud2b8\ub85c\uc5d0\uc11c\uc758 \uc220\uc790\ub9ac\ub294 \ub2e8\uc21c\ud55c \uc74c\uc8fc\ub97c \ub118\uc5b4 \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc774 \uc644\ubcbd\ud788 \uc870\ud654\ub97c \uc774\ub8e8\ub294 \uc2dc\uac04\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4. \uc9c0\uae08 \ubc14\ub85c \uc778\ud2b8\ub85c\uc5d0\uc11c \ud2b9\ubcc4\ud568\uc758 \uc2dc\uc791\uc744 \uacbd\ud5d8\ud574 \ubcf4\uc138\uc694!<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc778\ud2b8\ub85c\ub294 \uac70\ud488 \uc5c6\ub294 \uc815\ucc30\uc81c \uc6b4\uc601\uc73c\ub85c \ud569\ub9ac\uc801\uc774\uace0 \ud22c\uba85\ud55c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uba85\ud655\ud788 \uc548\ub0b4\ub418\uba70, \ucd94\uac00 \uc694\uae08 \uc5c6\uc774 \ud488\uaca9 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \ub9c8\uc74c\uaecf \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":5575,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[29],"class_list":["post-5518","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-dot5"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5518","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5575"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5518"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5518"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}