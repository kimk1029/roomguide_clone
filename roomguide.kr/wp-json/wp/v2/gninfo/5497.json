{"id":5497,"date":"2025-01-14T20:15:57","date_gmt":"2025-01-14T11:15:57","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%9c%a0%ec%95%a4%eb%af%b8\/"},"modified":"2025-01-16T19:51:07","modified_gmt":"2025-01-16T10:51:07","slug":"youandme","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/youandme\/","title":{"rendered":"\uc720\uc564\ubbf8"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad \uc720\uc564\ubbf8 \u2013 \ud2b9\ubcc4\ud55c \ub9cc\ub0a8\uc744 \uc704\ud55c \ucd5c\uc801\uc758 \uacf5\uac04<\/h3>\n\n\n\n<p>\uac15\ub0a8 <strong>\ud558\uc774\ud37c\ube14\ub9ad \uc720\uc564\ubbf8<\/strong>\ub294 \uc774\ub984\ucc98\ub7fc \ub2f9\uc2e0\uacfc \ub098, \uc6b0\ub9ac \ubaa8\ub450\ub97c \uc704\ud55c \uacf5\uac04\uc785\ub2c8\ub2e4. \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub85c \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\ub97c \ub118\uc5b4 \ud488\uaca9 \uc788\ub294 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud55c \uc720\uc564\ubbf8\ub294 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \ud2b9\ubcc4\ud55c \ub0a0\uc758 \ucd95\ud558, \uc0ac\uad50 \ubaa8\uc784 \ub4f1 \ub2e4\uc591\ud55c \ubaa9\uc801\uc744 \uc704\ud55c \uc644\ubcbd\ud55c \uc120\ud0dd\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc720\uc564\ubbf8\ub9cc\uc758 \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \ud604\ub300\uc801\uc774\uace0 \uac10\uac01\uc801\uc778 \uc778\ud14c\ub9ac\uc5b4<\/h3>\n\n\n\n<p>\uc720\uc564\ubbf8\ub294 \uc138\ub828\ub41c \ub514\uc790\uc778\uacfc \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\uac00 \ub3cb\ubcf4\uc774\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uae54\ub054\ud558\uace0 \uc815\uad50\ud558\uac8c \uc124\uacc4\ub41c \ub8f8\uc740 \ucc28\ubd84\ud558\uba74\uc11c\ub3c4 \ud2b8\ub80c\ub514\ud55c \ubd84\uc704\uae30\ub97c \uc870\uc131\ud558\uba70, \ubaa8\ub4e0 \ub9cc\ub0a8\uc744 \ud2b9\ubcc4\ud55c \ucd94\uc5b5\uc73c\ub85c \ub9cc\ub4e4\uc5b4 \uc90d\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ud3b8\uc548\ud568\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uace0\ub824\ud558\uc5ec \uc5ec\uc720\ub86d\uace0 \ud488\uaca9 \uc788\ub294 \uc2dc\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\uc5d0\uc11c\uc758 \ud2b9\ubcc4\ud55c \uc811\uadfc\uc131<\/h3>\n\n\n\n<p>\uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad \uc720\uc564\ubbf8\ub294 \uac15\ub0a8 \ud55c\ubcf5\ud310\uc5d0 \uc704\uce58\ud574 \uc774\ub3d9\uc774 \ud3b8\ub9ac\ud558\uace0 \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub0a9\ub2c8\ub2e4. \ub3c4\uc2ec \uc18d\uc5d0\uc11c \uc5ec\uc720\uc640 \ud488\uaca9\uc744 \ub290\ub084 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uc7a5\uc18c\ub85c, \uac15\ub0a8\uc758 \uc5d0\ub108\uc9c0\uc640 \uc720\uc564\ubbf8\ub9cc\uc758 \ucc28\ubd84\ud55c \ubd84\uc704\uae30\ub97c \ub3d9\uc2dc\uc5d0 \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ubaa8\ub4e0 \uc21c\uac04\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305, \uc0dd\uc77c \ud30c\ud2f0, \uae30\ub150\uc77c, \ud639\uc740 \ub2e8\uc21c\ud55c \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \uc5b4\ub5a4 \uc0c1\ud669\uc5d0\ub3c4 \uc720\uc564\ubbf8\ub294 \ucd5c\uc801\ud654\ub41c \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub204\uad6c\uc640 \ud568\uaed8\ud558\ub354\ub77c\ub3c4 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc138\uc2ec\ud568\uc774 \ub3cb\ubcf4\uc774\ub294 \uace0\uac1d \uc911\uc2ec\uc758 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5<\/h3>\n\n\n\n<p>\uc720\uc564\ubbf8\ub294 \uace0\uac1d\ub2d8\uc758 \ud3b8\uc758\ub97c \uc704\ud574 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ud504\ub77c\uc774\ube57 \ucc28\ub7c9 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \ubc14\ub85c \uc785\uc7a5\ud560 \uc218 \uc788\uc73c\uba70, \uc774\ub3d9 \uacfc\uc815\uc5d0\uc11c\ub3c4 \ud3b8\uc548\ud568\uacfc \ud488\uaca9\uc744 \ub290\ub084 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ud2b9\ubcc4\ud55c \ub0a0\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uc774\ubca4\ud2b8<\/h3>\n\n\n\n<p>DJ\uc640 \uc544\ud2f0\uc2a4\ud2b8 \uc12d\uc678(\ubcc4\ub3c4 \uc694\uccad \uac00\ub2a5)\ub97c \ud1b5\ud574 \uace0\uac1d\ub2d8\uc758 \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ud2b9\ubcc4\ud558\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc774 \uc6d0\ud558\uc2dc\ub294 \ubd84\uc704\uae30\uc5d0 \ub9de\ucdb0 \ubaa8\ub4e0 \ub514\ud14c\uc77c\uc744 \uc138\uc2ec\ud558\uac8c \uc900\ube44\ud558\uc5ec \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\uac00 \uc544\ub2cc \uc78a\uc9c0 \ubabb\ud560 \uc21c\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc548\uc804\ud558\uace0 \ucf8c\uc801\ud55c \ud658\uacbd<\/h2>\n\n\n\n<p>\uc720\uc564\ubbf8\ub294 \uccb4\uacc4\uc801\uc73c\ub85c \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uacfc \ucca0\uc800\ud788 \uad50\uc721\ubc1b\uc740 \uc2a4\ud0dc\ud504\ub97c \ud1b5\ud574 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc220\uc790\ub9ac\ub97c \ubcf4\uc7a5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ubaa8\ub4e0 \uc21c\uac04\uc744 \uc548\uc804\ud558\uace0 \ub9cc\uc871\uc2a4\ub7fd\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9ac\uba70, \ud488\uaca9 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \uc57d\uc18d\ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc815\uc9c1\ud55c \uac00\uaca9\uacfc \uc2e0\ub8b0\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc6b4\uc601<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ud22c\uba85\ud558\uace0 \ud569\ub9ac\uc801\uc778 \uac00\uaca9 \uc815\ucc45<\/h3>\n\n\n\n<p>\uc720\uc564\ubbf8\ub294 \uc815\ucc30\uc81c \uac00\uaca9 \uc6b4\uc601\uc744 \ud1b5\ud574 \uace0\uac1d\ub2d8\uaed8 \uac70\ud488 \uc5c6\ub294 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uacfc \ud22c\uba85\ud55c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uc548\ub0b4\ub418\uba70, \ucd94\uac00 \uc694\uae08 \uac71\uc815 \uc5c6\uc774 \uc548\uc2ec\ud558\uace0 \uc774\uc6a9\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uc2e0\ub8b0\ub97c \uc911\uc2ec\uc73c\ub85c \ud55c \uace0\uac1d \uad00\ub9ac<\/h3>\n\n\n\n<p>\uc720\uc564\ubbf8\ub294 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0\uacfc \ucd9c\uadfc \ud604\ud669\uc744 \uba85\ud655\ud788 \uc548\ub0b4\ud558\uc5ec, \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4. \ud55c \ubc88 \ubc29\ubb38\ud55c \uace0\uac1d\ub2d8\ub4e4\uc774 \ub2e4\uc2dc \ucc3e\ub294 \uc774\uc720\ub294 \ubc14\ub85c \uc774\ub7ec\ud55c \uc2e0\ub8b0\uc640 \ud488\uc9c8\uc5d0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\uc640 \ud568\uaed8\ud558\ub294 \ud2b9\ubcc4\ud55c \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \ub9e4\ub825\uacfc \ud488\uaca9\uc744 \uc9c0\ub2cc \ud30c\ud2b8\ub108<\/h3>\n\n\n\n<p>\uc720\uc564\ubbf8\ub294 \uc5c4\uaca9\ud55c \uae30\uc900\uc73c\ub85c \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc774\uace0 \ud488\uaca9 \uc788\ub294 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc2a4\ud0c0\uc77c\uc744 \uc120\ud0dd\ud558\uc5ec, \uc220\uc790\ub9ac \uc774\uc0c1\uc758 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \ub204\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ud558\uc774\ud37c\ube14\ub9ad\ub9cc\uc758 \ucc28\ubcc4\ud654\ub41c \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc720\uc564\ubbf8\ub294 \ud558\uc774\ud37c\ube14\ub9ad \ud2b9\uc720\uc758 \uace0\uae09\uc2a4\ub7ec\uc6c0\uacfc \uc790\uc720\ub85c\uc6b4 \ubd84\uc704\uae30\ub97c \uacb0\ud569\ud558\uc5ec, \ub204\uad6c\uc640 \ud568\uaed8\ud558\ub354\ub77c\ub3c4 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \ubcf4\uc7a5\ud569\ub2c8\ub2e4. \uc220\uc790\ub9ac\uac00 \ub2e8\uc21c\ud55c \ubaa8\uc784\uc774 \uc544\ub2cc \uae30\uc5b5\uc5d0 \ub0a8\ub294 \uacbd\ud5d8\uc73c\ub85c \ub0a8\ub3c4\ub85d \ubaa8\ub4e0 \ub514\ud14c\uc77c\uc744 \uc644\ubcbd\ud788 \uc900\ube44\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uc21c\uac04<\/h2>\n\n\n\n<p>\uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad \uc720\uc564\ubbf8\ub294 \uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825\uacfc \ud2b9\ubcc4\ud568\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uae09\uc2a4\ub7ec\uc6b4 \uacf5\uac04\uacfc \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub294 \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \ucd94\uc5b5\uc744 \uc120\uc0ac\ud558\uba70, \uc18c\uc911\ud55c \ub0a0\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<br>\uc720\uc564\ubbf8\uc5d0\uc11c\uc758 \uc2dc\uac04\uc740 \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc774 \uc644\ubcbd\ud788 \uc870\ud654\ub97c \uc774\ub8e8\ub294 \uc21c\uac04\uc73c\ub85c \ub0a8\uc744 \uac83\uc785\ub2c8\ub2e4. \uc9c0\uae08 \ubc14\ub85c \uc720\uc564\ubbf8\uc5d0\uc11c \ub2f9\uc2e0\ub9cc\uc758 \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ub9cc\ub4e4\uc5b4 \ubcf4\uc138\uc694!<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\ub3c4\uc2ec \uc18d\uc5d0\uc11c \uc5ec\uc720\uc640 \ud488\uaca9\uc744 \ub290\ub084 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uc7a5\uc18c\ub85c, \uac15\ub0a8\uc758 \uc5d0\ub108\uc9c0\uc640 \uc720\uc564\ubbf8\ub9cc\uc758 \ucc28\ubd84\ud55c \ubd84\uc704\uae30\ub97c \ub3d9\uc2dc\uc5d0 \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":5590,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[27],"class_list":["post-5497","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-hipublic"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5497","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5590"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5497"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5497"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}