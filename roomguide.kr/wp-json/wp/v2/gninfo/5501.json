{"id":5501,"date":"2025-01-06T20:15:57","date_gmt":"2025-01-06T11:15:57","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%97%a0%ec%bc%80%ec%9d%b4\/"},"modified":"2025-03-26T12:51:42","modified_gmt":"2025-03-26T03:51:42","slug":"mk","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/mk\/","title":{"rendered":"\uc5e0\ucf00\uc774"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad \uc5e0\ucf00\uc774 \u2013 \ud2b9\ubcc4\ud568\uacfc \ud488\uaca9\uc774 \ub9cc\ub098\ub294 \uc644\ubcbd\ud55c \uacf5\uac04<\/h3>\n\n\n\n<p>\uac15\ub0a8 <strong>\ud558\uc774\ud37c\ube14\ub9ad \uc5e0\ucf00\uc774<\/strong>\ub294 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub85c, \uace0\uac1d\ub2d8\uaed8 \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac\uc640 \ud488\uaca9 \uc788\ub294 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc790\ub9ac \uc7a1\uc740 \uc5e0\ucf00\uc774\ub294 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300\ubd80\ud130 \uce5c\ubaa9 \ubaa8\uc784\uae4c\uc9c0 \ub2e4\uc591\ud55c \ubaa9\uc801\uc5d0 \ub9de\ucdb0 \uc124\uacc4\ub41c \uacf5\uac04\uc73c\ub85c, \uace0\uac1d\ub2d8\uc758 \ubaa8\ub4e0 \uae30\ub300\ub97c \ucda9\uc871\uc2dc\ud0ac \uc644\ubcbd\ud55c \uc7a5\uc18c\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc5e0\ucf00\uc774\uc758 \ub3c5\ucc3d\uc801\uc778 \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \ub3c5\ubcf4\uc801\uc778 \uc778\ud14c\ub9ac\uc5b4\uc640 \uc5ec\uc720\ub85c\uc6b4 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc5e0\ucf00\uc774\ub294 \uac10\uac01\uc801\uc778 \ub514\uc790\uc778\uacfc \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4\ub85c \ub3c5\ucc3d\uc801\uc778 \ubd84\uc704\uae30\ub97c \uc5f0\ucd9c\ud569\ub2c8\ub2e4. \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc0c9\uac10\uacfc \ub514\ud14c\uc77c\uc774 \uc0b4\uc544 \uc788\ub294 \uacf5\uac04\uc5d0\uc11c, \uc220\uc790\ub9ac \uc774\uc0c1\uc758 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \ub204\ub9ac\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uacf3\uc740 \ucc28\ubd84\ud558\uba74\uc11c\ub3c4 \uc138\ub828\ub41c \ubd84\uc704\uae30\ub85c \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uc774\ub098 \uc0ac\uc801\uc778 \ubaa8\uc784 \ubaa8\ub450\uc5d0 \uc801\ud569\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8\uc5d0\uc11c \ub204\ub9ac\ub294 \ud2b9\ubcc4\ud55c \uc811\uadfc\uc131<\/h3>\n\n\n\n<p>\uc5e0\ucf00\uc774\ub294 \uac15\ub0a8\uc758 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud558\uc5ec \uc811\uadfc\uc131\uc774 \ud0c1\uc6d4\ud569\ub2c8\ub2e4. \ub113\uace0 \ucf8c\uc801\ud55c \uc2dc\uc124\uc740 \ub2e4\uc591\ud55c \uaddc\ubaa8\uc758 \ubaa8\uc784\uc744 \uc218\uc6a9\ud560 \uc218 \uc788\uc73c\uba70, \uac15\ub0a8\uc758 \ud654\ub824\ud568 \uc18d\uc5d0\uc11c\ub3c4 \ud488\uaca9 \uc788\ub294 \ud734\uc2dd\uc744 \uc81c\uacf5\ud558\ub294 \uacf3\uc73c\ub85c \uc190\uaf3d\ud799\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ubaa8\ub4e0 \uc0c1\ud669\uc5d0 \ub9de\ucd98 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc5e0\ucf00\uc774\ub294 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300, \ud2b9\ubcc4\ud55c \ub0a0\uc758 \ucd95\ud558, \uc0ac\uad50\uc801\uc778 \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \ub2e4\uc591\ud55c \uace0\uac1d\uce35\uc758 \ud544\uc694\ub97c \ucda9\uc871\ud560 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uac01 \uc0c1\ud669\uc5d0 \ub9de\uac8c \uc720\uc5f0\ud558\uac8c \uc6b4\uc601\ub418\uba70, \ubc29\ubb38 \ubaa9\uc801\uc5d0 \ub530\ub77c \ucd5c\uc0c1\uc758 \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d \uc911\uc2ec\uc758 \ub514\ud14c\uc77c\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\uacfc \uc774\ub3d9\uc744 \uc704\ud55c \ud504\ub77c\uc774\ube57 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc5e0\ucf00\uc774\ub294 \uace0\uac1d\ub2d8\uc758 \ud3b8\uc758\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud558\uba70 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ud504\ub77c\uc774\ube57 \ucc28\ub7c9 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubcf5\uc7a1\ud55c \uc774\ub3d9 \uacfc\uc815\uc5d0\uc11c\ub3c4 \uc2a4\ud2b8\ub808\uc2a4 \uc5c6\uc774 \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \uc2dc\uc791\ud560 \uc218 \uc788\ub3c4\ub85d \uc138\uc2ec\ud558\uac8c \ubc30\ub824\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc694\uccad\uc5d0 \ub530\ub978 \ub9de\ucda4\ud615 \uc774\ubca4\ud2b8 \uc5f0\ucd9c<\/h3>\n\n\n\n<p>\ud2b9\ubcc4\ud55c \ub0a0\uc744 \uc704\ud55c \ub514\ud14c\uc77c\ud55c \uc900\ube44\uac00 \ud544\uc694\ud558\uc2dc\ub2e4\uba74 \uc5e0\ucf00\uc774\uac00 \uc644\ubcbd\ud55c \uc120\ud0dd\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4. \uc804\ubb38 DJ \ubc0f \uc544\ud2f0\uc2a4\ud2b8 \uc12d\uc678(\ucd94\uac00 \uc694\uccad \uac00\ub2a5)\ub97c \ud1b5\ud574 \uace0\uac1d\ub2d8\ub9cc\uc758 \ub3c5\ud2b9\ud55c \uc774\ubca4\ud2b8\ub97c \ub9cc\ub4e4\uc5b4\ub4dc\ub9bd\ub2c8\ub2e4. \uc5e0\ucf00\uc774\ub294 \ub2e8\uc21c\ud55c \uc220\uc790\ub9ac\uac00 \uc544\ub2cc \ud2b9\ubcc4\ud55c \ucd94\uc5b5\uc744 \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc548\uc804\ud558\uace0 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>\uc5e0\ucf00\uc774\ub294 \uace0\uac1d\ub2d8\uc758 \uc548\uc804\uacfc \ub9cc\uc871\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud569\ub2c8\ub2e4. \uccb4\uacc4\uc801\uc73c\ub85c \uad00\ub9ac\ub41c \ud658\uacbd \uc18d\uc5d0\uc11c \ubd88\ud3b8\ud568 \uc5c6\ub294 \ud3b8\uc548\ud55c \uc220\uc790\ub9ac\ub97c \ubcf4\uc7a5\ud558\uba70, \ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc644\ubcbd\ud55c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc2a4\ud0dc\ud504\uc640 \ud30c\ud2b8\ub108 \ubaa8\ub450 \ucca0\uc800\ud55c \uad50\uc721\uc744 \ud1b5\ud574 \ucd5c\uace0\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uc774 \uc990\uac70\uc6c0\uc5d0\ub9cc \uc9d1\uc911\ud560 \uc218 \uc788\ub3c4\ub85d \ub3d5\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud558\uace0 \ud569\ub9ac\uc801\uc778 \uc6b4\uc601 \ucca0\ud559<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\uc815\uc9c1\ud55c \uac00\uaca9\uacfc \uc2e0\ub8b0\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc5e0\ucf00\uc774\ub294 \ud22c\uba85\ud558\uace0 \uc815\uc9c1\ud55c \uac00\uaca9 \uc815\ucc45\uc744 \uc6b4\uc601\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uba85\ud655\ud788 \uc548\ub0b4\ub418\uba70, \uace0\uac1d\ub2d8\uaed8 \ucd94\uac00\uc801\uc778 \uc694\uae08 \ubd80\ub2f4 \uc5c6\uc774 \ucd5c\uc0c1\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uacfc \uace0\ud488\uc9c8\uc758 \uc11c\ube44\uc2a4\ub97c \uacb0\ud569\ud55c \uc5e0\ucf00\uc774\ub294 \uac00\uc131\ube44\uc640 \ub9cc\uc871\ub3c4\ub97c \ub3d9\uc2dc\uc5d0 \ubcf4\uc7a5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc911\uc2ec\uc758 \uc2e0\ub8b0 \uc6b4\uc601<\/h3>\n\n\n\n<p>\uc5e0\ucf00\uc774\ub294 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \ubb34\uc5c7\ubcf4\ub2e4 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0 \ubc0f \ud604\ud669 \uc815\ubcf4\ub97c \uc815\ud655\ud788 \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc774 \ub0ad\ube44\ub418\uc9c0 \uc54a\ub3c4\ub85d \uc6b4\uc601\ub429\ub2c8\ub2e4. \ucc98\uc74c \ubc29\ubb38\ud55c \uace0\uac1d\ub2d8\ub3c4 \uc548\uc2ec\ud558\uace0 \uc774\uc6a9\ud560 \uc218 \uc788\ub294 \ubbff\uc74c\uc9c1\ud55c \ud658\uacbd\uc744 \uc870\uc131\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\ucc44\ub85c\uc6b4 \ub9e4\ub825\uc758 \ud30c\ud2b8\ub108\uc640 \ud568\uaed8\ud558\ub294 \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\uac1c\uc131\uacfc \ud488\uaca9\uc744 \uacb8\ube44\ud55c \ud30c\ud2b8\ub108<\/h3>\n\n\n\n<p>\uc5e0\ucf00\uc774\ub294 \uc5c4\uaca9\ud55c \uae30\uc900\uc73c\ub85c \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \ud30c\ud2b8\ub108\ub97c \uc120\ud0dd\ud560 \uc218 \uc788\uc73c\uba70, \ud488\uaca9 \uc788\ub294 \uc220\uc790\ub9ac\uc640 \ub354\ubd88\uc5b4 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ub9cc\ub07d\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ud558\uc774\ud37c\ube14\ub9ad\ub9cc\uc758 \uc790\uc720\ub86d\uace0 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc5e0\ucf00\uc774\ub294 \ud558\uc774\ud37c\ube14\ub9ad\uc758 \uc7a5\uc810\uc744 \uadf9\ub300\ud654\ud558\uc5ec \uace0\uac1d\ub2d8\uaed8 \uc790\uc720\ub85c\uc6b4 \ubd84\uc704\uae30\uc640 \uace0\uae09\uc2a4\ub7ec\uc6c0\uc744 \ub3d9\uc2dc\uc5d0 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub204\uad6c\uc640 \ud568\uaed8\ud558\ub354\ub77c\ub3c4 \ub9cc\uc871\ud560 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \ud658\uacbd\uc744 \ud1b5\ud574 \uc220\uc790\ub9ac\uac00 \ub2e8\uc21c\ud55c \uc2dc\uac04\uc774 \uc544\ub2cc \uae30\uc5b5\uc5d0 \ub0a8\uc744 \uacbd\ud5d8\uc73c\ub85c \uc644\uc131\ub429\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \uacbd\ud5d8<\/h2>\n\n\n\n<p>\uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad \uc5e0\ucf00\uc774\ub294 \uac15\ub0a8\uc5d0\uc11c\ub9cc \ub9cc\ub0a0 \uc218 \uc788\ub294 \ub3c5\ud2b9\ud55c \ub9e4\ub825\uacfc \ud488\uaca9\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\uc640 \uc138\ub828\ub41c \uacf5\uac04\uc740 \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \uc120\uc0ac\ud558\uba70, \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<br>\uc774\uacf3\uc5d0\uc11c\uc758 \uc220\uc790\ub9ac\ub294 \ub2e8\uc21c\ud55c \uc74c\uc8fc\uac00 \uc544\ub2cc, \uc990\uac70\uc6c0\uacfc \ud488\uaca9\uc774 \uacf5\uc874\ud558\ub294 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4. \uac15\ub0a8 \ud558\uc774\ud37c\ube14\ub9ad \uc5e0\ucf00\uc774\uc5d0\uc11c \uae30\ub300 \uc774\uc0c1\uc758 \ub9cc\uc871\uc744 \uacbd\ud5d8\ud574 \ubcf4\uc138\uc694.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc5e0\ucf00\uc774\ub294 \uc5c4\uaca9\ud55c \uae30\uc900\uc73c\ub85c \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. <\/p>\n","protected":false},"featured_media":5567,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[27],"class_list":["post-5501","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-hipublic"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5501","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5567"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5501"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5501"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}