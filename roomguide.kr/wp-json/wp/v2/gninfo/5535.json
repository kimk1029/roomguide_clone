{"id":5535,"date":"2025-01-06T20:19:39","date_gmt":"2025-01-06T11:19:39","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/?post_type=gninfo&#038;p=5535"},"modified":"2025-03-26T12:48:32","modified_gmt":"2025-03-26T03:48:32","slug":"cnn-2","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/cnn-2\/","title":{"rendered":"\uc528\uc5d4\uc5d4"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \uc154\uce20\ub8f8 \uc528\uc5d4\uc5d4 \u2013 \ud2b9\ubcc4\ud55c \ubc24\uc744 \uc704\ud55c \uc138\ub828\ub41c \uc120\ud0dd<\/h3>\n\n\n\n<p>\uac15\ub0a8 <strong>\uc154\uce20\ub8f8 \uc528\uc5d4\uc5d4<\/strong>\uc740 \ubaa8\ub358\ud558\uace0 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac\ub97c \uc990\uae38 \uc218 \uc788\ub294 \ud488\uaca9 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \ub3c5\ud2b9\ud55c \ucee8\uc149\uacfc \uc815\uad50\ud55c \uc11c\ube44\uc2a4, \uac15\ub0a8 \uc911\uc2ec\uc758 \ud3b8\ub9ac\ud55c \uc704\uce58\ub85c \ub9ce\uc740 \uc0ac\ub791\uc744 \ubc1b\uace0 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc154\uce20\ub8f8 \uc528\uc5d4\uc5d4\uc758 \ud2b9\ubcc4\ud55c \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\uc640 \ucc28\ubcc4\ud654\ub41c \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uae54\ub054\ud558\uace0 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4\ub85c \ud55c\uce35 \uc138\ub828\ub41c \ubd84\uc704\uae30\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud3b8\uc548\ud558\uba74\uc11c\ub3c4 \ud488\uaca9 \uc788\ub294 \uacf5\uac04\uc5d0\uc11c \uc220\uc790\ub9ac\uc640 \uc0ac\uad50\ub97c \ub3d9\uc2dc\uc5d0 \ub9cc\uc871\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\uc5d0\uc11c\uc758 \ucd5c\uc801\uc758 \uc704\uce58<\/h3>\n\n\n\n<p>\uac15\ub0a8 \uc154\uce20\ub8f8 \uc528\uc5d4\uc5d4\uc740 \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub09c \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud558\uace0 \uc788\uc5b4, \ube44\uc988\ub2c8\uc2a4 \uc811\ub300\uc640 \ud2b9\ubcc4\ud55c \ub9cc\ub0a8 \ubaa8\ub450\uc5d0 \uc801\ud569\ud55c \ucd5c\uc801\uc758 \uc7a5\uc18c\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ub2e4\uc591\ud55c \uace0\uac1d\uce35\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \ube44\uc988\ub2c8\uc2a4 \uc811\ub300\ubfd0\ub9cc \uc544\ub2c8\ub77c \uc0dd\uc77c \ud30c\ud2f0, \uce5c\ubaa9 \ubaa8\uc784, \ud2b9\ubcc4\ud55c \uae30\ub150\uc77c\uc5d0\ub3c4 \ucd5c\uc801\ud654\ub41c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub0a8\ub140 \ub3d9\ubc18 \ubc29\ubb38\ub3c4 \uac00\ub2a5\ud558\uba70, \ubaa8\ub4e0 \uace0\uac1d\ub2d8\uaed8 \uc78a\uc9c0 \ubabb\ud560 \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc138\uc2ec\ud558\uac8c \uc900\ube44\ub41c \uace0\uac1d \uc911\uc2ec\uc758 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9 \ubc0f \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uace0\uac1d\ub2d8\uc758 \ubc29\ubb38\uc744 \ub354\uc6b1 \ud3b8\ub9ac\ud558\uac8c \ub9cc\ub4e4\uc5b4 \uc904 \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc8fc\ucc28 \uac71\uc815 \uc5c6\uc774 \uc5ec\uc720\ub86d\uac8c \uc785\uc7a5\ud560 \uc218 \uc788\uc73c\uba70, \uc774\ub3d9 \ub610\ud55c \ud504\ub77c\uc774\ube57\ud558\uace0 \ud3b8\uc548\ud558\uac8c \uc9c4\ud589\ub429\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9de\ucda4\ud615 \uc774\ubca4\ud2b8 \uc9c0\uc6d0<\/h3>\n\n\n\n<p>\ud2b9\ubcc4\ud55c \ub0a0\uc744 \uc704\ud574 DJ \ubc0f \uc2f1\uc5b4 \uc12d\uc678 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. (\ubcc4\ub3c4 \ube44\uc6a9 \ubc1c\uc0dd) \uace0\uac1d\ub2d8\uc758 \uc694\uccad\uc5d0 \ub530\ub77c \ub9de\ucda4\ud615 \uc774\ubca4\ud2b8\ub97c \uc900\ube44\ud558\uc5ec \ub354\uc6b1 \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ub9cc\ub4e4\uc5b4\ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uc5c6\ub294 \uc548\uc804\ud558\uace0 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uace0\uac1d\ub2d8\uaed8 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc57d\uc18d\ub4dc\ub9bd\ub2c8\ub2e4. \uccb4\uacc4\uc801\uc778 \uad50\uc721\uc744 \ubc1b\uc740 \uc2a4\ud0dc\ud504\uc640 \ucca0\uc800\ud788 \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uc744 \ud1b5\ud574 \uc5b8\uc81c\ub098 \uc548\uc804\ud558\uace0 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud569\ub9ac\uc801\uc778 \uac00\uaca9 \uc815\ucc45\uacfc \uc2e0\ub8b0<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ud22c\uba85\ud55c \uc815\ucc30\uc81c \uc6b4\uc601<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uac70\ud488 \uc5c6\ub294 \uc815\ucc30\uc81c \uac00\uaca9\uc73c\ub85c \uace0\uac1d\ub2d8\uaed8 \ud22c\uba85\ud55c \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \ube44\uc6a9\uc740 \uc0ac\uc804\uc5d0 \uba85\ud655\ud788 \uc548\ub0b4\ub418\uba70, \ucd94\uac00 \ube44\uc6a9\uc5d0 \ub300\ud55c \uac71\uc815 \uc5c6\uc774 \ud3b8\uc548\ud558\uac8c \uc774\uc6a9\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc2e0\ub8b0\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uace0\uac1d\ub2d8\uc758 \uc2e0\ub8b0\ub97c \uac00\uc7a5 \uc911\uc694\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc778\uc6d0\uacfc \ucd9c\uadfc \ud604\ud669 \ub4f1\uc744 \uc815\ud655\ud788 \uc548\ub0b4\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\uc640\uc758 \ud2b9\ubcc4\ud55c \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \ub9e4\ub825\uc758 \ud30c\ud2b8\ub108<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uc5c4\uaca9\ud55c \uae30\uc900\uc73c\ub85c \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc778 \ud30c\ud2b8\ub108\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \ud30c\ud2b8\ub108\ub97c \uc120\ud0dd\ud558\uc5ec \ub354\uc6b1 \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \ub9cc\ub07d\ud558\uc138\uc694.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uc154\uce20\ub8f8\ub9cc\uc758 \ucc28\ubcc4\ud654\ub41c \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc528\uc5d4\uc5d4\uc740 \uc154\uce20\ub8f8 \ud2b9\uc720\uc758 \ucc28\ubcc4\ud654\ub41c \ucee8\uc149\uc73c\ub85c, \ud3b8\uc548\ud558\uba74\uc11c\ub3c4 \uc138\ub828\ub41c \ubd84\uc704\uae30\uc5d0\uc11c \uc790\uc720\ub86d\uace0 \uc990\uac70\uc6b4 \uc220\uc790\ub9ac\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud568<\/h2>\n\n\n\n<p>\uc154\uce20\ub8f8 \uc528\uc5d4\uc5d4\uc740 \uac15\ub0a8\uc5d0\uc11c\ub9cc \ub290\ub084 \uc218 \uc788\ub294 \ub3c5\ud2b9\ud55c \ub9e4\ub825\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \ud488\uaca9 \uc788\ub294 \uacf5\uac04\uacfc \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub85c \uace0\uac1d\ub2d8\uc758 \ubaa8\ub4e0 \uae30\ub300\ub97c \ucda9\uc871\uc2dc\ud0a4\uba70 \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4e4\uc5b4\ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \uc154\uce20\ub8f8 \uc528\uc5d4\uc5d4\uc740 \ubaa8\ub358\ud558\uace0 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uc220\uc790\ub9ac\ub97c \uc990\uae38 \uc218 \uc788\ub294 \ud488\uaca9 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. <\/p>\n","protected":false},"featured_media":5577,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[26],"class_list":["post-5535","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-shirtroom"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5535","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5577"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5535"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5535"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}