{"id":6186,"date":"2025-01-15T21:32:07","date_gmt":"2025-01-15T12:32:07","guid":{"rendered":"https:\/\/roomguide.kr\/?post_type=gninfo&#038;p=6186"},"modified":"2025-03-26T12:48:03","modified_gmt":"2025-03-26T03:48:03","slug":"sound","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/sound\/","title":{"rendered":"\uc0ac\uc6b4\ub4dc"},"content":{"rendered":"\n<p>\uc11c\uc6b8\uc758 \uac15\ub0a8\uad6c\ub294 \uadf8 \uc790\uccb4\ub85c \uc11c\uc6b8\uc758 \ud2b8\ub80c\ub4dc\ub97c \uc774\ub044\ub294 \uc911\uc2ec\uc9c0\uc785\ub2c8\ub2e4. \uace0\uae09 \ud328\uc158, \ucd5c\uc2e0 \uae30\uc220, \uadf8\ub9ac\uace0 \ub7ed\uc154\ub9ac\ud55c \ub77c\uc774\ud504\uc2a4\ud0c0\uc77c\uc744 \uc120\ub3c4\ud558\ub294 \uac15\ub0a8\uc740, \ud2b9\ud788 \uc80a\uc740\uce35\uacfc \uc7ac\ub825 \uc788\ub294 \uc0ac\ub78c\ub4e4\uc5d0\uac8c \ud070 \uc778\uae30\ub97c \ub04c\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uadf8 \uc911\uc5d0\uc11c\ub3c4 \uac15\ub0a8\uc758 \ud074\ub7fd \uc52c\uc740 \uc774 \uc9c0\uc5ed\uc758 \ub610 \ub2e4\ub978 \uc911\uc694\ud55c \ubb38\ud654\uc801 \uc694\uc18c\ub85c, \uc11c\uc6b8\uc758 \ub098\uc774\ud2b8\ub77c\uc774\ud504\ub97c \uc81c\ub300\ub85c \uc990\uae30\ub824\ub294 \uc774\ub4e4\uc5d0\uac8c \ud544\uc218\uc801\uc778 \uc7a5\uc18c\ub85c \uc190\uaf3d\ud788\uc8e0.<\/p>\n\n\n\n<p>\uac15\ub0a8 \ud074\ub7fd, \ud2b9\ud788 <strong>\uc2e0\uc0ac\uc5ed<\/strong>\uacfc <strong>\uac15\ub0a8\ub300\ub85c<\/strong>, \uadf8\ub9ac\uace0 <strong>\uac15\ub0a8\uc5ed<\/strong>\uc774 \ud3ec\ud568\ub41c <strong>\uc11c\ucd08\uad6c<\/strong> \uc9c0\uc5ed\uc740 \uc80a\uc740 \uce35\uc758 \ud56b\ud50c\ub808\uc774\uc2a4\ub85c \uc54c\ub824\uc838 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uacf3\uc740 20\ub300 \ucd08\ubc18\uc5d0\uc11c \ud6c4\ubc18\uc758 \uc80a\uace0 \uc138\ub828\ub41c \uc0ac\ub78c\ub4e4\uacfc, \uacbd\uc81c\uc801\uc73c\ub85c \uc5ec\uc720\uac00 \uc788\ub294 \uc774\ub4e4\uc774 \uc790\uc8fc \ucc3e\ub294 \uba85\uc18c\ub85c, \ubc24\ub9c8\ub2e4 \ud65c\uae30\ucc2c \uc5d0\ub108\uc9c0\ub97c \uc790\ub791\ud569\ub2c8\ub2e4. \uadf8\ub7fc \uc774 \uc9c0\uc5ed\uc758 \ud074\ub7fd\ub4e4\uc774 \uc65c \uc774\ub807\uac8c \ud2b9\ubcc4\ud55c\uc9c0, \uadf8 \ub9e4\ub825\uc744 \ud55c\ubc88 \uc0b4\ud3b4\ubcf4\uaca0\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \ud074\ub7fd\uc5d0\uc11c \ub9cc\ub098\ub294 \ud2b9\ubcc4\ud55c \uc0ac\ub78c\ub4e4<\/h3>\n\n\n\n<p>\uac15\ub0a8 \ud074\ub7fd \uc52c\uc758 \uac00\uc7a5 \ud070 \ud2b9\uc9d5\uc740 \ubc14\ub85c \uadf8\uacf3\uc744 \ucc3e\ub294 \uc0ac\ub78c\ub4e4\uc785\ub2c8\ub2e4. \uc774\uacf3\uc744 \ucc3e\ub294 \uc0ac\ub78c\ub4e4\uc740 \ub300\ubd80\ubd84 \uc80a\uace0, \uc2a4\ud0c0\uc77c\ub9ac\uc2dc\ud558\uba70, \uacbd\uc81c\uc801\uc73c\ub85c \uc5ec\uc720\uac00 \uc788\ub294 \uc0ac\ub78c\ub4e4\ub85c, \uadf8\ub4e4\ub9cc\uc758 \ud2b9\ubcc4\ud55c \ubd84\uc704\uae30\ub97c \ub9cc\ub4e4\uc5b4\ub0c5\ub2c8\ub2e4.<\/p>\n\n\n\n<ul class=\"wp-block-list\">\n<li><strong>\uc80a\uc740 \uc5ec\uc131\ub4e4:<\/strong> \uac15\ub0a8\uc758 \ud074\ub7fd\uc744 \ucc3e\ub294 \ub9ce\uc740 \uc5ec\uc131\ub4e4\uc740 20\ub300 \ucd08\ubc18\uc5d0\uc11c \uc911\ubc18\uc758 \ub098\uc774\ub85c, \ucd5c\uc2e0 \uc720\ud589\uc744 \ub530\ub974\uba70 \ud328\uc154\ub108\ube14\ud55c \uc637\uc744 \uc785\uace0 \ud074\ub7fd\uc5d0 \ub098\ud0c0\ub0a9\ub2c8\ub2e4. \uc774\ub4e4\uc740 \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0b4\uac70\ub098, \uc0c8\ub85c\uc6b4 \uc778\uc5f0\uc744 \ub9cc\ub4e4\uae30 \uc704\ud574 \uc790\uc8fc \ubc29\ubb38\ud569\ub2c8\ub2e4. \uadf8\ub4e4\uc758 \uc790\uc2e0\uac10 \ub118\uce58\ub294 \uc5d0\ub108\uc9c0\uc640 \uc138\ub828\ub41c \uc2a4\ud0c0\uc77c\uc740 \uac15\ub0a8 \ud074\ub7fd\uc758 \ubd84\uc704\uae30\ub97c \ub354\uc6b1 \uace0\uae09\uc2a4\ub7fd\uace0 \ud65c\uae30\ucc28\uac8c \ub9cc\ub4ed\ub2c8\ub2e4.<\/li>\n\n\n\n<li><strong>\uc7ac\ub825 \uc788\ub294 \ub0a8\uc131\ub4e4:<\/strong> \uac15\ub0a8 \ud074\ub7fd\uc5d0\ub294 \ub610\ud55c \uacbd\uc81c\uc801 \uc5ec\uc720\uac00 \uc788\ub294 20\ub300 \ud6c4\ubc18\uc5d0\uc11c 30\ub300 \ucd08\ubc18\uc758 \ub0a8\uc131\ub4e4\uc774 \uc790\uc8fc \ub4f1\uc7a5\ud569\ub2c8\ub2e4. \uc774\ub4e4\uc740 \ubcf4\ud1b5 \uae08\uc735, IT, \uc2a4\ud0c0\ud2b8\uc5c5 \ub4f1 \ub2e4\uc591\ud55c \ubd84\uc57c\uc5d0\uc11c \uc131\uacf5\uc801\uc778 \uacbd\ub825\uc744 \uc313\uc740 \uc778\ubb3c\ub4e4\ub85c, \ud074\ub7fd\uc5d0\uc11c\ub294 \uc8fc\ub85c \ub124\ud2b8\uc6cc\ud0b9\uc744 \ud558\uac70\ub098, \uc77c\uc0c1\uc758 \uc2a4\ud2b8\ub808\uc2a4\ub97c \ud480\uae30 \uc704\ud574 \ucc3e\uc544\uc635\ub2c8\ub2e4. \uc774\ub4e4\uc758 \uc9c0\ucd9c\uc740 \uc0c1\ub2f9\ud788 \uc5ec\uc720\ub86d\uace0, \uc885\uc885 \uace0\uae09 \uc220\uc744 \uc8fc\ubb38\ud558\uac70\ub098 VIP \uacf5\uac04\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uc11c\ube44\uc2a4\ub97c \ubc1b\uc73c\uba70 \uc2dc\uac04\uc744 \ubcf4\ub0c5\ub2c8\ub2e4.<\/li>\n<\/ul>\n\n\n\n<p>\uc774\ucc98\ub7fc \uac15\ub0a8 \ud074\ub7fd\uc5d0\ub294 \uc138\ub828\ub41c \uc2a4\ud0c0\uc77c\uacfc \uace0\uae09\uc2a4\ub7ec\uc6c0\uc744 \ucd94\uad6c\ud558\ub294 \uc0ac\ub78c\ub4e4\ub85c \uac00\ub4dd \ucc28 \uc788\uc73c\uba70, \uc774\ub4e4\uc758 \uc5d0\ub108\uc9c0\uac00 \ud074\ub7fd\uc758 \ubd84\uc704\uae30\ub97c \ub354\uc6b1 \ub728\uac81\uac8c \ub9cc\ub4ed\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ud074\ub7fd\uc758 \uc74c\uc545: \uae00\ub85c\ubc8c \ud2b8\ub80c\ub4dc\uc640 \ub85c\uceec \uac10\uac01\uc758 \uc870\ud654<\/h3>\n\n\n\n<p>\uac15\ub0a8 \ud074\ub7fd \uc52c\uc758 \ub610 \ub2e4\ub978 \ud070 \ud2b9\uc9d5\uc740 \ubc14\ub85c <strong>\uc74c\uc545<\/strong>\uc785\ub2c8\ub2e4. \uc774\uacf3\uc758 \ud074\ub7fd\ub4e4\uc740 <strong>EDM(\uc77c\ub809\ud2b8\ub85c\ub2c9 \ub304\uc2a4 \uc74c\uc545)<\/strong>, <strong>\ud799\ud569<\/strong>, <strong>\ud2b8\ub7a9<\/strong>, \uadf8\ub9ac\uace0 <strong>K-pop<\/strong> \ub4f1 \ub2e4\uc591\ud55c \uc7a5\ub974\uc758 \uc74c\uc545\uc744 \ubbf9\uc2a4\ud558\uc5ec, \uc804 \uc138\uacc4\uc801\uc778 \ud2b8\ub80c\ub4dc\uc640 \ud55c\uad6d\uc801\uc778 \uc694\uc18c\uac00 \uc798 \uacb0\ud569\ub41c \uc0ac\uc6b4\ub4dc\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\ub300\ud45c\uc801\uc778 \ud074\ub7fd\uc778 <strong>\uc625\ud0c0\uace4<\/strong>, <strong>\uc544\ub808\ub098<\/strong>, <strong>\ub354 \ud558\uc774\ube0c<\/strong> \ub4f1\uc740 \uc138\uacc4\uc801\uc73c\ub85c \uc720\uba85\ud55c DJ\ub4e4\uc758 \uacf5\uc5f0\uc744 \uc790\uc8fc \uac1c\ucd5c\ud558\uba70, \ucd5c\uc2e0 \uae00\ub85c\ubc8c \ud788\ud2b8\uace1\uacfc \ub85c\uceec \ud2b8\ub799\uc774 \uc11e\uc5ec \ub04a\uc784\uc5c6\uc774 \ud074\ub7fd\uc758 \ubd84\uc704\uae30\ub97c \uace0\uc870\uc2dc\ud0b5\ub2c8\ub2e4. EDM\uc758 \uc804\uc790\uc801\uc778 \ube44\ud2b8\ubd80\ud130 K-pop\uc758 \uc911\ub3c5\uc131 \uac15\ud55c \uba5c\ub85c\ub514\uae4c\uc9c0, \ud074\ub7fd \ub0b4\uc5d0\uc11c \ud758\ub7ec\ub098\uc624\ub294 \uc74c\uc545\uc740 \ud30c\ud2f0\uc758 \uc5d0\ub108\uc9c0\ub97c \ud55c\uce35 \ub354 \ub04c\uc5b4\uc62c\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">VIP \ub77c\uc6b4\uc9c0\uc640 \ubcd1\ud589\ub418\ub294 \ub7ed\uc154\ub9ac\ud55c \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uac15\ub0a8 \ud074\ub7fd\uc740 \ub2e8\uc21c\ud55c \ub098\uc774\ud2b8\ud074\ub7fd \uc774\uc0c1\uc758 \uc758\ubbf8\ub97c \uac00\uc9c0\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\uacf3\uc740 <strong>VIP \uc11c\ube44\uc2a4<\/strong>\uc640 <strong>\ud504\ub77c\uc774\ube57\ud55c \ub77c\uc6b4\uc9c0<\/strong>\ub97c \ud1b5\ud574 \ud074\ub7fdbing\uc744 \uc990\uae30\ub294 \uc0ac\ub78c\ub4e4\uc5d0\uac8c \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\ub9ce\uc740 \ud074\ub7fd\ub4e4\uc774 \uace0\uae09\uc2a4\ub7ec\uc6b4 <strong>\ubcd1\ud589 \uc11c\ube44\uc2a4<\/strong>\uc640 <strong>VIP \ud14c\uc774\ube14<\/strong>\uc744 \ub9c8\ub828\ud574 \ub450\uace0 \uc788\uc73c\uba70, \uc774\ub7f0 \uacf5\uac04\uc5d0\uc11c \ud30c\ud2f0\ub97c \uc990\uae30\ub294 \uc0ac\ub78c\ub4e4\uc740 \ubcf4\ub2e4 \ud504\ub77c\uc774\ube57\ud558\uba74\uc11c\ub3c4 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub294 \uac15\ub0a8\uc758 \ud074\ub7fd\ub4e4\uc774 \uc81c\uacf5\ud558\ub294 \ub610 \ub2e4\ub978 \ub9e4\ub825\uc801\uc778 \uc694\uc18c\ub85c, \uc7ac\ub825 \uc788\ub294 \uc0ac\ub78c\ub4e4\uc774 \uc790\uc8fc \ucc3e\ub294 \uc774\uc720 \uc911 \ud558\ub098\uc785\ub2c8\ub2e4. \uace0\uae09 \uc220\uc744 \uc8fc\ubb38\ud558\uace0, \ud2b9\ubcc4\ud55c \uacf5\uac04\uc5d0\uc11c \uc0ac\ub78c\ub4e4\uacfc \uc18c\ud1b5\ud558\uba70, \uc804\uc6a9 \uc11c\ube44\uc2a4\ub97c \ubc1b\ub294 \uacbd\ud5d8\uc740 \uc77c\ubc18\uc801\uc778 \ud074\ub7fd\ubcf4\ub2e4 \ub354\uc6b1 \ud2b9\ubcc4\ud55c \ubd84\uc704\uae30\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \ud074\ub7fd\uc758 \ub4dc\ub808\uc2a4 \ucf54\ub4dc\uc640 \ud0dc\ub3c4<\/h3>\n\n\n\n<p>\uac15\ub0a8\uc758 \ud074\ub7fd\uc5d0\uc11c\ub294 <strong>\ub4dc\ub808\uc2a4 \ucf54\ub4dc<\/strong>\uc640 <strong>\ud0dc\ub3c4<\/strong> \ub610\ud55c \uc911\uc694\ud55c \uc694\uc18c\ub85c \uc791\uc6a9\ud569\ub2c8\ub2e4. \uc774 \uc9c0\uc5ed\uc758 \ud074\ub7fd\uc740 \uc138\ub828\ub41c \ubd84\uc704\uae30\ub97c \uc720\uc9c0\ud558\uae30 \uc704\ud574 \uc5c4\uaca9\ud55c \ub4dc\ub808\uc2a4 \ucf54\ub4dc\ub97c \uc9c0\ud0a4\ub294 \uacf3\uc774 \ub9ce\uc2b5\ub2c8\ub2e4. \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc758\uc0c1\uacfc \ud328\uc154\ub108\ube14\ud55c \uc2a4\ud0c0\uc77c\uc774 \uae30\ubcf8\uc774\uba70, \ud074\ub7fd\uc744 \ubc29\ubb38\ud558\ub294 \uc0ac\ub78c\ub4e4\uc740 \uc774\ub97c \uc900\uc218\ud558\uba74\uc11c \uc790\uc2e0\ub9cc\uc758 \uc2a4\ud0c0\uc77c\uc744 \ubf50\ub0c5\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\ub610\ud55c, \uac15\ub0a8\uc758 \ud074\ub7fd\uc5d0\uc11c \uc911\uc694\ud55c \uac83\uc740 \ub2e8\uc21c\ud788 \uc990\uae30\ub294 \uac83 \uc774\uc0c1\uc758 <strong>\uc790\uc2e0\uac10<\/strong>\uacfc <strong>\uc2a4\ud0c0\uc77c<\/strong>\uc785\ub2c8\ub2e4. \uc774\uacf3\uc740 \ub2e8\uc9c0 \ucda4\uc744 \ucd94\uace0 \uc220\uc744 \ub9c8\uc2dc\ub294 \uc7a5\uc18c\uac00 \uc544\ub2c8\ub77c, \uc790\uc2e0\uc758 \uc0ac\ud68c\uc801 \uc9c0\uc704\uc640 \uac1c\uc131\uc744 \ud45c\ud604\ud558\ub294 \uc7a5\uc18c\uc785\ub2c8\ub2e4. \uc774\ub97c \ud1b5\ud574 \uac15\ub0a8\uc758 \ud074\ub7fd\uc740 \uc80a\uc740 \uc0ac\ub78c\ub4e4\uc5d0\uac8c \uc790\uc2e0\uc744 \ud45c\ud604\ud560 \uc218 \uc788\ub294 \ud2b9\ubcc4\ud55c \ubb34\ub300\uac00 \ub418\uc5b4\uc90d\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uacb0\ub860: \uac15\ub0a8\uc5d0\uc11c \ub9cc\ub098\ub294 \uc80a\uace0 \uc138\ub828\ub41c \ub098\uc774\ud2b8\ub77c\uc774\ud504<\/h3>\n\n\n\n<p>\uacb0\ub860\uc801\uc73c\ub85c \uac15\ub0a8\uc758 \ud074\ub7fd \uc52c\uc740 <strong>\uc11c\uc6b8\uc758 \ub098\uc774\ud2b8\ub77c\uc774\ud504<\/strong>\uc5d0\uc11c \uac00\uc7a5 \ub9e4\ub825\uc801\uc774\uace0 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc774\uacf3\uc740 <strong>\uc80a\uc740 \uc5ec\uc131\ub4e4<\/strong>, <strong>\uc7ac\ub825 \uc788\ub294 \ub0a8\uc131\ub4e4<\/strong>, \uadf8\ub9ac\uace0 <strong>\uc138\ub828\ub41c \uc2a4\ud0c0\uc77c\uc744 \ucd94\uad6c\ud558\ub294 \uc0ac\ub78c\ub4e4<\/strong>\uc774 \ubaa8\uc5ec \ud558\ub098\uc758 \ud2b9\ubcc4\ud55c \ubd84\uc704\uae30\ub97c \ub9cc\ub4e4\uc5b4\ub0c5\ub2c8\ub2e4. \uac15\ub0a8\uc758 \ud074\ub7fd\uc5d0\uc11c\ub294 \ucd5c\uc2e0 \uc74c\uc545\uc744 \ub4e3\uace0, \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30 \uc18d\uc5d0\uc11c \ucda4\uc744 \ucd94\uba70, \uc790\uc2e0\ub9cc\uc758 \uc2a4\ud0c0\uc77c\uc744 \ubf50\ub0bc \uc218 \uc788\ub294 \uae30\ud68c\uac00 \uc8fc\uc5b4\uc9d1\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uac15\ub0a8\uc758 \ud074\ub7fd \uc52c\uc740 \ub2e8\uc21c\ud55c \ud30c\ud2f0\uac00 \uc544\ub2d9\ub2c8\ub2e4. \uadf8\uac83\uc740 <strong>\uc2a4\ud0c0\uc77c<\/strong>\uacfc <strong>\uc790\uc2e0\uac10<\/strong>, \uadf8\ub9ac\uace0 <strong>\ub7ed\uc154\ub9ac<\/strong>\ub97c \uc990\uae38 \uc218 \uc788\ub294 \ub098\uc774\ud2b8\ub77c\uc774\ud504\uc758 \ucd5c\uc804\uc120\uc785\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c\uc758 \ubc24\uc740 \uadf8 \uc790\uccb4\ub85c \ud2b9\ubcc4\ud558\uba70, \uc774 \uc9c0\uc5ed\uc758 \ud074\ub7fd\uc740 \uc138\uacc4\uc801 \uc218\uc900\uc758 \ub098\uc774\ud2b8\ub77c\uc774\ud504\ub97c \uc6d0\ud558\ub294 \uc774\ub4e4\uc5d0\uac8c \uac00\uc7a5 \uc801\ud569\ud55c \uc7a5\uc18c\uc785\ub2c8\ub2e4.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uc2e0\uc0ac\uc5ed 1\ubc88 \ucd9c\uad6c \ubc14\ub85c \uc55e\uc5d0 \uc704\uce58\ud55c \uac15\ub0a8 \ud074\ub7fd \uc0ac\uc6b4\ub4dc\ub294 \uc74c\uc545\uacfc \ub304\uc2a4\ub97c \uc990\uae30\ub294 \uc774\ub4e4\uc744 \uc704\ud55c \uc778\uae30\uc788\ub294 \ud074\ub7fd \uc911 \ud558\ub098\uc785\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":5663,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[30],"class_list":["post-6186","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-club"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/6186","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5663"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=6186"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=6186"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}