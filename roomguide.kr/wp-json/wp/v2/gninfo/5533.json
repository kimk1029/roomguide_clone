{"id":5533,"date":"2025-01-06T20:16:00","date_gmt":"2025-01-06T11:16:00","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ec%96%b4%ea%b2%8c%ec%9d%b8\/"},"modified":"2025-01-15T22:06:05","modified_gmt":"2025-01-15T13:06:05","slug":"again","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/again\/","title":{"rendered":"\uc5b4\uac8c\uc778"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\uac15\ub0a8 \ud638\uc2a4\ud2b8\ubc14 \uc5b4\uac8c\uc778 \u2013 \ub2f9\uc2e0\uc744 \uc704\ud55c \ud2b9\ubcc4\ud55c \uc21c\uac04\uc758 \uc2dc\uc791<\/h3>\n\n\n\n<p>\uac15\ub0a8 <strong>\ud638\uc2a4\ud2b8\ubc14 \uc5b4\uac8c\uc778<\/strong>\uc740 \uc5ec\uc131 \uace0\uac1d\ub2d8\ub9cc\uc744 \uc704\ud574 \uc900\ube44\ub41c \uc138\ub828\ub41c \uacf5\uac04\uc73c\ub85c, \uc77c\uc0c1\uc758 \ud2c0\uc744 \ubc97\uc5b4\ub098 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. \uc5b4\uac8c\uc778\uc740 \ud2b8\ub80c\ub514\ud55c \uc778\ud14c\ub9ac\uc5b4\uc640 \ucc28\ubcc4\ud654\ub41c \uc11c\ube44\uc2a4\ub97c \ud1b5\ud574 \ub2e8\uc21c\ud55c \ub9cc\ub0a8\uc744 \ub118\uc5b4 \uc78a\uc9c0 \ubabb\ud560 \ucd94\uc5b5\uc744 \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc5d0\uc11c \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc744 \ub3d9\uc2dc\uc5d0 \ub204\ub9b4 \uc218 \uc788\ub294 \ucd5c\uace0\uc758 \uc7a5\uc18c\ub85c, \ub2e4\uc2dc \ucc3e\uace0 \uc2f6\uc740 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uc5b4\uac8c\uc778\ub9cc\uc758 \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">1. \uc5ec\uc131 \uace0\uac1d\uc744 \uc704\ud55c \uc138\ub828\ub41c \uacf5\uac04<\/h3>\n\n\n\n<p>\uc5b4\uac8c\uc778\uc740 \uc5ec\uc131 \uace0\uac1d\ub2d8\ub4e4\ub9cc\uc744 \uc704\ud55c \uacf5\uac04\uc73c\ub85c, \uac10\uac01\uc801\uc774\uace0 \uc6b0\uc544\ud55c \uc778\ud14c\ub9ac\uc5b4\ub97c \uc790\ub791\ud569\ub2c8\ub2e4. \uace0\uae09\uc2a4\ub7ec\uc6c0\uacfc \ud3b8\uc548\ud568\uc744 \uacb0\ud569\ud55c \ub514\uc790\uc778\uc740 \uace0\uac1d\ub2d8\uaed8 \uc628\uc804\ud788 \uc9d1\uc911\ub41c \uc2dc\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uc5b4\uac8c\uc778\uc5d0\uc11c \ub2f9\uc2e0\uc740 \uc8fc\uc778\uacf5\uc73c\ub85c\uc11c \ud2b9\ubcc4\ud55c \ubc24\uc744 \ub204\ub9ac\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">2. \uac15\ub0a8 \uc911\uc2ec\ubd80\uc758 \ud3b8\ub9ac\ud55c \uc704\uce58<\/h3>\n\n\n\n<p>\uc5b4\uac8c\uc778\uc740 \uac15\ub0a8\uc758 \uc911\uc2ec\ubd80\uc5d0 \uc704\uce58\ud558\uc5ec \uc811\uadfc\uc131\uc774 \ub6f0\uc5b4\ub0a9\ub2c8\ub2e4. \ub3c4\uc2ec \uc18d\uc5d0\uc11c \ud654\ub824\ud568\uacfc \uace0\uc694\ud568\uc774 \uc870\ud654\ub97c \uc774\ub8e8\ub294 \uacf5\uac04\uc5d0\uc11c, \uc624\uc9c1 \ub2f9\uc2e0\ub9cc\uc744 \uc704\ud55c \uc2dc\uac04\uc744 \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">3. \ub2e4\uc591\ud55c \ubaa9\uc801\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4<\/h3>\n\n\n\n<p>\uc0dd\uc77c \ud30c\ud2f0, \uae30\ub150\uc77c, \uce5c\ubaa9 \ubaa8\uc784 \ub4f1 \uc5b4\uac8c\uc778\uc740 \ubaa8\ub4e0 \uace0\uac1d\ub2d8\uc758 \uc694\uad6c\ub97c \ucda9\uc871\uc2dc\ud0ac \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ucd98 \uc138\uc2ec\ud55c \uc900\ube44\uc640 \uc5f0\ucd9c\ub85c \ud2b9\ubcc4\ud55c \uc21c\uac04\uc744 \ub354\uc6b1 \ube5b\ub098\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d \uc911\uc2ec\uc758 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ud504\ub77c\uc774\ube57 \ud53d\uc5c5<\/h3>\n\n\n\n<p>\uc5b4\uac8c\uc778\uc740 \uace0\uac1d\ub2d8\uc758 \ud3b8\uc758\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ubc1c\ub81b\ud30c\ud0b9 \uc11c\ube44\uc2a4\uc640 \ud504\ub77c\uc774\ube57 \ud53d\uc5c5 \uc635\uc158\uc744 \ud1b5\ud574 \ubc29\ubb38\ubd80\ud130 \uadc0\uac00\uae4c\uc9c0 \ubaa8\ub4e0 \uacfc\uc815\uc5d0\uc11c \ud488\uaca9\uacfc \ud3b8\uc548\ud568\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\ub9de\ucda4\ud615 \uc774\ubca4\ud2b8\uc640 \uc138\uc2ec\ud55c \uc5f0\ucd9c<\/h3>\n\n\n\n<p>\uc5b4\uac8c\uc778\uc740 \uace0\uac1d\ub2d8\uc758 \ud2b9\ubcc4\ud55c \ub0a0\uc744 \ub354\uc6b1 \ud2b9\ubcc4\ud558\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4. DJ\uc640 \uc774\ubca4\ud2b8 \uc804\ubb38\uac00\uc758 \uc138\uc2ec\ud55c \uc900\ube44\ub85c, \ub2f9\uc2e0\ub9cc\uc758 \uc18c\uc911\ud55c \uc21c\uac04\uc744 \uc78a\uc9c0 \ubabb\ud560 \ucd94\uc5b5\uc73c\ub85c \uc644\uc131\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ub9e4\ub825\uc801\uc778 \ud638\uc2a4\ud2b8\uc640 \ud568\uaed8\ud558\ub294 \uc2dc\uac04<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\ud488\uaca9\uacfc \ub9e4\ub825\uc744 \uacb8\ube44\ud55c \ud638\uc2a4\ud2b8<\/h3>\n\n\n\n<p>\uc5b4\uac8c\uc778\uc740 \uc5c4\uaca9\ud55c \uae30\uc900\uc744 \ud1b5\ud574 \uc120\ubc1c\ub41c \ub9e4\ub825\uc801\uc774\uace0 \ud488\uaca9 \uc788\ub294 \ud638\uc2a4\ud2b8\ub4e4\uacfc \ud568\uaed8\ud560 \uc218 \uc788\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ubd84\uc704\uae30\uc640 \ucde8\ud5a5\uc5d0 \ub9de\ucdb0, \uc78a\uc9c0 \ubabb\ud560 \uc990\uac70\uc6c0\uacfc \ud3b8\uc548\ud568\uc744 \uc81c\uacf5\ud574 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uc5b4\uac8c\uc778\ub9cc\uc758 \uc790\uc720\ub86d\uace0 \ud488\uaca9 \uc788\ub294 \ubd84\uc704\uae30<\/h3>\n\n\n\n<p>\uc5b4\uac8c\uc778\uc740 \uc5ec\uc131 \uace0\uac1d\ub2d8\ub4e4\ub9cc\uc744 \uc704\ud55c \uc548\uc804\ud558\uace0 \uc790\uc720\ub85c\uc6b4 \uacf5\uac04\uc73c\ub85c, \ub204\uad6c\uc640 \ud568\uaed8\ud558\ub4e0 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub3c4\ub85d \uc138\uc2ec\ud558\uac8c \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud558\uace0 \uc2e0\ub8b0\ud560 \uc218 \uc788\ub294 \uc6b4\uc601<\/h2>\n\n\n\n<h3 class=\"wp-block-heading\">\uc815\ucc30\uc81c\ub97c \ud1b5\ud55c \ud569\ub9ac\uc801 \uac00\uaca9<\/h3>\n\n\n\n<p>\uc5b4\uac8c\uc778\uc740 \uc815\ucc30\uc81c\ub97c \uc6b4\uc601\ud558\uc5ec \ubaa8\ub4e0 \ube44\uc6a9\uc744 \uc0ac\uc804\uc5d0 \uba85\ud655\ud788 \uc548\ub0b4\ud569\ub2c8\ub2e4. \ucd94\uac00 \uc694\uae08 \uc5c6\uc774 \ud569\ub9ac\uc801\uc778 \uac00\uaca9\uc73c\ub85c \uace0\ud488\uaca9 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uaed8 \uc2e0\ub8b0\ub97c \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<h3 class=\"wp-block-heading\">\uace0\uac1d \uc2e0\ub8b0\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c<\/h3>\n\n\n\n<p>\uc5b4\uac8c\uc778\uc740 \uc5ec\uc131 \uace0\uac1d\ub2d8\ub4e4\uaed8 \ucd5c\uc0c1\uc758 \ub9cc\uc871\uc744 \uc81c\uacf5\ud558\uae30 \uc704\ud574 \ud22c\uba85\ud558\uace0 \uc2e0\ub8b0\ud560 \uc218 \uc788\ub294 \uc6b4\uc601\uc744 \ucca0\uc800\ud788 \uc9c0\ud0b5\ub2c8\ub2e4. \ud638\uc2a4\ud2b8 \uc120\ud0dd\uacfc \uc11c\ube44\uc2a4 \ub0b4\uc6a9\uc5d0 \uc788\uc5b4 \ubaa8\ub4e0 \uc815\ubcf4\ub97c \uba85\ud655\ud788 \uc81c\uacf5\ud558\uc5ec \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ub354 \uac00\uce58 \uc788\uac8c \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<\/p>\n\n\n\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n\n\n\n<h2 class=\"wp-block-heading\">\uac15\ub0a8\uc5d0\uc11c \ub2e4\uc2dc \ucc3e\uace0 \uc2f6\uc740 \ud2b9\ubcc4\ud55c \uacf5\uac04<\/h2>\n\n\n\n<p>\uac15\ub0a8 \ud638\uc2a4\ud2b8\ubc14 \uc5b4\uac8c\uc778\uc740 \uc5ec\uc131 \uace0\uac1d\ub2d8\ub4e4\ub9cc\uc744 \uc704\ud55c \ub3c5\ubcf4\uc801\uc778 \ub9e4\ub825\uacfc \ud2b9\ubcc4\ud568\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud488\uaca9 \uc788\ub294 \uc11c\ube44\uc2a4\uc640 \uc138\ub828\ub41c \uacf5\uac04\uc740 \uc77c\uc0c1\uc5d0\uc11c \ubc97\uc5b4\ub098 \ud2b9\ubcc4\ud55c \ucd94\uc5b5\uc744 \ub9cc\ub4e4\uc5b4 \ub4dc\ub9bd\ub2c8\ub2e4.<br>\uc5b4\uac8c\uc778\uc5d0\uc11c\uc758 \uc2dc\uac04\uc740 \ub2f9\uc2e0\ub9cc\uc744 \uc704\ud55c \ud488\uaca9\uacfc \uc990\uac70\uc6c0\uc774 \uc870\ud654\ub97c \uc774\ub8e8\ub294 \uc21c\uac04\uc73c\ub85c \uae30\uc5b5\ub420 \uac83\uc785\ub2c8\ub2e4. \uc9c0\uae08 \ubc14\ub85c \uc5b4\uac8c\uc778\uc5d0\uc11c \ub2f9\uc2e0\ub9cc\uc758 \uc774\uc57c\uae30\ub97c \uc2dc\uc791\ud574 \ubcf4\uc138\uc694!<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \ud638\uc2a4\ud2b8\ubc14 \uc5b4\uac8c\uc778\uc740 \uc5ec\uc131 \uace0\uac1d\ub2d8\ub9cc\uc744 \uc704\ud574 \uc900\ube44\ub41c \uc138\ub828\ub41c \uacf5\uac04\uc73c\ub85c, \uc77c\uc0c1\uc758 \ud2c0\uc744 \ubc97\uc5b4\ub098 \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4. <\/p>\n","protected":false},"featured_media":2386,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[31],"class_list":["post-5533","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-hostbar"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5533","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/2386"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5533"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5533"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}