{"id":5521,"date":"2025-01-06T20:15:59","date_gmt":"2025-01-06T11:15:59","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/gninfo\/%ea%b0%95%eb%82%a8-%ea%b5%ac%ea%b5%ac%eb%8b%a8\/"},"modified":"2025-03-26T12:41:34","modified_gmt":"2025-03-26T03:41:34","slug":"gugudan","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/gugudan\/","title":{"rendered":"\uad6c\uad6c\ub2e8"},"content":{"rendered":"\n<h2 class=\"wp-block-heading\">\uac15\ub0a8 \uca5c\uc624 \uad6c\uad6c\ub2e8 &#8211; \uace0\uae09\uc2a4\ub7ec\uc6c0\uacfc \ud3b8\uc548\ud568\uc744 \ub3d9\uc2dc\uc5d0<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uad6c\uad6c\ub2e8\uc740 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4\uc640 \uc138\ub828\ub41c \ubd84\uc704\uae30\uac00 \ub3cb\ubcf4\uc774\ub294 \uacf5\uac04\uc73c\ub85c, \ud488\uaca9 \ub192\uc740 \uc220\uc790\ub9ac\uc640 \ud3b8\uc548\ud55c \ubd84\uc704\uae30\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub113\uace0 \uc5ec\uc720\ub85c\uc6b4 \uacf5\uac04\uc5d0\uc11c \uace0\uac1d\ub2d8\uaed8 \ucd5c\uc0c1\uc758 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uac15\ub0a8\uc5d0\uc11c \uac00\uc7a5 \ud070 \uaddc\ubaa8\ub97c \uc790\ub791\ud558\ub294 \uc774\uacf3\uc740 \ub2e4\uc591\ud55c \uace0\uac1d\ub4e4\uc758 \uc694\uad6c\ub97c \ucda9\uc871\uc2dc\ud0ac \uc218 \uc788\ub294 \uc644\ubcbd\ud55c \uc7a5\uc18c\uc785\ub2c8\ub2e4. \uac15\ub0a8\uc5d0\uc11c \ud2b9\ubcc4\ud55c \ub0a0\uc744 \uc990\uae30\uace0 \uc2f6\ub2e4\uba74, \uad6c\uad6c\ub2e8\uc740 \uadf8 \uc120\ud0dd\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \ubaa8\uc784\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uacf5\uac04<\/h2>\n\n\n\n<p>&#8220;\uad6c\uad6c\ub2e8&#8221;\uc740 \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uc740 \ubb3c\ub860, \uc0dd\uc77c \ud30c\ud2f0\ub098 \uce5c\uad6c \ubaa8\uc784 \ub4f1 \ub2e4\uc591\ud55c \uc774\ubca4\ud2b8\ub97c \uc704\ud55c \ucd5c\uc801\uc758 \uacf5\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud2b9\ud788 \uc0dd\uc77c \ud30c\ud2f0\ub098 \uc911\uc694\ud55c \ub0a0\uc744 \uae30\ub150\ud558\ub824\ub294 \ubd84\ub4e4\uaed8 \uac15\ub825\ud788 \ucd94\ucc9c\ub418\ub294 \uacf3\uc785\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8\uc11c \ud3b8\uc548\ud558\uac8c \uc220\uacfc \uc74c\uc2dd\uc744 \uc990\uae30\uba70 \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub3c4\ub85d \ubaa8\ub4e0 \uac83\uc774 \uc900\ube44\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \ub0a8\ub140 \uad6c\ubd84 \uc5c6\uc774 \ub204\uad6c\ub098 \ud3b8\uc548\ud558\uac8c \ubc29\ubb38\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<p>&#8220;\uad6c\uad6c\ub2e8&#8221;\uc740 \uace0\uac1d\ub2d8\uc774 \ud3b8\uc548\ud558\uac8c \ubc29\ubb38\ud560 \uc218 \uc788\ub3c4\ub85d \ubc1c\ub81b\ud30c\ud0b9\uacfc \ub9ac\ubb34\uc9c4 \ud53d\uc5c5 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub9ac\ubb34\uc9c4\uc744 \uc608\uc57d\ud574\uc8fc\uc2dc\uba74 \ud3b8\uc548\ud558\uac8c \uc774\ub3d9\ud558\uc2e4 \uc218 \uc788\uc73c\uba70, \ubc1c\ub81b\ud30c\ud0b9 \uc11c\ube44\uc2a4\ub97c \ud1b5\ud574 \uc8fc\ucc28 \ubb38\uc81c\ub3c4 \uac71\uc815 \uc5c6\uc774 \ud574\uacb0\ub429\ub2c8\ub2e4. \ub610\ud55c \ud2b9\ubcc4\ud55c \ubd84\uc704\uae30\ub97c \uc704\ud55c \uc544\ud2f0\uc2a4\ud2b8\ub098 DJ \uc12d\uc678\ub3c4 \uac00\ub2a5\ud558\uc5ec (\ubcc4\ub3c4\uc758 \ube44\uc6a9 \ubc1c\uc0dd), \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \ud2b9\ubcc4\ud55c \uc2dc\uac04\uc744 \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d \ub9de\ucda4\ud615 \uc138\uc2ec\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<p>&#8220;\uad6c\uad6c\ub2e8&#8221;\uc5d0\uc11c\ub294 \uace0\uac1d\ub2d8\uc744 \uc704\ud55c \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uc138\uc2ec\ud558\uac8c \uc900\ube44\ub41c \uacf5\uac04\uc5d0\uc11c \ucd5c\uace0\uae09 \uc11c\ube44\uc2a4\ub97c \uacbd\ud5d8\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ucca0\uc800\ud55c \ub9c8\uc778\ub4dc \uad50\uc721\uc744 \ubc1b\uc740 \uc544\uac00\uc528\ub4e4\uc774 \uace0\uac1d\ub2d8\uc744 \ubc30\ub824\ud558\uba70 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub3c4\ub85d \ub3d5\uc2b5\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uc758 \ub9cc\uc871\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud558\uba70, \ud2b9\ubcc4\ud558\uace0 \ucc28\ubcc4\ud654\ub41c \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\uc758 \uc644\ubcbd\ud55c \ubc38\ub7f0\uc2a4<\/h2>\n\n\n\n<p>\ube44\uc988\ub2c8\uc2a4\uc640 \uc811\ub300\ub294 \uc11c\ub85c \ubc00\uc811\ud55c \uad00\uacc4\ub97c \uac00\uc9c0\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc811\ub300\ub294 \ube44\uc988\ub2c8\uc2a4\uc758 \uc131\uacf5\uc5d0 \ud070 \uc601\ud5a5\uc744 \ubbf8\uce69\ub2c8\ub2e4. &#8220;\uad6c\uad6c\ub2e8&#8221;\uc740 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uacf5\uac04\uacfc \ucca0\uc800\ud55c \uc11c\ube44\uc2a4\ub85c \ube44\uc988\ub2c8\uc2a4 \ubbf8\ud305\uacfc \uc811\ub300 \ubaa8\ub450\ub97c \uc644\ubcbd\ud558\uac8c \uc9c0\uc6d0\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \ube44\uc988\ub2c8\uc2a4 \uc131\uacfc\ub97c \uadf9\ub300\ud654\ud560 \uc218 \uc788\ub3c4\ub85d \ub3d5\uc2b5\ub2c8\ub2e4. \ubaa8\ub4e0 \uace0\uac1d\ub2d8\uaed8 \ub9de\ucda4\ud615 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uc5ec, \uc131\uacf5\uc801\uc778 \uc811\ub300\uc640 \ubbf8\ud305\uc774 \uc774\ub8e8\uc5b4\uc9c8 \uc218 \uc788\ub3c4\ub85d \ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud22c\uba85\ud55c \uac00\uaca9, \uc815\uc9c1\ud55c \uc11c\ube44\uc2a4<\/h2>\n\n\n\n<p>&#8220;\uad6c\uad6c\ub2e8&#8221;\uc740 \uac70\ud488 \uc5c6\ub294 \uac00\uaca9\uacfc \ud22c\uba85\ud55c \uc815\ucc30\uc81c\ub85c \uc6b4\uc601\ub418\uc5b4 \uace0\uac1d\ub2d8\uaed8 \ubd88\ud544\uc694\ud55c \ucd94\uac00 \ube44\uc6a9\uc744 \uc694\uad6c\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uc8fc\ub300\uc640 \uad00\ub828\ub41c \ubaa8\ub4e0 \uc0ac\ud56d\uc740 \ubbf8\ub9ac \uc548\ub0b4\ud574\ub4dc\ub9ac\uba70, \uac00\uaca9\uc5d0 \ub300\ud574 \uac71\uc815\ud560 \ud544\uc694 \uc5c6\uc774 \ud3b8\uc548\ud558\uac8c \uc990\uae30\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud22c\uba85\ud55c \uac00\uaca9\uacfc \uc815\uc9c1\ud55c \uc11c\ube44\uc2a4\ub85c, \uace0\uac1d\ub2d8\uc758 \uc2dc\uac04\uc744 \ub0ad\ube44\ud558\uc9c0 \uc54a\ub3c4\ub85d \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ud55c \ubc88 \ubc29\ubb38, \uc9c0\uc18d\uc801\uc778 \uad00\uacc4<\/h2>\n\n\n\n<p>&#8220;\uad6c\uad6c\ub2e8&#8221;\uc740 \uace0\uac1d\ub2d8\uacfc\uc758 \uc9c0\uc18d\uc801\uc778 \uad00\uacc4\ub97c \ub9e4\uc6b0 \uc18c\uc911\ud558\uac8c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ud55c\ubc88 \ubc29\ubb38\ud55c \uace0\uac1d\ub2d8\ub4e4\uc740 \ub300\ubd80\ubd84 \ub2e8\uace8\uc774 \ub418\uc5b4 \ub2e4\uc2dc \ucc3e\uc544\uc624\uc2ed\ub2c8\ub2e4. \uc2e0\ub8b0\uc640 \uc815\uc9c1\uc744 \uae30\ubc18\uc73c\ub85c \uace0\uac1d\ub2d8\uacfc\uc758 \uc778\uc5f0\uc744 \uc774\uc5b4\uac00\uba70, \ucd08\uc774\uc2a4 \uac00\ub2a5\ud55c \uc544\uac00\uc528 \uc22b\uc790\ub098 \ub300\uae30 \uc2dc\uac04\uc5d0 \ub300\ud574\uc11c\ub3c4 \uacfc\uc7a5 \uc5c6\uc774 \uc815\ud655\ud558\uac8c \uc548\ub0b4\ud574 \ub4dc\ub9bd\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8 \ud56d\uc0c1 \ub9cc\uc871\uc2a4\ub7ec\uc6b4 \uc2dc\uac04\uc744 \uc81c\uacf5\ud558\uae30 \uc704\ud574 \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \uc544\uac00\uc528\ub4e4<\/h2>\n\n\n\n<p>&#8220;\uad6c\uad6c\ub2e8&#8221;\uc5d0\ub294 \ub2e4\uc591\ud55c \uc2a4\ud0c0\uc77c\uc758 \uc544\uac00\uc528\ub4e4\uc774 \uc900\ube44\ub418\uc5b4 \uc788\uc5b4, \uace0\uac1d\ub2d8\uc740 \uc790\uc2e0\uc774 \uc120\ud638\ud558\ub294 \uc2a4\ud0c0\uc77c\uc744 \uc120\ud0dd\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uae4c\ub2e4\ub85c\uc6b4 \uae30\uc900\uc744 \ud1b5\ud574 \uc120\ubcc4\ub41c \uc544\uac00\uc528\ub4e4\uc740 \ubbf8\ubaa8\uc640 \ub9c8\uc778\ub4dc \ubaa8\ub450\uc5d0\uc11c \uc218\uc900 \ub192\uc740 \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc544\uac00\uc528\ub97c \uc120\ud0dd\ud558\uc2dc\uba74 \ub429\ub2c8\ub2e4. &#8220;\uad6c\uad6c\ub2e8&#8221;\ub9cc\uc758 \ud2b9\ubcc4\ud55c \ub9e4\ub825\uc744 \ub290\uaef4\ubcf4\uc138\uc694.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\ub0b4\uc0c1 \uac71\uc815 \uc5c6\ub294 \uc220\uc790\ub9ac<\/h2>\n\n\n\n<p>&#8220;\uad6c\uad6c\ub2e8&#8221;\uc5d0\uc11c\ub294 \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uac70\uc6b4 \uc220\uc790\ub9ac\ub97c \ubcf4\ub0bc \uc218 \uc788\ub3c4\ub85d \ucca0\uc800\ud558\uac8c \uad00\ub9ac\ub41c \uc2dc\uc2a4\ud15c\uc744 \uc790\ub791\ud569\ub2c8\ub2e4. \uace0\uac1d\ub2d8\uaed8\uc11c \ud3b8\uc548\ud558\uac8c \uc990\uae38 \uc218 \uc788\ub3c4\ub85d \uc8fc\ub300\uc640 \uc11c\ube44\uc2a4 \ubaa8\ub450\uc5d0 \uc138\uc2ec\ud55c \ubc30\ub824\ub97c \uae30\uc6b8\uc774\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ub0b4\uc0c1 \uac71\uc815 \uc5c6\uc774 \uc990\uac70\uc6b4 \uc2dc\uac04\uc744 \ubcf4\ub0bc \uc218 \uc788\ub3c4\ub85d \uc9c0\uc6d0\ud558\uba70, \uace0\uac1d\ub2d8\uc758 \ub9cc\uc871\uc744 \uc704\ud574 \ucd5c\uc120\uc744 \ub2e4\ud569\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uca5c\uc624 \uad6c\uad6c\ub2e8\ub9cc\uc758 \ucc28\ubcc4\ud654\ub41c \ub9e4\ub825<\/h2>\n\n\n\n<p>\uac15\ub0a8 \uca5c\uc624 \uad6c\uad6c\ub2e8\uc740 \ub2e4\ub978 \uacf3\uacfc \ucc28\ubcc4\ud654\ub41c \ubd84\uc704\uae30\uc640 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc544\uac00\uc528\ub4e4\ub85c \uad6c\uc131\ub41c \uc2dc\uc2a4\ud15c\uc744 \uc790\ub791\ud569\ub2c8\ub2e4. \ud3b8\uc548\ud55c \ubd84\uc704\uae30\uc5d0\uc11c \uc220\uacfc \ub178\ub798\ub97c \uc990\uae30\uba70, \ud130\uce58\uc758 \uc790\uc720\ub85c\uc6c0\ub3c4 \uc81c\uacf5\ub429\ub2c8\ub2e4. \uc218\uc704\uc640 \uc2a4\ud0c0\uc77c\uc774 \ub2e4\uc591\ud558\uc5ec \uace0\uac1d\ub2d8\uc758 \ucde8\ud5a5\uc5d0 \ub9de\ub294 \uc544\uac00\uc528\ub97c \uc120\ud0dd\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h2 class=\"wp-block-heading\">\uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04 \ucd5c\uc6b0\uc120<\/h2>\n\n\n\n<p>&#8220;\uad6c\uad6c\ub2e8&#8221;\uc740 \uace0\uac1d\ub2d8\uc758 \uc18c\uc911\ud55c \uc2dc\uac04\uc744 \ucd5c\uc6b0\uc120\uc73c\ub85c \uc0dd\uac01\ud569\ub2c8\ub2e4. \ubaa8\ub4e0 \uc11c\ube44\uc2a4\ub294 \ud22c\uba85\ud558\uac8c \uc81c\uacf5\ub418\uba70, \uace0\uac1d\ub2d8\uaed8 \ubd88\ud3b8\ud568\uc744 \ub4dc\ub9ac\uc9c0 \uc54a\ub3c4\ub85d \uc138\uc2ec\ud558\uac8c \uad00\ub9ac\ub429\ub2c8\ub2e4. \uac15\ub0a8 \uca5c\uc624 &#8220;\uad6c\uad6c\ub2e8&#8221;\uc5d0\uc11c \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc744 \ub204\ub9ac\uc2e4 \uc218 \uc788\ub3c4\ub85d, \uc8fc\ub300\uc640 \uc11c\ube44\uc2a4\uc5d0 \ub300\ud574 \uba85\ud655\ud558\uac8c \uc548\ub0b4\ud574 \ub4dc\ub9ac\uba70, \ucd5c\uc0c1\uc758 \uc220\uc790\ub9ac \uacbd\ud5d8\uc744 \uc120\uc0ac\ud560 \uac83\uc785\ub2c8\ub2e4. \uc5b8\uc81c\ub4e0\uc9c0 \ubb38\uc758\ud574 \uc8fc\uc138\uc694.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8 \uca5c\uc624 \uad6c\uad6c\ub2e8\uc740 \uace0\uae09\uc2a4\ub7ec\uc6b4 \uc778\ud14c\ub9ac\uc5b4\uc640 \uc138\ub828\ub41c \ubd84\uc704\uae30\uac00 \ub3cb\ubcf4\uc774\ub294 \uacf5\uac04\uc73c\ub85c, \ud488\uaca9 \ub192\uc740 \uc220\uc790\ub9ac\uc640 \ud3b8\uc548\ud55c \ubd84\uc704\uae30\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. <\/p>\n","protected":false},"featured_media":5603,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[29],"class_list":["post-5521","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-dot5"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5521","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/5603"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5521"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5521"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}