{"id":5339,"date":"2025-01-10T00:36:27","date_gmt":"2025-01-09T15:36:27","guid":{"rendered":"https:\/\/dk062.mycafe24.com\/?post_type=gninfo&#038;p=5339"},"modified":"2025-03-26T12:50:56","modified_gmt":"2025-03-26T03:50:56","slug":"perfect","status":"publish","type":"gninfo","link":"https:\/\/roomguide.kr\/gninfo\/perfect\/","title":{"rendered":"\ud37c\ud399\ud2b8"},"content":{"rendered":"\n<h3 class=\"wp-block-heading\">\ud37c\ud399\ud2b8 \uac00\ub77c\uc624\ucf00: \uac15\ub0a8 \ucd5c\uace0\uc758 \uc5d4\ud130\ud14c\uc778\uba3c\ud2b8 \uacf5\uac04<\/h3>\n\n\n\n<p>\uac15\ub0a8\uad6c \ub17c\ud604\ub3d9\uc5d0 \uc704\uce58\ud55c <strong>\ud37c\ud399\ud2b8 \uac00\ub77c\uc624\ucf00<\/strong>\ub294 \ub7ed\uc154\ub9ac \uac00\ub77c\uc624\ucf00\ub85c, \ud2b9\ubcc4\ud55c \ud30c\ud2f0\uc640 \ubaa8\uc784\uc744 \uc704\ud55c \ucd5c\uc801\uc758 \uc7a5\uc18c\uc785\ub2c8\ub2e4. \uacfc\uac70 \uc625\ud0c0\uace4\uc774 \uc0c8\ub86d\uac8c \ub9ac\ub178\ubca0\uc774\uc158\ub418\uc5b4 \ud0c4\uc0dd\ud55c \uc774\uacf3\uc740 \ub0a8\ub140 \ubaa8\ub450 \uc990\uae38 \uc218 \uc788\ub294 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ud30c\ud2f0 \uacf5\uac04\uc73c\ub85c, \uac15\ub0a8\uc5d0\uc11c \uc190\uaf3d\ud788\ub294 \uc778\uae30 \uba85\uc18c\uc785\ub2c8\ub2e4.<\/p>\n\n\n\n<h4 class=\"wp-block-heading\">\ud504\ub9ac\ubbf8\uc5c4 \uacbd\ud5d8\uacfc \uac00\uaca9<\/h4>\n\n\n\n<p>\ud37c\ud399\ud2b8 \uac00\ub77c\uc624\ucf00\ub294 \uace0\uae09 \uc11c\ube44\uc2a4\uc640 \ucd5c\uace0\uc758 \uc2dc\uc124\uc744 \uc790\ub791\ud558\uba70, \uac00\uaca9\uc740 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4:<\/p>\n\n\n\n<ul class=\"wp-block-list\">\n<li><strong>1\ubd80<\/strong>: 35\ub9cc \uc6d0<\/li>\n\n\n\n<li><strong>2\ubd80<\/strong>: 16\ub9cc \uc6d0<\/li>\n<\/ul>\n\n\n\n<p>\uc154\uce20\ub8f8\uc774\ub098 \ud558\uc774\ud37c\ube14\ub9ad\uacfc \ube44\uad50\ud588\uc744 \ub54c \uac00\uaca9\uc774 \ub2e4\uc18c \ub192\uc9c0\ub9cc, \uc2dc\uc124\uacfc \uaddc\ubaa8 \uba74\uc5d0\uc11c \uc555\ub3c4\uc801\uc778 \uac00\uce58\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud2b9\ud788, \ud504\ub9ac\ubbf8\uc5c4 \uc704\uc2a4\ud0a4 \uc138\ud2b8\uc640 \ud568\uaed8 \uace0\uae09\uc2a4\ub7ec\uc6b4 \ubd84\uc704\uae30\ub97c \uacbd\ud5d8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h4 class=\"wp-block-heading\">\ucd5c\uace0\uc758 \uc2dc\uc124<\/h4>\n\n\n\n<p>\ud37c\ud399\ud2b8 \uac00\ub77c\uc624\ucf00\ub294 <strong>50\uac1c \uc774\uc0c1\uc758 \ub8f8<\/strong>\uc744 \ubcf4\uc720\ud558\uace0 \uc788\uc73c\uba70, \uc18c\ud615, \uc911\ud615, \ub300\ud615 \ub8f8\uc73c\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \ubaa8\ub4e0 \ub8f8\uc740 \ucd5c\ucca8\ub2e8 \uc74c\ud5a5 \uc7a5\ube44\uc640 \uc138\ub828\ub41c \uc778\ud14c\ub9ac\uc5b4\ub85c \uafb8\uba70\uc838 \uc788\uc73c\uba70, \uace0\uac1d\ub4e4\uc774 \uc990\uac81\uace0 \uc78a\uc9c0 \ubabb\ud560 \ud30c\ud2f0 \ubd84\uc704\uae30\ub97c \ub204\ub9b4 \uc218 \uc788\ub3c4\ub85d \uc124\uacc4\ub418\uc5c8\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<h4 class=\"wp-block-heading\">\ud2b9\ubcc4 \uc11c\ube44\uc2a4<\/h4>\n\n\n\n<ul class=\"wp-block-list\">\n<li><strong>\uc804\ubb38\uc801\uc778 \uc9c1\uc6d0 \uc11c\ube44\uc2a4<\/strong>: \ud37c\ud399\ud2b8 \uac00\ub77c\uc624\ucf00\ub294 \uac15\ub0a8\uad6c\uccad\uc758 \ud5c8\uac00\ub97c \ubc1b\uc740 <strong>\ud569\ubc95 1\uae09 \uc5d4\ud130\ud14c\uc778\uba3c\ud2b8 \uc5c5\uc18c<\/strong>\ub85c, \uc57d 100\uba85\uc758 \uc804\ubb38 \uc9c1\uc6d0\uc774 \uadfc\ubb34\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc694\uccad \uc2dc \ud30c\ud2b8\ub108(\ub808\uc774\ub514)\ub97c \uc120\ud0dd\ud560 \uc218 \uc788\ub294 \uc11c\ube44\uc2a4\ub3c4 \uc81c\uacf5\ub429\ub2c8\ub2e4.<\/li>\n\n\n\n<li><strong>\ubb34\ub8cc \ubc1c\ub81b \ubc0f \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/strong>: \uc790\ucc28 \uc774\uc6a9 \uace0\uac1d\uc5d0\uac8c\ub294 \uc608\uc57d \uc2dc \ubb34\ub8cc \ubc1c\ub81b \uc11c\ube44\uc2a4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ucc28\ub7c9\uc774 \uc5c6\ub294 \uace0\uac1d\ub3c4 \uac71\uc815 \uc5c6\uc774 \uc774\uc6a9\ud560 \uc218 \uc788\ub3c4\ub85d, \uac15\ub0a8 \uc9c0\uc5ed \ub0b4 \uc608\uc57d \uc190\ub2d8\uc5d0\uac8c\ub294 <strong>\ub7ed\uc154\ub9ac \ucc28\ub7c9 \ubb34\ub8cc \ud53d\uc5c5 \uc11c\ube44\uc2a4<\/strong>\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.<\/li>\n\n\n\n<li><strong>\uc774\ubca4\ud2b8 \uc815\ubcf4<\/strong>: \ud37c\ud399\ud2b8 \uac00\ub77c\uc624\ucf00\uc5d0\uc11c\ub294 \uc800\ub141 \uc2dc\uac04\ub300 \ud2b9\ubcc4 \uc774\ubca4\ud2b8\uac00 \uc790\uc8fc \uc5f4\ub9bd\ub2c8\ub2e4. \uc608\uc57d \uc2dc \uc9c4\ud589 \uc911\uc778 \uc774\ubca4\ud2b8\uc5d0 \ub300\ud55c \uc815\ubcf4\ub97c \ud655\uc778\ud560 \uc218 \uc788\uc73c\ub2c8, \ubc29\ubb38 \uc804 \uc608\uc57d\uc744 \uad8c\uc7a5\ud569\ub2c8\ub2e4.<\/li>\n<\/ul>\n\n\n\n<h4 class=\"wp-block-heading\">\uc608\uc57d \ubc0f \uc6b4\uc601 \uc2dc\uac04<\/h4>\n\n\n\n<p>\ud37c\ud399\ud2b8 \uac00\ub77c\uc624\ucf00\ub294 <strong>\uc624\ud6c4 6\uc2dc\ubd80\ud130 \ub2e4\uc74c \ub0a0 \uc624\ud6c4 3\uc2dc\uae4c\uc9c0<\/strong> \uc6b4\uc601\ub418\uba70, \ucda9\ubd84\ud788 \uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. <strong>24\uc2dc\uac04 \uc608\uc57d \uc0c1\ub2f4<\/strong> \uc11c\ube44\uc2a4\ub97c \ud1b5\ud574 \uc6d0\ud558\ub294 \ub0a0\uc9dc\uc640 \uc2dc\uac04\uc5d0 \ub9de\ucdb0 \uce5c\uc808\ud55c \uc0c1\ub2f4\uc744 \ubc1b\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/p>\n\n\n\n<p>\uac15\ub0a8\uc5d0\uc11c \ud2b9\ubcc4\ud55c \ubaa8\uc784, \uc0dd\uc77c \ud30c\ud2f0, \ud68c\uc2dd \ub4f1\uc744 \uacc4\ud68d \uc911\uc774\ub77c\uba74, <strong>\ud37c\ud399\ud2b8 \uac00\ub77c\uc624\ucf00<\/strong>\uc5d0\uc11c \ud488\uaca9 \uc788\ub294 \uacbd\ud5d8\uc744 \ub204\ub824\ubcf4\uc138\uc694.<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\uac15\ub0a8\uad6c \ub17c\ud604\ub3d9 \uc5d8\ub9ac\uc5d0\ub098 \ud638\ud154 \uc9c0\ud558\uc5d0 \uc704\uce58\ud55c \ud37c\ud399\ud2b8 \uac00\ub77c\uc624\ucf00\ub294 \ucd08\ub300\ud615 \uac00\ub77c\uc624\ucf00\ub85c \ucd5c\uace0\uc758 \uc2dc\uc124\uc744 \uc790\ub791\ud569\ub2c8\ub2e4.<\/p>\n","protected":false},"featured_media":2401,"parent":0,"template":"","meta":{"_acf_changed":true},"categories":[25],"class_list":["post-5339","gninfo","type-gninfo","status-publish","has-post-thumbnail","hentry","category-karaoke"],"acf":[],"_links":{"self":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo\/5339","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/gninfo"}],"about":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/types\/gninfo"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media\/2401"}],"wp:attachment":[{"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/media?parent=5339"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"https:\/\/roomguide.kr\/wp-json\/wp\/v2\/categories?post=5339"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}